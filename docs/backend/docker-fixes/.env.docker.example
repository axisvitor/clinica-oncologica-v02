# ============================================================================
# Environment Variables for Docker Compose
# ============================================================================
# Copy this file to .env and update with your production values

# --------------------------------------------------------------------------
# Redis Configuration
# --------------------------------------------------------------------------
REDIS_PASSWORD=change_this_to_strong_password_in_production
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --------------------------------------------------------------------------
# Celery Configuration
# --------------------------------------------------------------------------
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

# --------------------------------------------------------------------------
# Celery Flower (Monitoring Dashboard)
# --------------------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=change_this_to_strong_password_in_production
FLOWER_PORT=5555

# --------------------------------------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------------------------------------
# For Python 3.13, use psycopg (v3): postgresql+psycopg://
DATABASE_URL=postgresql+psycopg://user:password@host:5432/database

# --------------------------------------------------------------------------
# Firebase Admin SDK
# --------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40your-project.iam.gserviceaccount.com

# --------------------------------------------------------------------------
# Supabase
# --------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --------------------------------------------------------------------------
# Google Gemini AI
# --------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# --------------------------------------------------------------------------
# WhatsApp (Evolution API)
# --------------------------------------------------------------------------
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=your-instance-name

# --------------------------------------------------------------------------
# Application Settings
# --------------------------------------------------------------------------
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=change_this_to_random_secret_key_in_production
API_V1_PREFIX=/api/v1
PROJECT_NAME="Hormonia Backend API"

# --------------------------------------------------------------------------
# CORS Configuration
# --------------------------------------------------------------------------
ALLOWED_ORIGINS=https://your-frontend.com,https://app.your-domain.com
ALLOWED_HOSTS=your-backend.com,api.your-domain.com

# --------------------------------------------------------------------------
# JWT Configuration
# --------------------------------------------------------------------------
JWT_SECRET_KEY=change_this_to_random_jwt_secret_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------------------------------------
# Rate Limiting
# --------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=your-sentry-dsn-if-using-sentry

# --------------------------------------------------------------------------
# Workers Configuration
# --------------------------------------------------------------------------
WORKERS=4
WEB_CONCURRENCY=4

# --------------------------------------------------------------------------
# OpenTelemetry (Distributed Tracing)
# --------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=hormonia-backend
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# ============================================================================
# Security Notes:
# ============================================================================
# 1. NEVER commit this file with real credentials to version control
# 2. Use strong, randomly generated passwords (min 32 characters)
# 3. Rotate secrets regularly (every 90 days)
# 4. Use Docker secrets for sensitive values in production
# 5. Consider using external secret management (AWS Secrets Manager, Vault)
# ============================================================================
