# =============================================================================
# SENTRY CONFIGURATION FOR BACKEND (FastAPI)
# =============================================================================
# ENV Variable Naming Convention: SENTRY_* and MONITORING_SENTRY_*
# Copy this file to .env and fill in your actual values
# =============================================================================

# ============================================================================
# SENTRY CORE CONFIGURATION
# ============================================================================
# Prefer setting BOTH variables for compatibility across modules.
SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/123456
MONITORING_SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/123456

# Environment (development, staging, production)
APP_ENVIRONMENT=development
MONITORING_SENTRY_ENVIRONMENT=development

# ============================================================================
# PERFORMANCE MONITORING - SENTRY_*_SAMPLE_RATE
# ============================================================================
# Sampling rates for performance monitoring (0.0 to 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================================================
# APPLICATION METADATA - APP_*
# ============================================================================
APP_VERSION=1.0.0
