# =============================================================================
# SENTRY CONFIGURATION FOR BACKEND (FastAPI)
# =============================================================================
# ENV Variable Naming Convention: MONITORING_SENTRY_{ATTRIBUTE}
# Copy this file to .env and fill in your actual values
# =============================================================================

# ============================================================================
# SENTRY CORE CONFIGURATION - MONITORING_SENTRY_*
# ============================================================================
# Sentry DSN - Get this from your Sentry project settings
MONITORING_SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/123456

# Environment (development, staging, production)
APP_ENVIRONMENT=development

# ============================================================================
# PERFORMANCE MONITORING - MONITORING_SENTRY_*_RATE
# ============================================================================
# Sampling rates for performance monitoring (0.0 to 1.0)
MONITORING_SENTRY_TRACES_SAMPLE_RATE=0.1
MONITORING_SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================================================
# APPLICATION METADATA - APP_*
# ============================================================================
APP_VERSION=1.0.0

# ============================================================================
# OPTIONAL SENTRY CONFIGURATION - MONITORING_SENTRY_*
# ============================================================================
MONITORING_SENTRY_ENABLE_DEFAULT_PII=false
MONITORING_SENTRY_ENABLE_STACKTRACE=true
MONITORING_SENTRY_MAX_BREADCRUMBS=50
MONITORING_SENTRY_SHUTDOWN_TIMEOUT_SECONDS=2

# ============================================================================
# INTEGRATION TOGGLES - MONITORING_SENTRY_ENABLE_*
# ============================================================================
MONITORING_SENTRY_ENABLE_DB_INTEGRATION=true
MONITORING_SENTRY_ENABLE_REDIS_INTEGRATION=true
MONITORING_SENTRY_ENABLE_HTTPX_INTEGRATION=true

# ============================================================================
# PERFORMANCE THRESHOLDS - MONITORING_SENTRY_*_THRESHOLD_SECONDS
# ============================================================================
MONITORING_SENTRY_SLOW_QUERY_THRESHOLD_SECONDS=1.0
MONITORING_SENTRY_SLOW_REQUEST_THRESHOLD_SECONDS=2.0

# ============================================================================
# ERROR FILTERING - MONITORING_SENTRY_ENABLE_*
# ============================================================================
MONITORING_SENTRY_ENABLE_IGNORE_HEALTH_CHECKS=true
MONITORING_SENTRY_ENABLE_IGNORE_DEV_ERRORS=true
