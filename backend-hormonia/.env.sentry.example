# Sentry Configuration for Backend (FastAPI)
# Copy this file to .env and fill in your actual values

# Sentry DSN - Get this from your Sentry project settings
SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/123456

# Environment (development, staging, production)
ENVIRONMENT=development

# Sampling rates for performance monitoring (0.0 to 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Application version for release tracking
APP_VERSION=1.0.0

# Optional: Custom Sentry configuration
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ATTACH_STACKTRACE=true
SENTRY_MAX_BREADCRUMBS=50
SENTRY_SHUTDOWN_TIMEOUT=2

# Database monitoring (if using separate config)
SENTRY_DB_INTEGRATION=true
SENTRY_REDIS_INTEGRATION=true
SENTRY_HTTPX_INTEGRATION=true

# Performance monitoring thresholds
SENTRY_SLOW_QUERY_THRESHOLD=1.0
SENTRY_SLOW_REQUEST_THRESHOLD=2.0

# Error filtering
SENTRY_IGNORE_HEALTH_CHECKS=true
SENTRY_IGNORE_DEVELOPMENT_ERRORS=true