# =============================================================================
# QUIZ INTERFACE CORS CONFIGURATION
# =============================================================================
# ENV Variable Naming Convention: {CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
# Copy to .env and update with your actual values
# =============================================================================

# ============================================================================
# CORS CONFIGURATION - CORS_*
# ============================================================================
# Local development with quiz interface
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:3001","http://localhost:5174","http://localhost:8080","https://*.railway.app","https://quiz-mensal-interface.railway.app","https://frontend-v2.railway.app","https://quiz-*.railway.app","https://*-quiz.railway.app"]

# Alternative comma-separated format:
# CORS_ALLOWED_ORIGINS="http://localhost:3001,http://localhost:5174,https://quiz-mensal-interface.railway.app,https://quiz-*.railway.app"

# ============================================================================
# QUIZ CONFIGURATION - QUIZ_*
# ============================================================================
# Enable quiz via link instead of WhatsApp conversation
QUIZ_ENABLE_VIA_LINK=true

# Quiz interface base URL (update with your Railway URL)
QUIZ_BASE_URL="https://quiz-mensal-interface.railway.app/quiz/monthly"

# Quiz token configuration
QUIZ_TOKEN_SECRET="your-secure-quiz-token-secret-here"
QUIZ_TOKEN_EXPIRY_HOURS=72

# ============================================================================
# APPLICATION CONFIGURATION - APP_*
# ============================================================================
APP_ENABLE_DEBUG=false
APP_ENVIRONMENT="production"
SECURITY_SECRET_KEY="your-secret-key-here"

# ============================================================================
# SUPABASE CONFIGURATION - SUPABASE_*
# ============================================================================
SUPABASE_URL="your-supabase-project-url"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ============================================================================
# DATABASE CONFIGURATION - DATABASE_*
# ============================================================================
DATABASE_URL="postgresql://postgres:[password]@[host]:[port]/[database]"

# ============================================================================
# REDIS CONFIGURATION - REDIS_*
# ============================================================================
REDIS_URL="redis://red-xyz:6379"
REDIS_PASSWORD="your-redis-password"
REDIS_HOST="red-xyz.railway.app"
REDIS_PORT=6379
REDIS_ENABLE_SSL=true
REDIS_SSL_CERT_REQS="required"

# ============================================================================
# AI CONFIGURATION - AI_GEMINI_*
# ============================================================================
AI_GEMINI_API_KEY="your-gemini-api-key"

# ============================================================================
# MONITORING CONFIGURATION - MONITORING_*
# ============================================================================
MONITORING_ENABLE_DEBUG=false

# Resource thresholds
RESOURCE_CPU_THRESHOLD=85.0
RESOURCE_MEMORY_THRESHOLD=90.0

# ============================================================================
# CACHE CONFIGURATION - REDIS_*
# ============================================================================
REDIS_POOL_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT_SECONDS=10.0
