# =============================================================================
# QUIZ INTERFACE CONFIGURATION (BACKEND)
# =============================================================================
# ENV Variable Naming Convention: {CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
# Copy to .env and update with your actual values
# =============================================================================

# ============================================================================
# CORS CONFIGURATION - CORS_*
# ============================================================================
# Local development with quiz interface (explicit URLs only - no wildcards)
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:3001","http://localhost:5174","http://localhost:8080"]

# For production, set explicit URLs via CORS_FRONTEND_URL and CORS_QUIZ_URL:
# CORS_FRONTEND_URL=https://your-frontend.railway.app
# CORS_QUIZ_URL=https://your-quiz.railway.app

# ============================================================================
# QUIZ CONFIGURATION - QUIZ_*
# ============================================================================
# Enable quiz via link instead of WhatsApp conversation
QUIZ_ENABLE_VIA_LINK=true

# Quiz interface base URL (no path)
QUIZ_BASE_URL=https://quiz-mensal-interface.railway.app

# Quiz token configuration
QUIZ_TOKEN_SECRET=your-secure-quiz-token-secret-here
QUIZ_TOKEN_EXPIRY_HOURS=72

# ============================================================================
# APPLICATION CONFIGURATION - APP_*
# ============================================================================
APP_ENABLE_DEBUG=false
APP_ENVIRONMENT=production

# ============================================================================
# SECURITY CONFIGURATION - SECURITY_*
# ============================================================================
SECURITY_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE
SECURITY_CSRF_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE
ENCRYPTION_KEY_CURRENT=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE
HASH_SALT=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE
PHI_ENCRYPTION_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE

# ============================================================================
# DATABASE CONFIGURATION - DATABASE_*
# ============================================================================
DATABASE_URL=postgresql+psycopg://postgres:[password]@[host]:[port]/[database]?sslmode=require

# ============================================================================
# REDIS CONFIGURATION - REDIS_*
# ============================================================================
REDIS_URL=rediss://default:your-redis-password@red-xyz.railway.app:6379/0
REDIS_PASSWORD=your-redis-password
REDIS_HOST=red-xyz.railway.app
REDIS_PORT=6379
REDIS_ENABLE_SSL=true
REDIS_SSL_CERT_REQS=required
REDIS_POOL_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT_SECONDS=10.0

# ============================================================================
# AI CONFIGURATION - AI_GEMINI_*
# ============================================================================
AI_GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# MONITORING CONFIGURATION - MONITORING_*
# ============================================================================
MONITORING_ENABLE_DEBUG=false
RESOURCE_CPU_THRESHOLD=85.0
RESOURCE_MEMORY_THRESHOLD=90.0
