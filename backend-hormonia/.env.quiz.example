# Quiz Interface CORS Configuration Example
# Copy to .env and update with your actual values

# === QUIZ CORS CONFIGURATION ===
# Local development with quiz interface
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:3001","http://localhost:5174","http://localhost:8080","https://*.railway.app","https://quiz-mensal-interface.railway.app","https://frontend-v2.railway.app","https://quiz-*.railway.app","https://*-quiz.railway.app"]

# Alternative comma-separated format:
# ALLOWED_ORIGINS="http://localhost:3001,http://localhost:5174,https://quiz-mensal-interface.railway.app,https://quiz-*.railway.app"

# === QUIZ CONFIGURATION ===
# Enable quiz via link instead of WhatsApp conversation
MONTHLY_QUIZ_VIA_LINK=true

# Quiz interface base URL (update with your Railway URL)
MONTHLY_QUIZ_BASE_URL="https://quiz-mensal-interface.railway.app/quiz/monthly"

# Quiz token configuration
MONTHLY_QUIZ_TOKEN_SECRET="your-secure-quiz-token-secret-here"
MONTHLY_QUIZ_TOKEN_EXPIRY_HOURS=72

# === BASIC CONFIGURATION ===
DEBUG=false
ENVIRONMENT="production"
SECRET_KEY="your-secret-key-here"

# Supabase Configuration
SUPABASE_URL="your-supabase-project-url"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database
DATABASE_URL="postgresql://postgres:[password]@[host]:[port]/[database]"

# Redis (for Railway Redis addon)
REDIS_URL="redis://red-xyz:6379"
REDIS_PASSWORD="your-redis-password"
REDIS_HOST="red-xyz.railway.app"
REDIS_PORT=6379
REDIS_SSL=true
REDIS_SSL_CERT_REQS="required"

# AI Configuration
GEMINI_API_KEY="your-gemini-api-key"

# === PRODUCTION OPTIMIZATIONS ===
# Disable monitoring debug for better performance
MONITORING_DEBUG=false

# Optimize resource thresholds
RESOURCE_CPU_THRESHOLD=85.0
RESOURCE_MEMORY_THRESHOLD=90.0

# Cache configuration
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=10.0