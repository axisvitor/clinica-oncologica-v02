# Redis Configuration - Unified Client (redis-py 6.0.0)
# Copy this file to .env and update with your actual values

# Primary connection settings
ENABLE_REDIS=true
REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT
REDIS_PASSWORD=YOUR_PASSWORD
REDIS_HOST=YOUR_HOST
REDIS_PORT=6379

# SSL/TLS Configuration
# Note: Set to false if your Redis server doesn't use SSL/TLS
# Redis Cloud free tier (port 14149) typically does NOT use SSL
REDIS_SSL=false
REDIS_SSL_CERT_REQS=none

# Connection Pool Settings
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=10.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# Database Isolation
# Use different DB numbers for different purposes (0-15 available)
REDIS_ENABLE_DB_ISOLATION=true
REDIS_CACHE_DB=1          # Application cache
REDIS_BROKER_DB=0         # Celery broker
REDIS_SESSION_DB=2        # User sessions
REDIS_RATE_LIMIT_DB=3     # Rate limiting

# Celery Configuration
CELERY_BROKER_URL=redis://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/0
CELERY_RESULT_BACKEND=redis://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/0
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_TIME_LIMIT=300
CELERY_WORKER_SOFT_TIME_LIMIT=240
CELERY_QUEUES=celery,flows,quiz,maintenance,monitoring
