# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and update with your actual values
# See docs/deployment/RAILWAY_ENVIRONMENT_VARIABLES.md for complete guide
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL/AWS RDS)
# ============================================================================
# CRITICAL: Must include ?sslmode=require for production (Railway/AWS RDS)
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
#
# Example (Production):
# DATABASE_URL=postgresql+psycopg://app_user:PASSWORD@your-cluster.cluster-abcdefghijkl.us-east-1.rds.amazonaws.com:5432/clinica_oncologica?sslmode=require
#
# Example (Development):
# DATABASE_URL=postgresql+psycopg://localhost:5432/hormonia_dev
#
# SSL Mode Options:
# - require: Required for production (AWS RDS/Railway)
# - verify-full: Full certificate verification (most secure)
# - disable: No SSL (development only, NEVER in production)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DB_POOL_SIZE=30
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Primary connection settings
ENABLE_REDIS=true
# CRITICAL: Use rediss:// (with two 's') for SSL/TLS connections in production
# Format: rediss://default:PASSWORD@HOST:PORT
#
# Example (Production):
# REDIS_URL=rediss://default:PASSWORD@redis-production.railway.app:6379
#
# Example (Development):
# REDIS_URL=redis://localhost:6379
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT
REDIS_PASSWORD=YOUR_PASSWORD
REDIS_HOST=YOUR_HOST
REDIS_PORT=6379

# ============================================================================
# MONITORING & ERROR TRACKING
# ============================================================================
# Sentry DSN for error tracking and performance monitoring
# Get your DSN from: https://sentry.io/settings/projects/
# Format: https://PUBLIC_KEY@ORGANIZATION.ingest.sentry.io/PROJECT_ID
#
# Example:
# SENTRY_DSN=https://abc123def456@o123456.ingest.sentry.io/7890123
#
# Leave empty to disable Sentry
SENTRY_DSN=

# ============================================================================
# CORS Configuration (Dynamic)
# ============================================================================
ENVIRONMENT=development  # production | staging | development
FRONTEND_URL=http://localhost:5173
QUIZ_URL=http://localhost:3001
# ALLOWED_ORIGINS= # Optional override (CSV format, e.g., https://frontend.com,https://quiz.com)
# PRODUCTION: Use https:// URLs without trailing slashes
# Example: ALLOWED_ORIGINS=https://frontend-production.up.railway.app,https://quiz-production.up.railway.app

# SSL/TLS Configuration
# PRODUCTION: Set to true and use rediss:// URL scheme for secure connections
# DEVELOPMENT: Can be false with redis:// URL scheme for local development
REDIS_SSL=true
# Certificate validation: none (dev only), optional, required (production default)
# SECURITY: Always use "required" for production to verify SSL certificates
REDIS_SSL_CERT_REQS=required

# Connection Pool Settings
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=10.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# Database Isolation
# Use different DB numbers for different purposes (0-15 available)
REDIS_ENABLE_DB_ISOLATION=true
REDIS_CACHE_DB=1          # Application cache
REDIS_BROKER_DB=0         # Celery broker
REDIS_SESSION_DB=2        # User sessions
REDIS_RATE_LIMIT_DB=3     # Rate limiting

# Celery Configuration
# IMPORTANT: Use rediss:// (with SSL) for production environments
CELERY_BROKER_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/0
CELERY_RESULT_BACKEND=rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/0
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_TIME_LIMIT=300
CELERY_WORKER_SOFT_TIME_LIMIT=240
CELERY_QUEUES=celery,flows,quiz,maintenance,monitoring

# ============================================================================
# INTEGRATIONS - EVOLUTION (WhatsApp)
# ============================================================================
ENABLE_EVOLUTION=true
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE_NAME=clinica_oncologica
EVOLUTION_API_KEY=CHANGE_THIS

# WhatsApp settings
ENABLE_WHATSAPP_ON_REGISTRATION=true
WHATSAPP_WELCOME_MESSAGE_ENABLED=true
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_SECONDS=60
CLINIC_NAME=Neoplasias Litoral
CLINIC_SUPPORT_PHONE=+55REPLACE_WITH_SUPPORT

# ============================================================================
# AI SERVICES (Google Gemini & LangChain)
# ============================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=500
GEMINI_TOP_P=0.8
GEMINI_TOP_K=40
GEMINI_TIMEOUT=30
GEMINI_MAX_RETRIES=3

# AI Humanization Configuration
AI_HUMANIZATION_ENABLED=true
AI_HUMANIZATION_SAFETY_MODE=true
AI_HUMANIZATION_MAX_RETRIES=2
AI_HUMANIZATION_TIMEOUT=10.0
AI_HUMANIZATION_FALLBACK_ENABLED=true
AI_HUMANIZATION_CRITICAL_KEYWORDS=["medicação","remédio","dosagem","mg","ml","emergência","urgente","hospital"]

# ============================================================================
# FIREBASE ADMIN SDK
# ============================================================================
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ============================================================================
# MONTHLY QUIZ CONFIGURATION
# ============================================================================
MONTHLY_QUIZ_VIA_LINK=true
MONTHLY_QUIZ_BASE_URL=http://localhost:3001
MONTHLY_QUIZ_TOKEN_SECRET=CHANGE_THIS_TO_SECURE_RANDOM
MONTHLY_QUIZ_TOKEN_EXPIRY_HOURS=72

# ============================================================================
# SECURITY: CSRF PROTECTION
# ============================================================================
# CRITICAL: Generate secure secret for CSRF token signing
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# PRODUCTION: Must be different from SECRET_KEY and JWT_SECRET_KEY
CSRF_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE

# ============================================================================
# WEBHOOK SECURITY
# ============================================================================
# Evolution API Webhook Secret for HMAC signature validation
# CRITICAL: Must match the secret configured in Evolution API
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# This secret is used to:
# - Validate webhook signatures (HMAC-SHA256)
# - Prevent webhook spoofing and tampering
# - Protect against replay attacks (with timestamp validation)
#
# Configuration in Evolution API:
# 1. Go to Evolution API settings
# 2. Set webhook URL: https://your-domain.com/api/v2/webhooks/evolution/message
# 3. Set webhook secret to the same value as below
# 4. Enable signature validation
EVOLUTION_WEBHOOK_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE

# ============================================================================
# LOGGING CONFIGURATION (Enhanced for Critical Bug Fixes)
# ============================================================================
# Logging levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
# PRODUCTION: Use INFO or WARNING to reduce log volume
# DEVELOPMENT: Use DEBUG for detailed troubleshooting
LOG_LEVEL=INFO

# Rate limiting to prevent log flooding (Railway limit: 500 logs/sec)
# Adjust based on your deployment platform's limits
MAX_LOGS_PER_SECOND=100

# Request logging configuration
# PRODUCTION: Set to false to reduce routine log volume
# DEVELOPMENT: Set to true for debugging
ENABLE_REQUEST_LOGGING=true

# Stack trace logging for errors
# PRODUCTION: Can be false to reduce log size
# DEVELOPMENT: Should be true for debugging
LOG_STACK_TRACES=true

# Log deduplication window in seconds (prevents spam)
LOG_DEDUPLICATION_WINDOW=300

# ============================================================================
# ERROR TRACKING CONFIGURATION (Critical Bug Fixes)
# ============================================================================
# Enable centralized error tracking and database logging
ENABLE_ERROR_TRACKING=true

# Maximum error logs to store in database (prevents unbounded growth)
MAX_ERROR_LOGS=1000

# Error deduplication window in seconds (groups similar errors)
ERROR_DEDUPLICATION_WINDOW=3600

# Rate limiting for error logs (per error type per minute)
ERROR_TRACKING_RATE_LIMIT=10

# Enable notifications for critical errors (DI, role enum, schema issues)
CRITICAL_ERROR_NOTIFICATION=true

# ============================================================================
# VIRUS SCANNING (ClamAV)
# ============================================================================
# ClamAV virus scanner for file uploads
CLAMAV_ENABLED=true
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=30
# Allow uploads if scanner unavailable (fail open)
CLAMAV_FAIL_OPEN=true
# Quarantine directory for infected files
QUARANTINE_DIR=quarantine

# ============================================================================
# SECURITY FEATURES (CVE FIXES - REQUIRED FOR PRODUCTION)
# ============================================================================
# CVE-CLINIC-2025-002: MIME Type Validation
MIME_VALIDATION_ENABLED=true           # Enable MIME content validation (libmagic)
MIME_VALIDATION_STRICT=false           # Reject fuzzy matches (image/jpg vs image/jpeg)
MIME_ALLOWED_VARIANCE=true             # Allow similar MIME types (same category)

# CVE-CLINIC-2025-003: File Security Scanning
FILE_SECURITY_ENABLED=true             # Enable comprehensive file security scans
ALLOW_MACROS=false                     # Allow macro-enabled Office docs (.docm, .xlsm)
ALLOW_PDF_JAVASCRIPT=false             # Allow JavaScript in PDFs (DANGEROUS if true)

# ============================================================================
# UPLOAD QUOTA MANAGEMENT
# ============================================================================
# Default quota per user in GB
DEFAULT_USER_QUOTA_GB=1
# Premium user quota in GB
PREMIUM_USER_QUOTA_GB=10
# Quota cache TTL in seconds
QUOTA_CACHE_TTL=300

# ============================================================================
# MULTI-CHANNEL NOTIFICATIONS
# ============================================================================

# Email (SMTP) Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@clinica-oncologica.com
SMTP_USE_TLS=true

# Slack Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_DEFAULT_CHANNEL=#alerts

# PagerDuty Configuration
PAGERDUTY_API_KEY=your-pagerduty-api-key
PAGERDUTY_SERVICE_KEY=your-pagerduty-integration-key

# Notification Retry Settings
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5

# ============================================================================
# CELERY TASK CONFIGURATION
# ============================================================================

# Flow Processing Settings
FLOW_PROCESSING_TIMEOUT=30          # Timeout per patient flow (seconds)
FLOW_BATCH_SIZE=10                  # Patients per batch
FLOW_MAX_CONCURRENT=50              # Maximum concurrent flows
FLOW_MAX_RETRIES=3                  # Maximum retries for flow tasks
FLOW_RETRY_DELAY=300                # Base retry delay (seconds, 5 minutes)

# Task Time Limits
TASK_TIME_LIMIT=3600                # Hard time limit (seconds, 1 hour)
TASK_SOFT_TIME_LIMIT=3300           # Soft time limit (seconds, 55 minutes)

# Retry Configuration (Global Defaults)
MAX_RETRIES=3                       # Maximum retries for general tasks
RETRY_BACKOFF_FACTOR=2              # Exponential backoff factor
RETRY_BACKOFF_BASE=300              # Base retry delay (seconds, 5 minutes)

# Message Processing Settings
MESSAGE_SEND_TIMEOUT=60             # Message send timeout (seconds)
MESSAGE_MAX_RETRIES=3               # Maximum retries for messages
MESSAGE_RETRY_DELAY=60              # Base message retry delay (seconds)
MESSAGE_BATCH_SIZE=100              # Messages to process per batch
MESSAGE_RETRY_BATCH_SIZE=50         # Failed messages to retry per batch

# Quiz Processing Settings
QUIZ_PROCESSING_TIMEOUT=600         # Quiz processing timeout (seconds, 10 minutes)
QUIZ_REPORT_TIMEOUT=300             # Quiz report timeout (seconds, 5 minutes)
QUIZ_MAX_RETRIES=3                  # Maximum retries for quiz operations
QUIZ_RETRY_DELAY=60                 # Base quiz retry delay (seconds)
QUIZ_QUESTION_RETRY_DELAY=60        # Quiz question retry delay (seconds)
QUIZ_RESPONSE_RETRY_DELAY=30        # Quiz response retry delay (seconds)
QUIZ_RESPONSE_MAX_RETRIES=2         # Quiz response max retries
QUIZ_TRIGGER_RETRY_DELAY=120        # Quiz trigger check retry delay (seconds)
QUIZ_CLEANUP_RETRY_DELAY=60         # Quiz cleanup retry delay (seconds)
QUIZ_CLEANUP_MAX_RETRIES=2          # Quiz cleanup max retries
QUIZ_PROGRESS_RETRY_DELAY=30        # Quiz progress update retry delay (seconds)
QUIZ_REPORT_RETRY_DELAY=120         # Quiz report generation retry delay (seconds)
QUIZ_REMINDER_RETRY_DELAY=60        # Quiz reminder retry delay (seconds)
QUIZ_LINK_MONITORING_RETRY_DELAY=120 # Quiz link monitoring retry delay (seconds)
QUIZ_TRIGGER_BATCH_SIZE=100         # Quiz triggers to check per batch
QUIZ_SESSION_TIMEOUT_HOURS=48       # Quiz session timeout (hours)
QUIZ_EXPIRED_LINKS_BATCH_SIZE=100   # Expired links to process per batch
QUIZ_DLQ_BATCH_SIZE=50              # DLQ items to process per batch

# Health Monitoring Settings
HEALTH_CHECK_TIMEOUT=30             # Health check timeout (seconds)
HEALTH_ACTIVE_FLOWS_LIMIT=1000      # Maximum active flows to fetch for monitoring

# Cleanup Settings
CLEANUP_BATCH_SIZE=100              # Cleanup batch size
CLEANUP_DAYS_OLD=90                 # Age threshold for cleanup (days)
ARCHIVE_RETENTION_DAYS=365          # Archive retention period (days)

# Report Generation Settings
REPORT_MAX_RETRIES=3                # Maximum retries for reports
REPORT_RETRY_DELAY=300              # Base report retry delay (seconds, 5 minutes)
REPORT_RETRY_DELAY_ALT=600          # Alternative report retry delay (seconds, 10 minutes)

# Saga Pattern Settings
SAGA_MAX_RETRIES=3                  # Maximum retries for saga operations
SAGA_RETRY_DELAY=60                 # Base saga retry delay (seconds)

# Alert Settings
ALERT_MAX_RETRIES=3                 # Maximum retries for alerts
ALERT_MAX_RETRIES_ALT=2             # Alternative max retries for specific alerts

# Debounce Settings
DEBOUNCE_WINDOW_SECONDS=3           # Debounce window for duplicate operations (seconds)

# Redis Settings for Tasks
REDIS_TASK_RESULT_EXPIRY=3600       # Task result expiration in Redis (seconds, 1 hour)
REDIS_SOCKET_TIMEOUT=5              # Socket timeout for Redis (seconds)
REDIS_SOCKET_CONNECT_TIMEOUT=5      # Socket connect timeout for Redis (seconds)

# Concurrency Settings
USE_ASYNC_DB=false                  # Use async database operations
ENABLE_PARALLEL_PROCESSING=true     # Enable parallel processing for batches
THREAD_POOL_SIZE=5                  # Thread pool size for concurrent operations
CONNECTION_POOL_SIZE=10             # Database connection pool size

# Feature Flags
ENABLE_ADMIN_ALERTS=true            # Enable admin alerts for critical failures
ADMIN_ALERT_EMAIL=admin@example.com # Admin email for alerts
ENABLE_SAGA_PATTERN=true            # Enable saga pattern for distributed transactions
ENABLE_REDIS_CACHING=true           # Enable Redis caching

# ============================================================================
# CACHE TTL SETTINGS (MEDIUM-008)
# All values in seconds. Override with CACHE_ prefix.
# Example: CACHE_FLOW_TEMPLATE_TTL=7200
# ============================================================================

# Flow & Templates
CACHE_FLOW_TEMPLATE_TTL=3600
CACHE_TEMPLATE_CACHE_TTL=3600

# User & Authentication
CACHE_USER_SESSION_TTL=1800
CACHE_AUTH_TOKEN_TTL=86400
CACHE_REFRESH_TOKEN_TTL=604800

# Patient Data
CACHE_PATIENT_CACHE_TTL=900
CACHE_DOCTOR_CACHE_TTL=1800

# Quiz & Sessions
CACHE_QUIZ_SESSION_TTL=7200
CACHE_QUIZ_TEMPLATES_TTL=3600

# Messages & Communication
CACHE_MESSAGE_CACHE_TTL=3600
CACHE_MESSAGE_STATS_TTL=300
CACHE_WHATSAPP_METRICS_TTL=604800

# Webhooks & Idempotency
CACHE_WEBHOOK_IDEMPOTENCY_TTL=3600
CACHE_WEBHOOK_CACHE_TTL=300

# Rate Limiting
CACHE_RATE_LIMIT_WINDOW_TTL=60

# Reports & Analytics
CACHE_REPORT_CACHE_TTL=1800
CACHE_ANALYTICS_CACHE_TTL=300

# Distributed Systems
CACHE_DISTRIBUTED_LOCK_TTL=30
CACHE_SAGA_STATE_TTL=3600
CACHE_CIRCUIT_BREAKER_STATE_TTL=300

# Monitoring & Metrics
CACHE_SYSTEM_METRICS_TTL=60
CACHE_RESOURCE_MONITOR_TTL=300

# Connection State
CACHE_CONNECTION_STATE_TTL=300
CACHE_QRCODE_TTL=300

# ============================================================================
# WEBHOOK RETRY SETTINGS (MEDIUM-009)
# ============================================================================
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_MIN_WAIT=2
WEBHOOK_RETRY_MAX_WAIT=60
WEBHOOK_RETRY_MULTIPLIER=1
WEBHOOK_TIMEOUT=30
WEBHOOK_BATCH_SIZE=50
