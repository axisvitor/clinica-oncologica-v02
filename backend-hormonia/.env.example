# ===================================
# SECURITY CONFIGURATION TEMPLATE
# ===================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control
# NEVER share these keys publicly

# ===================================
# APPLICATION SETTINGS
# ===================================
ENVIRONMENT=development
DEBUG=true
APP_NAME=NeoplasiaLitoral-Backend
APP_VERSION=2.0.0
PORT=8000
HOST=0.0.0.0

# ===================================
# SECURITY KEYS (CRITICAL - CHANGE THESE!)
# ===================================
# Generate strong keys using: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_64_CHARS_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ===================================
# FIREBASE AUTHENTICATION (CRITICAL - DO NOT EXPOSE!)
# ===================================
# Firebase Admin SDK Configuration
# Get service account JSON from: https://console.firebase.google.com/project/_/settings/serviceaccounts/adminsdk
# REQUIRED: Backend will fail to start (503 errors) if these are not configured
FIREBASE_ADMIN_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Firebase Security - Domain Allowlist for Auto-Provisioning
# Comma-separated list of allowed email domains for auto-provisioning users
# Example: oncologia.com,hospital.local,neoplasiaslitoral.com
# Leave empty to allow all domains
FIREBASE_ALLOWED_DOMAINS=
# Block public email domains (gmail, yahoo, etc.) - set to false to allow during development
FIREBASE_BLOCK_PUBLIC_DOMAINS=false

# ===================================
# SUPABASE DATABASE (CRITICAL - DO NOT EXPOSE!)
# ===================================
# NOTE: Supabase is used for PostgreSQL database and Storage (avatars), NOT for authentication
# Firebase handles authentication, Supabase provides the database and file storage
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase Storage Configuration
# Bucket name for user avatars (create this bucket in Supabase Storage dashboard)
SUPABASE_AVATARS_BUCKET=avatars

# ===================================
# DATABASE CONFIGURATION
# ===================================
# Get from: https://app.supabase.com/project/_/settings/database
# IMPORTANT: Use postgresql+psycopg:// for Python 3.13 compatibility (psycopg v3)
DATABASE_URL=postgresql+psycopg://postgres:your_password@your-host.supabase.co:6543/postgres

# Database Pool Settings (SECURITY FIX: Increased for better performance)
DB_POOL_SIZE=30
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=20
DB_STATEMENT_TIMEOUT=30000
DB_POOL_RECYCLE=3600

# ===================================
# REDIS CONFIGURATION (REQUIRED - NOT OPTIONAL!)
# ===================================
# CRITICAL: Redis is REQUIRED for authentication to work
# AuthService will raise RuntimeError if Redis is not connected
# Use Redis Cloud or local Redis instance with SSL/TLS

# Main Redis URL (for cache operations - DB 1 recommended)
ENABLE_REDIS=true
REDIS_URL=rediss://default:your_password@your-redis-host:port/1
REDIS_PASSWORD=your_redis_password
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_SSL=true
REDIS_SSL_CERT_REQS=required
REDIS_MAX_CONNECTIONS=25
REDIS_SOCKET_TIMEOUT=10.0

# Redis DB Isolation (recommended for production)
# Separates Celery broker traffic from application cache
REDIS_ENABLE_DB_ISOLATION=true
REDIS_CACHE_DB=1
REDIS_BROKER_DB=0

# Development: Use local Redis without SSL if needed
# REDIS_URL=redis://localhost:6379/1
# REDIS_SSL=false

# ===================================
# CELERY CONFIGURATION
# ===================================
# Use DB 0 for broker/backend to isolate from application cache (DB 1)
CELERY_BROKER_URL=rediss://default:your_password@your-redis-host:port/0
CELERY_RESULT_BACKEND=rediss://default:your_password@your-redis-host:port/0
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=300

# ===================================
# AI SERVICE CONFIGURATION (DO NOT EXPOSE!)
# ===================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-09-2025
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=4096

# ===================================
# EVOLUTION API (WHATSAPP) - SECURE THESE!
# ===================================
ENABLE_EVOLUTION=true
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_WEBHOOK_SECRET=your_webhook_secret_here
EVOLUTION_INSTANCE_NAME=clinica_oncologica
EVOLUTION_BASE_URL=https://evolution-api.example.com

# ===================================
# MONTHLY QUIZ SECURITY
# ===================================
MONTHLY_QUIZ_VIA_LINK=true
MONTHLY_QUIZ_BASE_URL=http://localhost:3000/quiz/monthly
MONTHLY_QUIZ_TOKEN_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY
MONTHLY_QUIZ_TOKEN_EXPIRY_HOURS=72

# ===================================
# CORS AND ALLOWED ORIGINS
# ===================================
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# ===================================
# FRONTEND RUNTIME CONFIGURATION
# ===================================
# These variables control the PUBLIC /config endpoint values
# FRONTEND_API_URL: Explicit API URL for frontend to connect to (overrides auto-detection)
FRONTEND_API_URL=

# FRONTEND_URL: Main frontend application URL (for CORS)
FRONTEND_URL=

# QUIZ_URL: Monthly quiz interface URL (for CORS)
QUIZ_URL=

# Firebase Web App Configuration (PUBLIC - safe to expose to frontend)
# Get these from Firebase Console > Project Settings > General > Your apps > Web app
# NOTE: These are PUBLIC keys meant for client-side use (different from admin SDK keys)
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_AUTH_DOMAIN=

# Railway-specific environment variables (auto-populated by Railway)
# RAILWAY_PUBLIC_DOMAIN: Public domain for this service
# RAILWAY_STATIC_URL: Static URL for this deployment

# ===================================
# RLS CONFIGURATION
# ===================================
SUPABASE_USE_SERVICE_ROLE=true
SUPABASE_BYPASS_RLS=true
RLS_POOL_SIZE=30
RLS_POOL_MAX_OVERFLOW=50

# ===================================
# SECURITY HEADERS
# ===================================
SECURE_SSL_REDIRECT=false
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_BROWSER_XSS_FILTER=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true

# ===================================
# MONITORING
# ===================================
MONITORING_ENABLED=true
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ===================================
# FILE ENCRYPTION (OPTIONAL BUT RECOMMENDED)
# ===================================
ENABLE_FIELD_ENCRYPTION=true
ENCRYPTION_KEY=CHANGE_THIS_TO_A_SECURE_32_BYTE_KEY

# ===================================
# COMPLIANCE
# ===================================
LGPD_COMPLIANCE_MODE=true
AUDIT_LOG_RETENTION_DAYS=365
DATA_RETENTION_DAYS=730
