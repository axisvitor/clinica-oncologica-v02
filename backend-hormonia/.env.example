# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and update with your actual values
#
# NAMING CONVENTION:
# - Pattern: {CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
# - Booleans: Always use ENABLE_ prefix after category
# - Timeouts: Always include _SECONDS or _MS suffix
# - Pools: Use _POOL_SIZE, _POOL_MAX_CONNECTIONS
# ============================================================================

# ============================================================================
# SERVICE TYPE (api, worker, beat)
# ============================================================================
SERVICE_TYPE=api

# ============================================================================
# APPLICATION CORE
# ============================================================================
APP_ENVIRONMENT=development
APP_ENABLE_DEBUG=true
APP_NAME=NeoplasiaLitoral-Backend
APP_VERSION=2.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_API_VERSION=v2
APP_ADMIN_DASHBOARD_URL=http://localhost:5173/admin
ALLOW_AI_SIMULATION=true
DEFAULT_LOCALE=pt-BR
SUPPORTED_LOCALES=["en","pt-BR","es"]

# ============================================================================
# PROCESS/WORKER CONCURRENCY
# ============================================================================
WEB_CONCURRENCY=4

# ============================================================================
# SECURITY - KEYS
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ============================================================================
SECURITY_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE
SECURITY_ALGORITHM=HS256
SECURITY_CSRF_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE
SECURITY_ENABLE_FIELD_ENCRYPTION=true
SECURITY_ENABLE_SSL_REDIRECT=false
SECURITY_ENABLE_CONTENT_TYPE_NOSNIFF=true
SECURITY_ENABLE_BROWSER_XSS_FILTER=true

# ============================================================================
# SECURITY - AUTHENTICATION (JWT)
# ============================================================================
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_BCRYPT_ROUNDS=12
AUTH_ENABLE_TOKEN_ROTATION=false
AUTH_ENABLE_TOKEN_BLACKLIST=true
ENABLE_STRICT_UID_VALIDATION=true
ENABLE_COOKIE_PRIORITY=true

# ============================================================================
# SECURITY - SESSION/COOKIES
# ============================================================================
SESSION_ENABLE_COOKIE_SECURE=false
SESSION_ENABLE_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_PATH=/
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_MAX_AGE_SECONDS=28800
SESSION_MAX_AGE_SECONDS=604800 # 7 days

# ============================================================================
# DATABASE (PostgreSQL/AWS RDS)
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# ============================================================================
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DB_MAX_CONNECTIONS=80
DB_WARN_AT_CONNECTIONS=80
DATABASE_POOL_SIZE=30
DATABASE_POOL_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=3600
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_RESET_ON_RETURN=commit
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_SLOW_QUERY_THRESHOLD_SECONDS=1.0
DB_QUERY_TIMEOUT_READ=5
DB_QUERY_TIMEOUT_WRITE=10

# ============================================================================
# REDIS - CONNECTION
# Format: redis:// (dev) or rediss:// (production with SSL)
# ============================================================================
REDIS_ENABLE_SERVICE=true
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# REDIS - SSL/TLS
# PRODUCTION: Enable SSL and use rediss:// URL scheme
# ============================================================================
REDIS_ENABLE_SSL=false
REDIS_SSL_CERT_REQS=required
REDIS_SSL_MIN_VERSION=
REDIS_SSL_CA_CERTS=
REDIS_SSL_SESSION_REUSE=true
REDIS_SSL_CONNECTION_POOL_WARMUP=true
REDIS_SSL_WARMUP_CONNECTIONS=5

# ============================================================================
# REDIS - CONNECTION POOL
# ============================================================================
REDIS_POOL_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT_SECONDS=10.0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5.0
REDIS_ENABLE_RETRY_ON_TIMEOUT=true
REDIS_MAX_RETRY_ATTEMPTS=3
REDIS_ENABLE_HEALTH_CHECK=true
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30
REDIS_ENABLE_DECODE_RESPONSES=true
REDIS_OPERATION_TIMEOUT=5

# ============================================================================
# REDIS - DATABASE ISOLATION
# ============================================================================
REDIS_ENABLE_DB_ISOLATION=true
REDIS_CACHE_DB_NUMBER=1
REDIS_BROKER_DB_NUMBER=0
REDIS_SESSION_DB_NUMBER=2
REDIS_RATE_LIMIT_DB_NUMBER=3

# ============================================================================
# CELERY - BROKER
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================================================
# CELERY - WORKER
# ============================================================================
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_TIME_LIMIT_SECONDS=300
CELERY_WORKER_SOFT_TIME_LIMIT_SECONDS=240
CELERY_QUEUES=celery,flows,quiz,maintenance,monitoring
CELERY_ENABLE_UTC=true
CELERY_ENABLE_TRACK_STARTED=true
CELERY_ENABLE_DISABLE_RATE_LIMITS=true
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# ============================================================================
# CORS - Primary URLs
# Migration completed: Now uses centralized CORS configuration in settings.py
# CORS_FRONTEND_URL and CORS_QUIZ_URL are always included automatically
# ============================================================================
CORS_FRONTEND_URL=http://localhost:5173
CORS_QUIZ_URL=http://localhost:3001
# Additional origins (optional, comma-separated)
CORS_ALLOWED_ORIGINS=

# ============================================================================
# MONITORING & ERROR TRACKING
# ============================================================================
MONITORING_ENABLE_SERVICE=true
SENTRY_DSN=
MONITORING_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
MONITORING_SENTRY_ENVIRONMENT=development
MONITORING_ENABLE_DEBUG=false

# ============================================================================
# WHATSAPP - EVOLUTION API
# ============================================================================
WHATSAPP_ENABLE_SERVICE=true
WHATSAPP_EVOLUTION_API_URL=http://localhost:8080
WHATSAPP_EVOLUTION_INSTANCE_NAME=clinica_oncologica
WHATSAPP_EVOLUTION_API_KEY=CHANGE_THIS
WHATSAPP_EVOLUTION_WEBHOOK_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE
# IMPORTANT: Use the integration webhook endpoint, NOT /api/v2/webhooks/evolution
# Format: {BACKEND_URL}/webhooks/whatsapp/evolution/{INSTANCE_NAME}
WHATSAPP_EVOLUTION_WEBHOOK_URL=http://localhost:8000/webhooks/whatsapp/evolution/clinica_oncologica
WHATSAPP_WEBHOOK_HMAC_ENABLED=true
WHATSAPP_WEBHOOK_TIMESTAMP_REQUIRED=false
WHATSAPP_WEBHOOK_MAX_TIMESTAMP_AGE_SECONDS=300
# Optional: restrict webhook source IPs (comma-separated or JSON array)
WHATSAPP_WEBHOOK_IP_WHITELIST=

# ============================================================================
# WHATSAPP - SETTINGS
# ============================================================================
WHATSAPP_ENABLE_ON_REGISTRATION=true
WHATSAPP_ENABLE_WELCOME_MESSAGE=true
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_SECONDS=60
WHATSAPP_CLINIC_NAME=Neoplasias Litoral
WHATSAPP_CLINIC_SUPPORT_PHONE=+55REPLACE_WITH_SUPPORT

# ============================================================================
# AI - GOOGLE GEMINI
# ============================================================================
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-2.0-flash-exp
AI_GEMINI_TEMPERATURE=0.7
AI_GEMINI_MAX_OUTPUT_TOKENS=500
AI_GEMINI_TOP_P=0.8
AI_GEMINI_TOP_K=40
AI_GEMINI_TIMEOUT_SECONDS=30
AI_GEMINI_MAX_RETRIES=3

# ============================================================================
# AI - LANGCHAIN
# ============================================================================
AI_LANGCHAIN_ENABLE_TRACING_V2=false
AI_LANGCHAIN_API_KEY=

# ============================================================================
# AI - HUMANIZATION
# ============================================================================
AI_ENABLE_HUMANIZATION=true
AI_HUMANIZATION_ENABLE_SAFETY_MODE=true
AI_HUMANIZATION_MAX_RETRIES=2
AI_HUMANIZATION_TIMEOUT_SECONDS=10.0
AI_HUMANIZATION_ENABLE_FALLBACK=true
AI_HUMANIZATION_CRITICAL_KEYWORDS=["medicação","remédio","dosagem","mg","ml","emergência","urgente","hospital"]

# ============================================================================
# FIREBASE - ADMIN SDK
# ============================================================================
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_ADMIN_SDK_TIMEOUT=10
# Timeout in seconds to avoid blocking during slow Firebase Admin SDK calls

# ============================================================================
# FIREBASE - SECURITY
# ============================================================================
FIREBASE_ENABLE_REQUIRE_CUSTOM_CLAIMS=true
FIREBASE_ENABLE_AUDIT_LOGGING=true
FIREBASE_ENABLE_BLOCK_PUBLIC_DOMAINS=true
FIREBASE_ALLOWED_ROLES=["admin","doctor","medico"]
FIREBASE_TOKEN_CACHE_TTL_SECONDS=3600
FIREBASE_USER_CACHE_TTL_SECONDS=7200
FIREBASE_SESSION_TTL_SECONDS=86400

# ============================================================================
# MONTHLY QUIZ
# ============================================================================
QUIZ_ENABLE_VIA_LINK=true
QUIZ_BASE_URL=http://localhost:3001
QUIZ_TOKEN_SECRET=CHANGE_THIS_TO_SECURE_RANDOM
QUIZ_TOKEN_EXPIRY_HOURS=72

# ============================================================================
# LOGGING
# ============================================================================
LOGGING_LEVEL=INFO
LOGGING_ENABLE_REQUEST_LOGGING=true
LOGGING_ENABLE_STACK_TRACES=true
LOGGING_DEDUPLICATION_WINDOW_SECONDS=300
LOGGING_MAX_LOGS_PER_SECOND=100

# ============================================================================
# ERROR TRACKING
# ============================================================================
ERROR_ENABLE_TRACKING=true
ERROR_MAX_LOGS=1000
ERROR_DEDUPLICATION_WINDOW_SECONDS=3600
ERROR_TRACKING_RATE_LIMIT=10
ERROR_ENABLE_CRITICAL_NOTIFICATION=true

# ============================================================================
# DATA RETENTION
# ============================================================================
RETENTION_DATA_DAYS=730
RETENTION_AUDIT_LOG_DAYS=365

# ============================================================================
# FILE UPLOAD
# ============================================================================
UPLOAD_MAX_SIZE_BYTES=10485760
UPLOAD_DIRECTORY=uploads

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLE_SERVICE=true
RATE_LIMIT_REDIS_URL=

# ============================================================================
# VIRUS SCANNING (ClamAV)
# ============================================================================
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=30
CLAMAV_FALLBACK_CLI=true

# ============================================================================
# FILE SECURITY (CVE FIXES)
# ============================================================================
MIME_VALIDATION_ENABLED=true
MIME_VALIDATION_STRICT=false
MIME_ALLOWED_VARIANCE=true
FILE_SECURITY_ENABLED=true
ALLOW_MACROS=false
ALLOW_SCRIPTS_IN_PDF=false

# ============================================================================
# UPLOAD QUOTA
# ============================================================================
QUOTA_DEFAULT_USER_GB=1
QUOTA_PREMIUM_USER_GB=10
QUOTA_CACHE_TTL_SECONDS=300

# ============================================================================
