# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and update with your actual values
# See docs/deployment/RAILWAY_ENVIRONMENT_VARIABLES.md for complete guide
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL/AWS RDS)
# ============================================================================
# CRITICAL: Must include ?sslmode=require for production (Railway/AWS RDS)
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
#
# Example (Production):
# DATABASE_URL=postgresql+psycopg://app_user:PASSWORD@your-cluster.cluster-abcdefghijkl.us-east-1.rds.amazonaws.com:5432/clinica_oncologica?sslmode=require
#
# Example (Development):
# DATABASE_URL=postgresql+psycopg://localhost:5432/hormonia_dev
#
# SSL Mode Options:
# - require: Required for production (AWS RDS/Railway)
# - verify-full: Full certificate verification (most secure)
# - disable: No SSL (development only, NEVER in production)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DB_POOL_SIZE=30
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Primary connection settings
ENABLE_REDIS=true
# CRITICAL: Use rediss:// (with two 's') for SSL/TLS connections in production
# Format: rediss://default:PASSWORD@HOST:PORT
#
# Example (Production):
# REDIS_URL=rediss://default:PASSWORD@redis-production.railway.app:6379
#
# Example (Development):
# REDIS_URL=redis://localhost:6379
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT
REDIS_PASSWORD=YOUR_PASSWORD
REDIS_HOST=YOUR_HOST
REDIS_PORT=6379

# ============================================================================
# MONITORING & ERROR TRACKING
# ============================================================================
# Sentry DSN for error tracking and performance monitoring
# Get your DSN from: https://sentry.io/settings/projects/
# Format: https://PUBLIC_KEY@ORGANIZATION.ingest.sentry.io/PROJECT_ID
#
# Example:
# SENTRY_DSN=https://abc123def456@o123456.ingest.sentry.io/7890123
#
# Leave empty to disable Sentry
SENTRY_DSN=

# ============================================================================
# CORS Configuration (Dynamic)
# ============================================================================
ENVIRONMENT=development  # production | staging | development
FRONTEND_URL=http://localhost:5173
QUIZ_URL=http://localhost:3001
# ALLOWED_ORIGINS= # Optional override (CSV format, e.g., https://frontend.com,https://quiz.com)
# PRODUCTION: Use https:// URLs without trailing slashes
# Example: ALLOWED_ORIGINS=https://frontend-production.up.railway.app,https://quiz-production.up.railway.app

# SSL/TLS Configuration
# PRODUCTION: Set to true and use rediss:// URL scheme for secure connections
# DEVELOPMENT: Can be false with redis:// URL scheme for local development
REDIS_SSL=true
# Certificate validation: none (dev only), optional, required (production default)
# SECURITY: Always use "required" for production to verify SSL certificates
REDIS_SSL_CERT_REQS=required

# Connection Pool Settings
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=10.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# Database Isolation
# Use different DB numbers for different purposes (0-15 available)
REDIS_ENABLE_DB_ISOLATION=true
REDIS_CACHE_DB=1          # Application cache
REDIS_BROKER_DB=0         # Celery broker
REDIS_SESSION_DB=2        # User sessions
REDIS_RATE_LIMIT_DB=3     # Rate limiting

# Celery Configuration
# IMPORTANT: Use rediss:// (with SSL) for production environments
CELERY_BROKER_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/0
CELERY_RESULT_BACKEND=rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/0
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_TIME_LIMIT=300
CELERY_WORKER_SOFT_TIME_LIMIT=240
CELERY_QUEUES=celery,flows,quiz,maintenance,monitoring

# ============================================================================
# SECURITY: CSRF PROTECTION
# ============================================================================
# CRITICAL: Generate secure secret for CSRF token signing
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# PRODUCTION: Must be different from SECRET_KEY and JWT_SECRET_KEY
CSRF_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE

# ============================================================================
# WEBHOOK SECURITY
# ============================================================================
# Evolution API Webhook Secret for HMAC signature validation
# CRITICAL: Must match the secret configured in Evolution API
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# This secret is used to:
# - Validate webhook signatures (HMAC-SHA256)
# - Prevent webhook spoofing and tampering
# - Protect against replay attacks (with timestamp validation)
#
# Configuration in Evolution API:
# 1. Go to Evolution API settings
# 2. Set webhook URL: https://your-domain.com/api/v2/webhooks/evolution/message
# 3. Set webhook secret to the same value as below
# 4. Enable signature validation
EVOLUTION_WEBHOOK_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE

# ============================================================================
# LOGGING CONFIGURATION (Enhanced for Critical Bug Fixes)
# ============================================================================
# Logging levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
# PRODUCTION: Use INFO or WARNING to reduce log volume
# DEVELOPMENT: Use DEBUG for detailed troubleshooting
LOG_LEVEL=INFO

# Rate limiting to prevent log flooding (Railway limit: 500 logs/sec)
# Adjust based on your deployment platform's limits
MAX_LOGS_PER_SECOND=100

# Request logging configuration
# PRODUCTION: Set to false to reduce routine log volume
# DEVELOPMENT: Set to true for debugging
ENABLE_REQUEST_LOGGING=true

# Stack trace logging for errors
# PRODUCTION: Can be false to reduce log size
# DEVELOPMENT: Should be true for debugging
LOG_STACK_TRACES=true

# Log deduplication window in seconds (prevents spam)
LOG_DEDUPLICATION_WINDOW=300

# ============================================================================
# ERROR TRACKING CONFIGURATION (Critical Bug Fixes)
# ============================================================================
# Enable centralized error tracking and database logging
ENABLE_ERROR_TRACKING=true

# Maximum error logs to store in database (prevents unbounded growth)
MAX_ERROR_LOGS=1000

# Error deduplication window in seconds (groups similar errors)
ERROR_DEDUPLICATION_WINDOW=3600

# Rate limiting for error logs (per error type per minute)
ERROR_TRACKING_RATE_LIMIT=10

# Enable notifications for critical errors (DI, role enum, schema issues)
CRITICAL_ERROR_NOTIFICATION=true
