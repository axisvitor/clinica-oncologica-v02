# ============================================================================
# BACKEND HORMONIA - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# Version: 2.1.0
# Last Updated: 2025-12-11
# Environment: PRODUCTION
# ENV Variable Naming Convention: {CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
#
# ⚠️  MIGRATION NOTES (v2.1.0):
# - CORS configuration centralized in settings.py
# - All backward compatibility code removed
# - Simplified environment variables using direct names
#
# ⚠️  CRITICAL PRODUCTION SECURITY CHECKLIST:
# [ ] All secrets rotated from development values
# [ ] SSL/TLS enabled for all external connections
# [ ] Rate limiting enabled and configured
# [ ] Error tracking (Sentry) configured
# [ ] Monitoring and alerting configured
# [ ] Backup strategy implemented
# [ ] Disaster recovery plan documented
# [ ] Security audit completed
# ============================================================================

# --------------------------------------------
# APPLICATION CONFIGURATION - APP_*
# --------------------------------------------
SERVICE_TYPE=api
APP_ENVIRONMENT=production
WEB_CONCURRENCY=4
APP_ENABLE_DEBUG=false
APP_NAME=NeoplasiaLitoral-Backend
APP_VERSION=2.0.0
APP_ADMIN_DASHBOARD_URL=https://app.hormonia.example.com/admin
ALLOW_AI_SIMULATION=false
LOGGING_LEVEL=INFO
LOGGING_ENABLE_REQUEST_LOGGING=false
LOGGING_ENABLE_STACK_TRACES=true
LOGGING_MAX_LOGS_PER_SECOND=100
LOGGING_DEDUPLICATION_WINDOW_SECONDS=300

# --------------------------------------------
# DATABASE CONFIGURATION - DATABASE_*
# --------------------------------------------
# ⚠️  CRITICAL: Must use SSL connection in production (sslmode=require)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DB_MAX_CONNECTIONS=80
DB_WARN_AT_CONNECTIONS=80

# Connection pool settings (optimized for production load)
DATABASE_POOL_SIZE=30
DATABASE_POOL_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=3600

# --------------------------------------------
# REDIS CONFIGURATION - REDIS_*
# --------------------------------------------
# ⚠️  CRITICAL: Memorystore uses redis:// over private VPC; use rediss:// only if TLS is enabled
REDIS_ENABLE_SERVICE=true
REDIS_URL=redis://10.109.61.19:6379/0
REDIS_PASSWORD=
REDIS_HOST=10.109.61.19
REDIS_PORT=6379

# SSL/TLS Configuration
REDIS_ENABLE_SSL=false
REDIS_SSL_CERT_REQS=none

# Connection Pool Settings (production optimized)
REDIS_POOL_MAX_CONNECTIONS=1000
REDIS_SOCKET_TIMEOUT_SECONDS=10.0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5.0
REDIS_ENABLE_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

# Database Isolation
REDIS_ENABLE_DB_ISOLATION=true
REDIS_CACHE_DB_NUMBER=1
REDIS_BROKER_DB_NUMBER=0
REDIS_SESSION_DB_NUMBER=2
REDIS_RATE_LIMIT_DB_NUMBER=3

# --------------------------------------------
# CELERY CONFIGURATION - CELERY_*
# --------------------------------------------
# ⚠️  CRITICAL: Memorystore uses redis://; use rediss:// only if TLS is enabled
CELERY_BROKER_URL=redis://10.109.61.19:6379/0
CELERY_RESULT_BACKEND=redis://10.109.61.19:6379/1
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_TIME_LIMIT_SECONDS=300
CELERY_WORKER_SOFT_TIME_LIMIT_SECONDS=240
CELERY_QUEUES=celery,flows,quiz,maintenance,monitoring
CELERY_TIMEZONE=America/Sao_Paulo

# --------------------------------------------
# CORS CONFIGURATION - CORS_*
# --------------------------------------------
# ⚠️  CRITICAL: Set to production frontend URLs only (no wildcards!)
# Migration completed: Centralized CORS configuration in settings.py
# CORS_FRONTEND_URL and CORS_QUIZ_URL are always included automatically
CORS_FRONTEND_URL=https://clinica-oncologica-hosting.web.app
CORS_QUIZ_URL=https://clinica-quiz.web.app
# Additional origins (optional, comma-separated - only needed for custom domains)
CORS_ALLOWED_ORIGINS=

# --------------------------------------------
# LOCALIZATION - DEFAULT_LOCALE, SUPPORTED_LOCALES
# --------------------------------------------
DEFAULT_LOCALE=pt-BR
SUPPORTED_LOCALES=["en","pt-BR","es"]

# --------------------------------------------
# SECURITY CONFIGURATION - SECURITY_*, AUTH_*
# --------------------------------------------
# ⚠️  CRITICAL: Generate secure random secrets for production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"

# Core Security Keys
SECURITY_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE_64_BYTES_OR_MORE
SECURITY_ALGORITHM=HS256

# CSRF Protection
SECURITY_CSRF_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE_DIFFERENT_FROM_SECRET

# Data Encryption (for PII fields - Fernet key)
ENCRYPTION_KEY_CURRENT=CHANGE_THIS_TO_FERNET_ENCRYPTION_KEY
ENCRYPTION_KEY_PREVIOUS=
HASH_SALT=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE
PHI_ENCRYPTION_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE

# Authentication Settings
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_BCRYPT_ROUNDS=12

# Session/Cookie Security (required in production)
SESSION_ENABLE_COOKIE_SECURE=true
SESSION_ENABLE_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=none

# Security Headers
SECURITY_ENABLE_SSL_REDIRECT=true
SECURITY_ENABLE_CONTENT_TYPE_NOSNIFF=true
SECURITY_ENABLE_BROWSER_XSS_FILTER=true
SECURITY_ENABLE_FIELD_ENCRYPTION=true

# Webhook Security
WHATSAPP_EVOLUTION_WEBHOOK_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE

# --------------------------------------------
# WHATSAPP / EVOLUTION API - WHATSAPP_*
# --------------------------------------------
WHATSAPP_ENABLE_SERVICE=true
WHATSAPP_EVOLUTION_API_URL=https://api.evolution.production.com
WHATSAPP_EVOLUTION_INSTANCE_NAME=clinica_oncologica_prod
WHATSAPP_EVOLUTION_API_KEY=YOUR_PRODUCTION_EVOLUTION_API_KEY

# WhatsApp Configuration - WHATSAPP_*
WHATSAPP_ENABLE_ON_REGISTRATION=true
WHATSAPP_ENABLE_WELCOME_MESSAGE=true
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_SECONDS=60
WHATSAPP_CLINIC_NAME=Neoplasias Litoral
WHATSAPP_CLINIC_SUPPORT_PHONE=+5511999887766

# --------------------------------------------
# AI SERVICES - AI_GEMINI_*
# --------------------------------------------
AI_GEMINI_API_KEY=YOUR_PRODUCTION_GEMINI_API_KEY
AI_GEMINI_MODEL=gemini-3-flash-preview
AI_GEMINI_TEMPERATURE=0.7
AI_GEMINI_MAX_OUTPUT_TOKENS=500
AI_GEMINI_TOP_P=0.8
AI_GEMINI_TOP_K=40
AI_GEMINI_TIMEOUT_SECONDS=30
AI_GEMINI_MAX_RETRIES=3

# AI Humanization Configuration - AI_ENABLE_*, AI_HUMANIZATION_*
AI_ENABLE_HUMANIZATION=true
AI_HUMANIZATION_ENABLE_SAFETY_MODE=true
AI_HUMANIZATION_MAX_RETRIES=2
AI_HUMANIZATION_TIMEOUT_SECONDS=10.0
AI_HUMANIZATION_ENABLE_FALLBACK=true
AI_HUMANIZATION_CRITICAL_KEYWORDS=["medicação","remédio","dosagem","mg","ml","emergência","urgente","hospital"]

# --------------------------------------------
# FIREBASE ADMIN SDK - FIREBASE_ADMIN_*
# --------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=your-production-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-production-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRODUCTION_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --------------------------------------------
# MONITORING & ERROR TRACKING - SENTRY_*, MONITORING_SENTRY_*, ERROR_*
# --------------------------------------------
# Monitoring Toggles
MONITORING_ENABLE_SERVICE=true
MONITORING_ENABLE_DEBUG=false
# Sentry Configuration (REQUIRED for production)
SENTRY_DSN=https://PUBLIC_KEY@ORGANIZATION.ingest.sentry.io/PROJECT_ID
MONITORING_SENTRY_DSN=https://PUBLIC_KEY@ORGANIZATION.ingest.sentry.io/PROJECT_ID
MONITORING_SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Error Tracking
ERROR_ENABLE_TRACKING=true
ERROR_MAX_LOGS=1000
ERROR_DEDUPLICATION_WINDOW_SECONDS=3600
ERROR_TRACKING_RATE_LIMIT=10
ERROR_ENABLE_CRITICAL_NOTIFICATION=true

# --------------------------------------------
# RATE LIMITING - RATE_LIMIT_*
# --------------------------------------------
RATE_LIMIT_ENABLE_SERVICE=true
RATE_LIMIT_REDIS_URL=redis://10.109.61.19:6379/3

# Webhook Rate Limiting - WEBHOOK_*
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_MIN_WAIT_SECONDS=2
WEBHOOK_RETRY_MAX_WAIT_SECONDS=60
WEBHOOK_RETRY_MULTIPLIER=1
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_BATCH_SIZE=50

# --------------------------------------------
# SECURITY FEATURES (CVE FIXES) - MIME_*, FILE_*, CLAMAV_*
# --------------------------------------------
# CVE-CLINIC-2025-002: MIME Type Validation
MIME_VALIDATION_ENABLED=true
MIME_VALIDATION_STRICT=true
MIME_ALLOWED_VARIANCE=false

# CVE-CLINIC-2025-003: File Security Scanning
FILE_SECURITY_ENABLED=true
ALLOW_MACROS=false
ALLOW_SCRIPTS_IN_PDF=false

# ClamAV Virus Scanning
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav-production.internal
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=30
CLAMAV_FALLBACK_CLI=false

# --------------------------------------------
# UPLOAD QUOTA MANAGEMENT - QUOTA_*
# --------------------------------------------
QUOTA_DEFAULT_USER_GB=1
QUOTA_PREMIUM_USER_GB=10
QUOTA_CACHE_TTL_SECONDS=300

# --------------------------------------------
# NOTIFICATION CHANNELS - SMTP_*, SLACK_*, PAGERDUTY_*, NOTIFICATION_*
# --------------------------------------------
# Email (SMTP) Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=YOUR_SENDGRID_API_KEY
SMTP_FROM_EMAIL=noreply@hormonia.example.com
SMTP_ENABLE_TLS=true

# Slack Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/PRODUCTION/WEBHOOK
SLACK_DEFAULT_CHANNEL=#production-alerts

# PagerDuty Configuration
PAGERDUTY_API_KEY=YOUR_PRODUCTION_PAGERDUTY_API_KEY
PAGERDUTY_SERVICE_KEY=YOUR_PRODUCTION_INTEGRATION_KEY

# Notification Retry Settings
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_SECONDS=5

# --------------------------------------------
# MONTHLY QUIZ CONFIGURATION - QUIZ_*
# --------------------------------------------
QUIZ_ENABLE_VIA_LINK=true
QUIZ_BASE_URL=https://quiz.hormonia.example.com
QUIZ_SHORT_BASE_URL=https://api.hormonia.example.com/q
QUIZ_TOKEN_SECRET=CHANGE_THIS_TO_SECURE_RANDOM_VALUE
QUIZ_TOKEN_EXPIRY_HOURS=72

# --------------------------------------------
# CELERY TASK CONFIGURATION - FLOW_*, TASK_*, MESSAGE_*, QUIZ_*
# --------------------------------------------
# Flow Processing
TASK_FLOW_PROCESSING_TIMEOUT_SECONDS=30
TASK_FLOW_BATCH_SIZE=10
TASK_FLOW_MAX_CONCURRENT=50
TASK_FLOW_MAX_RETRIES=3
TASK_FLOW_RETRY_DELAY_SECONDS=300

# Task Time Limits
TASK_TIME_LIMIT_SECONDS=3600
TASK_SOFT_TIME_LIMIT_SECONDS=3300

# Retry Configuration
TASK_MAX_RETRIES=3
TASK_RETRY_BACKOFF_FACTOR=2
TASK_RETRY_BACKOFF_BASE_SECONDS=300

# Message Processing
TASK_MESSAGE_SEND_TIMEOUT_SECONDS=60
TASK_MESSAGE_MAX_RETRIES=3
TASK_MESSAGE_RETRY_DELAY_SECONDS=60
TASK_MESSAGE_BATCH_SIZE=100
TASK_MESSAGE_RETRY_BATCH_SIZE=50

# Follow-up Deduplication
FOLLOW_UP_DEDUP_WINDOW_SECONDS=86400
FOLLOW_UP_DEDUP_LOCK_SECONDS=300

# Quiz Processing
TASK_QUIZ_PROCESSING_TIMEOUT_SECONDS=600
TASK_QUIZ_REPORT_TIMEOUT_SECONDS=300
TASK_QUIZ_MAX_RETRIES=3
TASK_QUIZ_RETRY_DELAY_SECONDS=60
TASK_QUIZ_SESSION_TIMEOUT_HOURS=48
TASK_QUIZ_EXPIRED_LINKS_BATCH_SIZE=100
TASK_WEBHOOK_DLQ_PROCESSING_TIMEOUT_SECONDS=180

# Health Monitoring
TASK_HEALTH_CHECK_TIMEOUT_SECONDS=30
TASK_HEALTH_ACTIVE_FLOWS_LIMIT=1000

# Cleanup Settings
TASK_CLEANUP_BATCH_SIZE=100
TASK_CLEANUP_DAYS_OLD=90
TASK_ARCHIVE_RETENTION_DAYS=365

# --------------------------------------------
# CACHE TTL SETTINGS - CACHE_*_TTL_SECONDS
# --------------------------------------------
# Flow & Templates
CACHE_FLOW_TEMPLATE_TTL_SECONDS=7200
CACHE_TEMPLATE_CACHE_TTL_SECONDS=7200

# User & Authentication
CACHE_USER_SESSION_TTL_SECONDS=3600
CACHE_AUTH_TOKEN_TTL_SECONDS=86400
CACHE_REFRESH_TOKEN_TTL_SECONDS=604800

# Patient Data
CACHE_PATIENT_CACHE_TTL_SECONDS=1800
CACHE_DOCTOR_CACHE_TTL_SECONDS=3600

# Quiz & Sessions
CACHE_QUIZ_SESSION_TTL_SECONDS=7200
CACHE_QUIZ_TEMPLATES_TTL_SECONDS=7200

# Messages & Communication
CACHE_MESSAGE_CACHE_TTL_SECONDS=3600
CACHE_MESSAGE_STATS_TTL_SECONDS=600
CACHE_WHATSAPP_METRICS_TTL_SECONDS=604800

# Webhooks & Idempotency
CACHE_WEBHOOK_IDEMPOTENCY_TTL_SECONDS=3600
CACHE_WEBHOOK_CACHE_TTL_SECONDS=600

# Rate Limiting
CACHE_RATE_LIMIT_WINDOW_TTL_SECONDS=60

# Reports & Analytics
CACHE_REPORT_CACHE_TTL_SECONDS=3600
CACHE_ANALYTICS_CACHE_TTL_SECONDS=600

# Distributed Systems
CACHE_DISTRIBUTED_LOCK_TTL_SECONDS=30
CACHE_SAGA_STATE_TTL_SECONDS=3600
CACHE_CIRCUIT_BREAKER_STATE_TTL_SECONDS=300

# Monitoring & Metrics
CACHE_SYSTEM_METRICS_TTL_SECONDS=60
CACHE_RESOURCE_MONITOR_TTL_SECONDS=300

# Connection State
CACHE_CONNECTION_STATE_TTL_SECONDS=300
CACHE_QRCODE_TTL_SECONDS=300

# --------------------------------------------
# TASK FEATURE FLAGS - TASK_*
# --------------------------------------------
TASK_ENABLE_ADMIN_ALERTS=true
TASK_ADMIN_ALERT_EMAIL=admin@hormonia.example.com
TASK_ENABLE_REDIS_CACHING=true

# --------------------------------------------
# DEPLOYMENT INFORMATION - DEPLOYMENT_*
# --------------------------------------------
DEPLOYMENT_VERSION=2.1.0
DEPLOYMENT_BUILD=#{CI_PIPELINE_ID}
DEPLOYMENT_COMMIT=#{CI_COMMIT_SHA}
DEPLOYMENT_DATE=#{CI_PIPELINE_CREATED_AT}

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Pre-Deployment:
# [ ] All environment variables set and validated
# [ ] Secrets rotated from development/staging
# [ ] Database migrations tested and ready
# [ ] SSL/TLS certificates valid and configured
# [ ] Monitoring and alerting configured
# [ ] Backup strategy implemented and tested
# [ ] Disaster recovery plan documented
# [ ] Load testing completed
# [ ] Security audit passed
# [ ] Team trained on runbook procedures
#
# Post-Deployment:
# [ ] Health checks passing
# [ ] Error tracking receiving events
# [ ] Metrics and dashboards operational
# [ ] Alerts configured and tested
# [ ] Log aggregation working
# [ ] Database performance metrics normal
# [ ] API response times within SLA
# [ ] No errors in application logs
# ============================================================================
