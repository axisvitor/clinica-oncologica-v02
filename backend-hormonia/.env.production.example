# ============================================================================
# BACKEND HORMONIA - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# Version: 2.1.0
# Last Updated: 2025-11-16
# Environment: PRODUCTION
#
# ⚠️  CRITICAL PRODUCTION SECURITY CHECKLIST:
# [ ] All secrets rotated from development values
# [ ] SSL/TLS enabled for all external connections
# [ ] Rate limiting enabled and configured
# [ ] Error tracking (Sentry) configured
# [ ] Monitoring and alerting configured
# [ ] Backup strategy implemented
# [ ] Disaster recovery plan documented
# [ ] Security audit completed
# ============================================================================

# --------------------------------------------
# ENVIRONMENT CONFIGURATION
# --------------------------------------------
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=false  # Reduce log volume in production
LOG_STACK_TRACES=true
MAX_LOGS_PER_SECOND=100

# --------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# --------------------------------------------
# ⚠️  CRITICAL: Must use SSL connection in production (sslmode=require)
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
#
# Example (AWS RDS):
# DATABASE_URL=postgresql+psycopg://app_user:PASSWORD@production-cluster.cluster-abc123.us-east-1.rds.amazonaws.com:5432/hormonia_prod?sslmode=require
#
# Example (Railway):
# DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@containers-us-west-123.railway.app:5432/railway?sslmode=require
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Connection pool settings (optimized for production load)
DB_POOL_SIZE=30              # Permanent connections
DB_MAX_OVERFLOW=40           # Additional connections under load
DB_POOL_TIMEOUT=30           # Connection timeout (seconds)
DB_POOL_RECYCLE=3600         # Recycle connections after 1 hour

# --------------------------------------------
# REDIS CONFIGURATION
# --------------------------------------------
# ⚠️  CRITICAL: Must use rediss:// (with SSL) in production
# Format: rediss://default:PASSWORD@HOST:PORT
#
# Example (Railway):
# REDIS_URL=rediss://default:PASSWORD@redis.railway.internal:6379
#
# Example (AWS ElastiCache):
# REDIS_URL=rediss://default:PASSWORD@production-redis.abc123.cache.amazonaws.com:6379
ENABLE_REDIS=true
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
REDIS_PASSWORD=CHANGE_THIS_TO_SECURE_REDIS_PASSWORD
REDIS_HOST=HOST
REDIS_PORT=6379

# SSL/TLS Configuration
REDIS_SSL=true
REDIS_SSL_CERT_REQS=required  # Enforce certificate validation

# Connection Pool Settings (production optimized)
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=10.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# Database Isolation
REDIS_ENABLE_DB_ISOLATION=true
REDIS_CACHE_DB=1              # Application cache
REDIS_BROKER_DB=0             # Celery broker
REDIS_SESSION_DB=2            # User sessions
REDIS_RATE_LIMIT_DB=3         # Rate limiting

# --------------------------------------------
# CELERY CONFIGURATION (Task Queue)
# --------------------------------------------
# ⚠️  CRITICAL: Use rediss:// with SSL
CELERY_BROKER_URL=rediss://default:PASSWORD@HOST:PORT/0
CELERY_RESULT_BACKEND=rediss://default:PASSWORD@HOST:PORT/0
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_TIME_LIMIT=300
CELERY_WORKER_SOFT_TIME_LIMIT=240
CELERY_QUEUES=celery,flows,quiz,maintenance,monitoring

# --------------------------------------------
# CORS CONFIGURATION
# --------------------------------------------
# ⚠️  CRITICAL: Set to production frontend URLs only (no wildcards!)
FRONTEND_URL=https://app.hormonia.example.com
QUIZ_URL=https://quiz.hormonia.example.com
ALLOWED_ORIGINS=https://app.hormonia.example.com,https://quiz.hormonia.example.com

# --------------------------------------------
# SECURITY CONFIGURATION
# --------------------------------------------
# ⚠️  CRITICAL: Generate secure random secrets for production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# JWT Configuration
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE_32_BYTES_OR_MORE
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CSRF Protection
CSRF_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE_DIFFERENT_FROM_JWT

# Data Encryption (for PII fields)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_THIS_TO_FERNET_ENCRYPTION_KEY

# Webhook Security
EVOLUTION_WEBHOOK_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE

# --------------------------------------------
# INTEGRATIONS - EVOLUTION API (WhatsApp)
# --------------------------------------------
ENABLE_EVOLUTION=true
EVOLUTION_API_URL=https://api.evolution.production.com
EVOLUTION_INSTANCE_NAME=clinica_oncologica_prod
EVOLUTION_API_KEY=YOUR_PRODUCTION_EVOLUTION_API_KEY

# WhatsApp Configuration
ENABLE_WHATSAPP_ON_REGISTRATION=true
WHATSAPP_WELCOME_MESSAGE_ENABLED=true
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_SECONDS=60
CLINIC_NAME=Neoplasias Litoral
CLINIC_SUPPORT_PHONE=+5511999887766

# --------------------------------------------
# AI SERVICES (Google Gemini)
# --------------------------------------------
GEMINI_API_KEY=YOUR_PRODUCTION_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=500
GEMINI_TOP_P=0.8
GEMINI_TOP_K=40
GEMINI_TIMEOUT=30
GEMINI_MAX_RETRIES=3

# AI Humanization Configuration
AI_HUMANIZATION_ENABLED=true
AI_HUMANIZATION_SAFETY_MODE=true
AI_HUMANIZATION_MAX_RETRIES=2
AI_HUMANIZATION_TIMEOUT=10.0
AI_HUMANIZATION_FALLBACK_ENABLED=true
AI_HUMANIZATION_CRITICAL_KEYWORDS=["medicação","remédio","dosagem","mg","ml","emergência","urgente","hospital"]

# --------------------------------------------
# FIREBASE ADMIN SDK
# --------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=your-production-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-production-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRODUCTION_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --------------------------------------------
# MONITORING & ERROR TRACKING
# --------------------------------------------
# Sentry Configuration (REQUIRED for production)
SENTRY_DSN=https://PUBLIC_KEY@ORGANIZATION.ingest.sentry.io/PROJECT_ID
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% performance tracing
SENTRY_PROFILES_SAMPLE_RATE=0.1  # 10% profiling

# Error Tracking
ENABLE_ERROR_TRACKING=true
MAX_ERROR_LOGS=1000
ERROR_DEDUPLICATION_WINDOW=3600
ERROR_TRACKING_RATE_LIMIT=10
CRITICAL_ERROR_NOTIFICATION=true

# --------------------------------------------
# RATE LIMITING
# --------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URL=rediss://default:PASSWORD@HOST:PORT/3

# API Rate Limits (per minute)
RATE_LIMIT_ANONYMOUS=60
RATE_LIMIT_AUTHENTICATED=300
RATE_LIMIT_PREMIUM=1000
RATE_LIMIT_ADMIN=5000

# Webhook Rate Limiting
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_MIN_WAIT=2
WEBHOOK_RETRY_MAX_WAIT=60
WEBHOOK_RETRY_MULTIPLIER=1
WEBHOOK_TIMEOUT=30
WEBHOOK_BATCH_SIZE=50

# --------------------------------------------
# SECURITY FEATURES (CVE FIXES)
# --------------------------------------------
# CVE-CLINIC-2025-002: MIME Type Validation
MIME_VALIDATION_ENABLED=true
MIME_VALIDATION_STRICT=true  # Strict mode in production
MIME_ALLOWED_VARIANCE=false  # No fuzzy matching in production

# CVE-CLINIC-2025-003: File Security Scanning
FILE_SECURITY_ENABLED=true
ALLOW_MACROS=false  # Never allow macros in production
ALLOW_PDF_JAVASCRIPT=false  # Never allow PDF JavaScript in production

# ClamAV Virus Scanning
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav-production.internal
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=30
CLAMAV_FAIL_OPEN=false  # Fail closed in production (reject if scanner unavailable)
QUARANTINE_DIR=/var/quarantine

# --------------------------------------------
# UPLOAD QUOTA MANAGEMENT
# --------------------------------------------
DEFAULT_USER_QUOTA_GB=1
PREMIUM_USER_QUOTA_GB=10
QUOTA_CACHE_TTL=300

# --------------------------------------------
# NOTIFICATION CHANNELS
# --------------------------------------------
# Email (SMTP) Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=YOUR_SENDGRID_API_KEY
SMTP_FROM_EMAIL=noreply@hormonia.example.com
SMTP_USE_TLS=true

# Slack Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/PRODUCTION/WEBHOOK
SLACK_DEFAULT_CHANNEL=#production-alerts

# PagerDuty Configuration
PAGERDUTY_API_KEY=YOUR_PRODUCTION_PAGERDUTY_API_KEY
PAGERDUTY_SERVICE_KEY=YOUR_PRODUCTION_INTEGRATION_KEY

# Notification Retry Settings
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5

# --------------------------------------------
# MONTHLY QUIZ CONFIGURATION
# --------------------------------------------
MONTHLY_QUIZ_VIA_LINK=true
MONTHLY_QUIZ_BASE_URL=https://quiz.hormonia.example.com
MONTHLY_QUIZ_TOKEN_SECRET=CHANGE_THIS_TO_SECURE_RANDOM_VALUE
MONTHLY_QUIZ_TOKEN_EXPIRY_HOURS=72

# --------------------------------------------
# CELERY TASK CONFIGURATION
# --------------------------------------------
# Flow Processing
FLOW_PROCESSING_TIMEOUT=30
FLOW_BATCH_SIZE=10
FLOW_MAX_CONCURRENT=50
FLOW_MAX_RETRIES=3
FLOW_RETRY_DELAY=300

# Task Time Limits
TASK_TIME_LIMIT=3600
TASK_SOFT_TIME_LIMIT=3300

# Retry Configuration
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2
RETRY_BACKOFF_BASE=300

# Message Processing
MESSAGE_SEND_TIMEOUT=60
MESSAGE_MAX_RETRIES=3
MESSAGE_RETRY_DELAY=60
MESSAGE_BATCH_SIZE=100
MESSAGE_RETRY_BATCH_SIZE=50

# Quiz Processing
QUIZ_PROCESSING_TIMEOUT=600
QUIZ_REPORT_TIMEOUT=300
QUIZ_MAX_RETRIES=3
QUIZ_RETRY_DELAY=60
QUIZ_SESSION_TIMEOUT_HOURS=48
QUIZ_EXPIRED_LINKS_BATCH_SIZE=100

# Health Monitoring
HEALTH_CHECK_TIMEOUT=30
HEALTH_ACTIVE_FLOWS_LIMIT=1000

# Cleanup Settings
CLEANUP_BATCH_SIZE=100
CLEANUP_DAYS_OLD=90
ARCHIVE_RETENTION_DAYS=365

# --------------------------------------------
# CACHE TTL SETTINGS (seconds)
# --------------------------------------------
# Flow & Templates
CACHE_FLOW_TEMPLATE_TTL=7200
CACHE_TEMPLATE_CACHE_TTL=7200

# User & Authentication
CACHE_USER_SESSION_TTL=3600
CACHE_AUTH_TOKEN_TTL=86400
CACHE_REFRESH_TOKEN_TTL=604800

# Patient Data
CACHE_PATIENT_CACHE_TTL=1800
CACHE_DOCTOR_CACHE_TTL=3600

# Quiz & Sessions
CACHE_QUIZ_SESSION_TTL=7200
CACHE_QUIZ_TEMPLATES_TTL=7200

# Messages & Communication
CACHE_MESSAGE_CACHE_TTL=3600
CACHE_MESSAGE_STATS_TTL=600
CACHE_WHATSAPP_METRICS_TTL=604800

# Webhooks & Idempotency
CACHE_WEBHOOK_IDEMPOTENCY_TTL=3600
CACHE_WEBHOOK_CACHE_TTL=600

# Rate Limiting
CACHE_RATE_LIMIT_WINDOW_TTL=60

# Reports & Analytics
CACHE_REPORT_CACHE_TTL=3600
CACHE_ANALYTICS_CACHE_TTL=600

# Distributed Systems
CACHE_DISTRIBUTED_LOCK_TTL=30
CACHE_SAGA_STATE_TTL=3600
CACHE_CIRCUIT_BREAKER_STATE_TTL=300

# Monitoring & Metrics
CACHE_SYSTEM_METRICS_TTL=60
CACHE_RESOURCE_MONITOR_TTL=300

# Connection State
CACHE_CONNECTION_STATE_TTL=300
CACHE_QRCODE_TTL=300

# --------------------------------------------
# FEATURE FLAGS
# --------------------------------------------
ENABLE_SWAGGER_UI=false  # Disable Swagger UI in production for security
ENABLE_DEBUG_TOOLBAR=false  # Never enable in production
ENABLE_METRICS_ENDPOINT=true
ENABLE_ADMIN_ALERTS=true
ADMIN_ALERT_EMAIL=admin@hormonia.example.com
ENABLE_SAGA_PATTERN=true
ENABLE_REDIS_CACHING=true

# --------------------------------------------
# DEPLOYMENT INFORMATION
# --------------------------------------------
# Optional: Track deployment metadata
DEPLOYMENT_VERSION=2.1.0
DEPLOYMENT_BUILD=#{CI_PIPELINE_ID}
DEPLOYMENT_COMMIT=#{CI_COMMIT_SHA}
DEPLOYMENT_DATE=#{CI_PIPELINE_CREATED_AT}

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Pre-Deployment:
# [ ] All environment variables set and validated
# [ ] Secrets rotated from development/staging
# [ ] Database migrations tested and ready
# [ ] SSL/TLS certificates valid and configured
# [ ] Monitoring and alerting configured
# [ ] Backup strategy implemented and tested
# [ ] Disaster recovery plan documented
# [ ] Load testing completed
# [ ] Security audit passed
# [ ] Team trained on runbook procedures
#
# Post-Deployment:
# [ ] Health checks passing
# [ ] Error tracking receiving events
# [ ] Metrics and dashboards operational
# [ ] Alerts configured and tested
# [ ] Log aggregation working
# [ ] Database performance metrics normal
# [ ] API response times within SLA
# [ ] No errors in application logs
# ============================================================================
