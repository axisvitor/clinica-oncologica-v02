# =============================================================================
# RAILWAY PRODUCTION ENVIRONMENT TEMPLATE - BACKEND
# =============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env.railway
# 2. Fill in all the values (replace all 'REPLACE_WITH_*' placeholders)
# 3. Use this file to set Railway environment variables:
#    railway variables set --from-file .env.railway
#
# SECURITY NOTE: This file contains sensitive information
# - Never commit this file to version control
# - Keep it secure and limit access
# =============================================================================

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================

# Environment Configuration
ENVIRONMENT=production
DEBUG=false
APP_NAME=NeoplasiaLitoral-Backend
APP_VERSION=2.0.0

# Security Keys - CRITICAL: Generate secure keys
# Use: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_64_CHARACTER_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Security
BCRYPT_ROUNDS=12

# Quiz Token Security - Use different secret than main SECRET_KEY
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
MONTHLY_QUIZ_TOKEN_SECRET=REPLACE_WITH_QUIZ_TOKEN_SECRET_DIFFERENT_FROM_MAIN_SECRET

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Railway automatically provides PORT
PORT=8000
HOST=0.0.0.0
WEB_CONCURRENCY=2

# =============================================================================
# DATABASE CONFIGURATION - SUPABASE
# =============================================================================

# Supabase Configuration
# Get from: https://app.supabase.com/project/YOUR_PROJECT_ID/settings/api
SUPABASE_URL=https://REPLACE_WITH_YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# Database URL - Supabase PostgreSQL
# Get from: https://app.supabase.com/project/YOUR_PROJECT_ID/settings/database
# IMPORTANT: Use postgresql+psycopg:// for Python 3.13 compatibility (psycopg v3)
DATABASE_URL=postgresql+psycopg://postgres:REPLACE_WITH_PASSWORD@db.REPLACE_WITH_PROJECT_ID.supabase.co:5432/postgres

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis Cloud Configuration (Recommended)
# Get from: https://redis.com dashboard
# IMPORTANT: Use rediss:// (with two 's') for SSL/TLS connections
REDIS_URL=rediss://default:REPLACE_WITH_REDIS_PASSWORD@REPLACE_WITH_REDIS_HOST:REPLACE_WITH_REDIS_PORT
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_HOST=REPLACE_WITH_REDIS_HOST
REDIS_PORT=6379
REDIS_SSL=true
# CERTIFICATE VALIDATION (SECURE MODE with CA certificate)
# "required" = Validate server certificate against CA (most secure - RECOMMENDED)
# "optional" = Try to validate but allow connection if validation fails
# "none" = No validation (encrypted but not verified - less secure)
REDIS_SSL_CERT_REQS=required

# CA CERTIFICATE: Path to Redis Cloud CA certificate (relative to backend-hormonia/)
# Download from: https://redis.io/docs/latest/operate/rc/security/database-security/tls-ssl/
# Upload to Railway: railway run --service backend-hormonia upload certs/redis_ca.pem
# OR add file via Railway Dashboard → backend-hormonia → Files
REDIS_SSL_CA_CERTS=certs/redis_ca.pem

# TLS VERSION: Force TLS 1.2 for Redis Cloud compatibility
# Python 3.13 + OpenSSL 3.x defaults to TLS 1.3, but Redis Cloud requires TLS 1.2
# Options: TLSv1_2, TLSv1_3, or leave empty for auto-negotiation
REDIS_SSL_MIN_VERSION=TLSv1_2

REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=30.0
REDIS_DECODE_RESPONSES=true

# =============================================================================
# CELERY CONFIGURATION - BACKGROUND TASKS
# =============================================================================

# Celery Broker and Backend (Redis)
# IMPORTANT: Use rediss:// (with SSL) for secure production connections
CELERY_BROKER_URL=rediss://default:REPLACE_WITH_REDIS_PASSWORD@REPLACE_WITH_REDIS_HOST:REPLACE_WITH_REDIS_PORT/0
CELERY_RESULT_BACKEND=rediss://default:REPLACE_WITH_REDIS_PASSWORD@REPLACE_WITH_REDIS_HOST:REPLACE_WITH_REDIS_PORT/1

# Celery Worker Configuration
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240

# =============================================================================
# AI SERVICES CONFIGURATION
# =============================================================================

# Google Gemini AI
# Get API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_GOOGLE_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_TOP_P=0.8
GEMINI_TOP_K=40
GEMINI_TIMEOUT=30
GEMINI_MAX_RETRIES=3

# LangChain Configuration (Optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=REPLACE_WITH_LANGCHAIN_API_KEY_OR_LEAVE_EMPTY

# AI Humanization Settings
AI_HUMANIZATION_ENABLED=true
AI_HUMANIZATION_SAFETY_MODE=true
AI_HUMANIZATION_MAX_RETRIES=2
AI_HUMANIZATION_TIMEOUT=10.0
AI_HUMANIZATION_FALLBACK_ENABLED=true

# =============================================================================
# WHATSAPP INTEGRATION - EVOLUTION API
# =============================================================================

# Evolution API Configuration
ENABLE_EVOLUTION=true
EVOLUTION_API_URL=https://REPLACE_WITH_EVOLUTION_DOMAIN.railway.app
EVOLUTION_INSTANCE_NAME=hormonia-instance
EVOLUTION_API_KEY=REPLACE_WITH_EVOLUTION_API_KEY

# Webhook Configuration
EVOLUTION_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
EVOLUTION_WEBHOOK_URL=https://REPLACE_WITH_BACKEND_DOMAIN.railway.app/api/v2/webhooks/whatsapp

# WhatsApp Settings
WHATSAPP_NUMBER=REPLACE_WITH_WHATSAPP_NUMBER
WHATSAPP_MESSAGE_DELAY=2
WHATSAPP_MAX_RETRIES=3
WHATSAPP_TIMEOUT=30

# =============================================================================
# CORS AND SECURITY CONFIGURATION
# =============================================================================

# CORS Origins - JSON array format
# Include your frontend domains
ALLOWED_ORIGINS=["https://REPLACE_WITH_FRONTEND_DOMAIN.railway.app","https://REPLACE_WITH_QUIZ_DOMAIN.railway.app","https://app.yourdomain.com","https://quiz.yourdomain.com"]

# Allowed Hosts
ALLOWED_HOSTS=["REPLACE_WITH_BACKEND_DOMAIN.railway.app","api.yourdomain.com"]

# Security Headers
SECURE_SSL_REDIRECT=true
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_BROWSER_XSS_FILTER=true

# Session Configuration
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# =============================================================================
# MONTHLY QUIZ SYSTEM
# =============================================================================

# Monthly Quiz Configuration
MONTHLY_QUIZ_VIA_LINK=true
MONTHLY_QUIZ_BASE_URL=https://REPLACE_WITH_QUIZ_DOMAIN.railway.app/quiz/monthly

# Quiz Token Security - Use different secret than main SECRET_KEY
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
MONTHLY_QUIZ_TOKEN_SECRET=REPLACE_WITH_QUIZ_TOKEN_SECRET_DIFFERENT_FROM_MAIN_SECRET
MONTHLY_QUIZ_TOKEN_EXPIRY_HOURS=72

# Quiz Processing
QUIZ_CACHE_TIMEOUT=1800
QUIZ_RESULTS_RETENTION_DAYS=365
MONTHLY_QUIZ_RATE_LIMIT_PER_HOUR=10

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Monitoring
MONITORING_ENABLED=true
MONITORING_DEBUG=false
APM_APDEX_THRESHOLD=0.5
APM_SLOW_REQUEST_THRESHOLD=1.0

# Resource Monitoring
RESOURCE_SAMPLE_INTERVAL=10.0
RESOURCE_CPU_THRESHOLD=80.0
RESOURCE_MEMORY_THRESHOLD=85.0

# Dashboard Configuration
DASHBOARD_UPDATE_INTERVAL=5.0

# Sentry Error Tracking (Optional)
SENTRY_DSN=REPLACE_WITH_SENTRY_DSN_OR_LEAVE_EMPTY
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=0.1

# =============================================================================
# RATE LIMITING
# =============================================================================

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=1000/hour

# =============================================================================
# FILE STORAGE
# =============================================================================

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,gif,txt
UPLOAD_DIR=uploads

# =============================================================================
# LOCALIZATION
# =============================================================================

# Language Settings
DEFAULT_LOCALE=pt-BR
SUPPORTED_LOCALES=["en","pt-BR","es"]
TIMEZONE=America/Sao_Paulo

# =============================================================================
# HEALTH CHECKS AND API
# =============================================================================

# Health Check Configuration
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_DATABASE=true
HEALTH_CHECK_REDIS=true
HEALTH_CHECK_EXTERNAL_APIS=true
HEALTH_CHECK_TIMEOUT=10

# API Configuration
API_VERSION=v1
API_TITLE=Neoplasias Litoral Backend API
API_DESCRIPTION=Backend API for Clínica Oncológica system

# =============================================================================
# BACKUP AND MAINTENANCE
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Maintenance
MAINTENANCE_MODE=false
READ_ONLY_MODE=false

# =============================================================================
# CLINIC INFORMATION
# =============================================================================

# Clinic Details for branding and communications
CLINIC_NAME=Neoplasias Litoral
CLINIC_ADDRESS=REPLACE_WITH_CLINIC_ADDRESS
CLINIC_PHONE=REPLACE_WITH_CLINIC_PHONE
CLINIC_EMAIL=REPLACE_WITH_CLINIC_EMAIL

# =============================================================================
# DEPLOYMENT VALIDATION
# =============================================================================

# These variables help validate the deployment
DEPLOYMENT_ENVIRONMENT=railway
DEPLOYMENT_DATE=REPLACE_WITH_DEPLOYMENT_DATE
DEPLOYMENT_VERSION=2.0.0

# =============================================================================
# INSTRUCTIONS FOR RAILWAY CLI:
#
# 1. Set variables from this file:
#    railway variables set --from-file .env.railway
#
# 2. Or set individual variables:
#    railway variables set SECRET_KEY="your-secret-key"
#
# 3. View all variables:
#    railway variables
#
# 4. Remove a variable:
#    railway variables unset VARIABLE_NAME
#
# =============================================================================