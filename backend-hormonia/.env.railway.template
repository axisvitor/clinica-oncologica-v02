# =============================================================================
# RAILWAY PRODUCTION ENVIRONMENT TEMPLATE - BACKEND
# =============================================================================
# ENV Variable Naming Convention: {CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
#
# INSTRUCTIONS:
# 1. Copy this file to .env.railway
# 2. Fill in all the values (replace all 'REPLACE_WITH_*' placeholders)
# 3. Use this file to set Railway environment variables:
#    railway variables set --from-file .env.railway
#
# SECURITY NOTE: This file contains sensitive information
# - Never commit this file to version control
# - Keep it secure and limit access
# =============================================================================

# =============================================================================
# APPLICATION CONFIGURATION - APP_*
# =============================================================================
APP_ENVIRONMENT=production
APP_ENABLE_DEBUG=false
APP_NAME=NeoplasiaLitoral-Backend
APP_VERSION=2.0.0

# =============================================================================
# SECURITY CONFIGURATION - SECURITY_*, AUTH_*
# =============================================================================
# Use: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECURITY_SECRET_KEY=REPLACE_WITH_64_CHARACTER_SECRET_KEY
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Security
SECURITY_BCRYPT_ROUNDS=12

# Quiz Token Security - Use different secret than main SECRET_KEY
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
QUIZ_TOKEN_SECRET=REPLACE_WITH_QUIZ_TOKEN_SECRET_DIFFERENT_FROM_MAIN_SECRET

# =============================================================================
# SERVER CONFIGURATION - SERVER_*
# =============================================================================
# Railway automatically provides PORT
SERVER_PORT=8000
SERVER_HOST=0.0.0.0
SERVER_WEB_CONCURRENCY=2

# =============================================================================
# DATABASE CONFIGURATION - DATABASE_*
# =============================================================================
# IMPORTANT: Use postgresql+psycopg:// for Python 3.13 compatibility (psycopg v3)
# Include sslmode=require in production environments
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@YOUR_RDS_HOST:5432/DBNAME?sslmode=require

# Connection Pool Settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=3600

# =============================================================================
# REDIS CONFIGURATION - REDIS_*
# =============================================================================
# IMPORTANT: Use rediss:// (with two 's') for SSL/TLS connections
REDIS_URL=rediss://default:REPLACE_WITH_REDIS_PASSWORD@REPLACE_WITH_REDIS_HOST:REPLACE_WITH_REDIS_PORT
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_HOST=REPLACE_WITH_REDIS_HOST
REDIS_PORT=6379
REDIS_ENABLE_SSL=true
# CERTIFICATE VALIDATION (SECURE MODE with CA certificate)
# "required" = Validate server certificate against CA (most secure - RECOMMENDED)
# "optional" = Try to validate but allow connection if validation fails
# "none" = No validation (encrypted but not verified - less secure)
REDIS_SSL_CERT_REQS=required

# CA CERTIFICATE: Path to Redis Cloud CA certificate (relative to backend-hormonia/)
REDIS_SSL_CA_CERTS=certs/redis_ca.pem

# TLS VERSION: Force TLS 1.2 for Redis Cloud compatibility
REDIS_SSL_MIN_VERSION=TLSv1_2

REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT_SECONDS=30.0
REDIS_ENABLE_DECODE_RESPONSES=true

# =============================================================================
# CELERY CONFIGURATION - CELERY_*
# =============================================================================
# IMPORTANT: Use rediss:// (with SSL) for secure production connections
CELERY_BROKER_URL=rediss://default:REPLACE_WITH_REDIS_PASSWORD@REPLACE_WITH_REDIS_HOST:REPLACE_WITH_REDIS_PORT/0
CELERY_RESULT_BACKEND=rediss://default:REPLACE_WITH_REDIS_PASSWORD@REPLACE_WITH_REDIS_HOST:REPLACE_WITH_REDIS_PORT/1

# Celery Worker Configuration
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_TIME_LIMIT_SECONDS=300
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=240

# =============================================================================
# AI SERVICES CONFIGURATION - AI_GEMINI_*, AI_LANGCHAIN_*, AI_HUMANIZATION_*
# =============================================================================
# Google Gemini AI
AI_GEMINI_API_KEY=REPLACE_WITH_GOOGLE_GEMINI_API_KEY
AI_GEMINI_MODEL=gemini-2.0-flash-exp
AI_GEMINI_TEMPERATURE=0.7
AI_GEMINI_MAX_OUTPUT_TOKENS=4096
AI_GEMINI_TOP_P=0.8
AI_GEMINI_TOP_K=40
AI_GEMINI_TIMEOUT_SECONDS=30
AI_GEMINI_MAX_RETRIES=3

# LangChain Configuration (Optional)
AI_LANGCHAIN_ENABLE_TRACING=false
AI_LANGCHAIN_API_KEY=REPLACE_WITH_LANGCHAIN_API_KEY_OR_LEAVE_EMPTY

# AI Humanization Settings
AI_HUMANIZATION_ENABLE=true
AI_HUMANIZATION_ENABLE_SAFETY_MODE=true
AI_HUMANIZATION_MAX_RETRIES=2
AI_HUMANIZATION_TIMEOUT_SECONDS=10.0
AI_HUMANIZATION_ENABLE_FALLBACK=true

# =============================================================================
# WHATSAPP INTEGRATION - EVOLUTION_*, WHATSAPP_*, CLINIC_*
# =============================================================================
EVOLUTION_ENABLE=true
EVOLUTION_API_URL=https://REPLACE_WITH_EVOLUTION_DOMAIN.railway.app
EVOLUTION_INSTANCE_NAME=hormonia-instance
EVOLUTION_API_KEY=REPLACE_WITH_EVOLUTION_API_KEY

# Webhook Configuration
EVOLUTION_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
EVOLUTION_WEBHOOK_URL=https://REPLACE_WITH_BACKEND_DOMAIN.railway.app/api/v2/webhooks/whatsapp

# WhatsApp Settings
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_SECONDS=60
CLINIC_NAME=Neoplasias Litoral
CLINIC_SUPPORT_PHONE=+55REPLACE_WITH_SUPPORT_NUMBER

# =============================================================================
# FIREBASE ADMIN SDK - FIREBASE_ADMIN_*
# =============================================================================
FIREBASE_ADMIN_PROJECT_ID=REPLACE_WITH_FIREBASE_PROJECT_ID
FIREBASE_ADMIN_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY\n-----END PRIVATE KEY-----\n

# =============================================================================
# CORS AND SECURITY CONFIGURATION - CORS_*, AUTH_*
# =============================================================================
# CORS Origins - JSON array format
CORS_ALLOWED_ORIGINS=["https://REPLACE_WITH_FRONTEND_DOMAIN.railway.app","https://REPLACE_WITH_QUIZ_DOMAIN.railway.app","https://app.yourdomain.com","https://quiz.yourdomain.com"]

# Allowed Hosts
SECURITY_ALLOWED_HOSTS=["REPLACE_WITH_BACKEND_DOMAIN.railway.app","api.yourdomain.com"]

# Security Headers
SECURITY_ENABLE_SSL_REDIRECT=true
SECURITY_ENABLE_CONTENT_TYPE_NOSNIFF=true
SECURITY_ENABLE_BROWSER_XSS_FILTER=true

# Session Configuration
AUTH_SESSION_COOKIE_SECURE=true
AUTH_SESSION_COOKIE_HTTPONLY=true
AUTH_SESSION_COOKIE_SAMESITE=Strict

# =============================================================================
# MONTHLY QUIZ SYSTEM - QUIZ_*
# =============================================================================
QUIZ_ENABLE_VIA_LINK=true
QUIZ_BASE_URL=https://REPLACE_WITH_QUIZ_DOMAIN.railway.app/quiz/monthly

# Quiz Token Security
QUIZ_TOKEN_SECRET=REPLACE_WITH_QUIZ_TOKEN_SECRET_DIFFERENT_FROM_MAIN_SECRET
QUIZ_TOKEN_EXPIRY_HOURS=72

# Quiz Processing
QUIZ_CACHE_TIMEOUT_SECONDS=1800
QUIZ_RESULTS_RETENTION_DAYS=365
QUIZ_RATE_LIMIT_PER_HOUR=10

# =============================================================================
# MONITORING AND LOGGING - LOGGING_*, MONITORING_*
# =============================================================================
LOGGING_LEVEL=INFO
LOGGING_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Monitoring
MONITORING_ENABLE=true
MONITORING_ENABLE_DEBUG=false
MONITORING_APM_APDEX_THRESHOLD=0.5
MONITORING_APM_SLOW_REQUEST_THRESHOLD_SECONDS=1.0

# Resource Monitoring
MONITORING_RESOURCE_SAMPLE_INTERVAL_SECONDS=10.0
MONITORING_RESOURCE_CPU_THRESHOLD_PERCENT=80.0
MONITORING_RESOURCE_MEMORY_THRESHOLD_PERCENT=85.0

# Dashboard Configuration
MONITORING_DASHBOARD_UPDATE_INTERVAL_SECONDS=5.0

# Sentry Error Tracking (Optional)
MONITORING_SENTRY_DSN=REPLACE_WITH_SENTRY_DSN_OR_LEAVE_EMPTY
MONITORING_SENTRY_ENVIRONMENT=production
MONITORING_SENTRY_SAMPLE_RATE=0.1

# =============================================================================
# RATE LIMITING - RATE_LIMIT_*
# =============================================================================
RATE_LIMIT_ENABLE=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=1000/hour

# =============================================================================
# FILE STORAGE - UPLOAD_*
# =============================================================================
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
UPLOAD_ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,gif,txt
UPLOAD_DIR=uploads

# =============================================================================
# LOCALIZATION - LOCALE_*
# =============================================================================
LOCALE_DEFAULT=pt-BR
LOCALE_SUPPORTED=["en","pt-BR","es"]
LOCALE_TIMEZONE=America/Sao_Paulo

# =============================================================================
# HEALTH CHECKS AND API - HEALTH_*, API_*
# =============================================================================
HEALTH_CHECK_PATH=/health
HEALTH_ENABLE_DATABASE_CHECK=true
HEALTH_ENABLE_REDIS_CHECK=true
HEALTH_ENABLE_EXTERNAL_APIS_CHECK=true
HEALTH_CHECK_TIMEOUT_SECONDS=10

# API Configuration
API_VERSION=v2
API_TITLE=Neoplasias Litoral Backend API
API_DESCRIPTION=Backend API for Clínica Oncológica system

# =============================================================================
# BACKUP AND MAINTENANCE - BACKUP_*, MAINTENANCE_*
# =============================================================================
BACKUP_ENABLE=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Maintenance
MAINTENANCE_ENABLE_MODE=false
MAINTENANCE_ENABLE_READ_ONLY=false

# =============================================================================
# CLINIC INFORMATION - CLINIC_*
# =============================================================================
CLINIC_NAME=Neoplasias Litoral
CLINIC_ADDRESS=REPLACE_WITH_CLINIC_ADDRESS
CLINIC_PHONE=REPLACE_WITH_CLINIC_PHONE
CLINIC_EMAIL=REPLACE_WITH_CLINIC_EMAIL

# =============================================================================
# DEPLOYMENT VALIDATION - DEPLOYMENT_*
# =============================================================================
DEPLOYMENT_ENVIRONMENT=railway
DEPLOYMENT_DATE=REPLACE_WITH_DEPLOYMENT_DATE
DEPLOYMENT_VERSION=2.0.0

# =============================================================================
# INSTRUCTIONS FOR RAILWAY CLI:
#
# 1. Set variables from this file:
#    railway variables set --from-file .env.railway
#
# 2. Or set individual variables:
#    railway variables set SECURITY_SECRET_KEY="your-secret-key"
#
# 3. View all variables:
#    railway variables
#
# 4. Remove a variable:
#    railway variables unset VARIABLE_NAME
#
# =============================================================================
