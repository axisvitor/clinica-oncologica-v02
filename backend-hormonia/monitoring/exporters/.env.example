# =============================================================================
# CUSTOM METRICS EXPORTER CONFIGURATION
# =============================================================================
# ENV Variable Naming Convention: {CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
# =============================================================================

# ============================================================================
# EXPORTER SETTINGS - EXPORTER_*
# ============================================================================
EXPORTER_PORT=9100
EXPORTER_COLLECTION_INTERVAL_SECONDS=60

# ============================================================================
# DATABASE CONNECTION - DB_*
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hormonia
DB_USER=postgres
DB_PASSWORD=your_password_here

# ============================================================================
# REDIS CONNECTION - REDIS_*
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
