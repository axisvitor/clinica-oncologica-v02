{
  "dashboard": {
    "title": "WhatsApp Integration Monitoring",
    "tags": ["whatsapp", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "type": "graph",
        "title": "Message Throughput (Sent vs Failed)",
        "targets": [
          {
            "expr": "sum(rate(whatsapp_messages_sent_total[1m])) by (instance, status)",
            "legendFormat": "sent {{instance}} {{status}}",
            "refId": "A"
          },
          {
            "expr": "sum(rate(whatsapp_messages_failed_total[1m])) by (instance, reason)",
            "legendFormat": "failed {{instance}} {{reason}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          { "label": "messages/sec", "min": 0 },
          { "label": null }
        ]
      },
      {
        "id": 2,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "type": "graph",
        "title": "Queue Size and DLQ Size",
        "targets": [
          {
            "expr": "whatsapp_queue_size",
            "legendFormat": "queue {{instance}}",
            "refId": "A"
          },
          {
            "expr": "whatsapp_dlq_size",
            "legendFormat": "dlq {{instance}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          { "label": "messages", "min": 0 },
          { "label": null }
        ]
      },
      {
        "id": 3,
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
        "type": "graph",
        "title": "Circuit Breaker State",
        "targets": [
          {
            "expr": "whatsapp_circuit_breaker_state",
            "legendFormat": "{{instance}} {{breaker_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "label": "state (0=closed,1=open,2=half_open)", "min": 0, "max": 2 },
          { "label": null }
        ]
      },
      {
        "id": 4,
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
        "type": "piechart",
        "title": "Webhook Event Types (5m)",
        "targets": [
          {
            "expr": "sum(rate(whatsapp_webhook_events_total[5m])) by (event_type)",
            "legendFormat": "{{event_type}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
        "type": "graph",
        "title": "Message Send Latency P95/P99",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(whatsapp_message_send_duration_seconds_bucket[5m])) by (le, instance))",
            "legendFormat": "p95 {{instance}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(whatsapp_message_send_duration_seconds_bucket[5m])) by (le, instance))",
            "legendFormat": "p99 {{instance}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          { "label": "seconds", "min": 0 },
          { "label": null }
        ]
      }
    ]
  }
}
