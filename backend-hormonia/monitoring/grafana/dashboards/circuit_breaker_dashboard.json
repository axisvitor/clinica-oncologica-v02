{
  "dashboard": {
    "title": "Circuit Breaker Monitoring - HIGH-006",
    "tags": ["circuit-breaker", "resilience", "high-006"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "type": "graph",
        "title": "Circuit Breaker States",
        "targets": [
          {
            "expr": "circuit_breaker_state{service=\"whatsapp_evolution_api\"}",
            "legendFormat": "WhatsApp - {{service}}",
            "refId": "A"
          },
          {
            "expr": "circuit_breaker_state{service=\"firebase_auth\"}",
            "legendFormat": "Firebase - {{service}}",
            "refId": "B"
          },
          {
            "expr": "circuit_breaker_state{service=\"gemini_ai\"}",
            "legendFormat": "Gemini AI - {{service}}",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "label": "State (0=Closed, 1=Open, 2=Half-Open)",
            "min": 0,
            "max": 2
          },
          {
            "label": null
          }
        ],
        "description": "Circuit breaker states over time. 0=CLOSED (normal), 1=OPEN (failing), 2=HALF_OPEN (testing recovery)"
      },
      {
        "id": 2,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "type": "graph",
        "title": "Success vs Failure Rates",
        "targets": [
          {
            "expr": "rate(circuit_breaker_successes_total[5m])",
            "legendFormat": "Success Rate - {{service}}",
            "refId": "A"
          },
          {
            "expr": "rate(circuit_breaker_failures_total[5m])",
            "legendFormat": "Failure Rate - {{service}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "Requests/sec",
            "min": 0
          },
          {
            "label": null
          }
        ],
        "description": "Success and failure rates per service (requests per second)"
      },
      {
        "id": 3,
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
        "type": "stat",
        "title": "WhatsApp Circuit State",
        "targets": [
          {
            "expr": "circuit_breaker_state{service=\"whatsapp_evolution_api\"}",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "background",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": { "text": "CLOSED", "color": "green" },
                  "1": { "text": "OPEN", "color": "red" },
                  "2": { "text": "HALF_OPEN", "color": "yellow" }
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "red" },
                { "value": 2, "color": "yellow" }
              ]
            }
          }
        },
        "description": "Current state of WhatsApp circuit breaker"
      },
      {
        "id": 4,
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
        "type": "stat",
        "title": "Firebase Circuit State",
        "targets": [
          {
            "expr": "circuit_breaker_state{service=\"firebase_auth\"}",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "background",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": { "text": "CLOSED", "color": "green" },
                  "1": { "text": "OPEN", "color": "red" },
                  "2": { "text": "HALF_OPEN", "color": "yellow" }
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "red" },
                { "value": 2, "color": "yellow" }
              ]
            }
          }
        },
        "description": "Current state of Firebase circuit breaker"
      },
      {
        "id": 5,
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
        "type": "stat",
        "title": "Gemini AI Circuit State",
        "targets": [
          {
            "expr": "circuit_breaker_state{service=\"gemini_ai\"}",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "background",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": { "text": "CLOSED", "color": "green" },
                  "1": { "text": "OPEN", "color": "red" },
                  "2": { "text": "HALF_OPEN", "color": "yellow" }
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "red" },
                { "value": 2, "color": "yellow" }
              ]
            }
          }
        },
        "description": "Current state of Gemini AI circuit breaker"
      },
      {
        "id": 6,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "type": "graph",
        "title": "Fallback Activation Rate",
        "targets": [
          {
            "expr": "rate(circuit_breaker_fallback_total[5m])",
            "legendFormat": "Fallback Rate - {{service}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "Fallbacks/sec",
            "min": 0
          },
          {
            "label": null
          }
        ],
        "description": "Rate of fallback mechanism activations (indicates circuit is open)"
      },
      {
        "id": 7,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "type": "graph",
        "title": "Circuit Breaker Call Duration",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(circuit_breaker_call_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 - {{service}} - {{status}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(circuit_breaker_call_duration_seconds_bucket[5m]))",
            "legendFormat": "p99 - {{service}} - {{status}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "Duration (seconds)",
            "min": 0
          },
          {
            "label": null
          }
        ],
        "description": "95th and 99th percentile call duration by service and status"
      },
      {
        "id": 8,
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
        "type": "table",
        "title": "Circuit Breaker Statistics Summary",
        "targets": [
          {
            "expr": "circuit_breaker_successes_total",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "circuit_breaker_failures_total",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "circuit_breaker_fallback_total",
            "format": "table",
            "instant": true,
            "refId": "C"
          },
          {
            "expr": "circuit_breaker_state",
            "format": "table",
            "instant": true,
            "refId": "D"
          }
        ],
        "transformations": [
          {
            "id": "merge",
            "options": {}
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "instance": true,
                "job": true
              },
              "indexByName": {
                "service": 0,
                "Value #A": 1,
                "Value #B": 2,
                "Value #C": 3,
                "Value #D": 4
              },
              "renameByName": {
                "service": "Service",
                "Value #A": "Total Successes",
                "Value #B": "Total Failures",
                "Value #C": "Total Fallbacks",
                "Value #D": "Current State"
              }
            }
          }
        ],
        "description": "Summary table of all circuit breaker metrics"
      },
      {
        "id": 9,
        "gridPos": { "h": 6, "w": 8, "x": 0, "y": 32 },
        "type": "stat",
        "title": "WhatsApp Total Failures",
        "targets": [
          {
            "expr": "circuit_breaker_failures_total{service=\"whatsapp_evolution_api\"}",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 10, "color": "yellow" },
                { "value": 50, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "gridPos": { "h": 6, "w": 8, "x": 8, "y": 32 },
        "type": "stat",
        "title": "Firebase Total Failures",
        "targets": [
          {
            "expr": "circuit_breaker_failures_total{service=\"firebase_auth\"}",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 5, "color": "yellow" },
                { "value": 20, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 11,
        "gridPos": { "h": 6, "w": 8, "x": 16, "y": 32 },
        "type": "stat",
        "title": "Gemini AI Total Failures",
        "targets": [
          {
            "expr": "circuit_breaker_failures_total{service=\"gemini_ai\"}",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 10, "color": "yellow" },
                { "value": 50, "color": "red" }
              ]
            }
          }
        }
      }
    ],
    "annotations": {
      "list": [
        {
          "name": "Circuit Opens",
          "datasource": "Prometheus",
          "expr": "changes(circuit_breaker_state[1m]) > 0 and circuit_breaker_state == 1",
          "iconColor": "red",
          "tagKeys": "service",
          "textFormat": "Circuit OPENED: {{service}}",
          "titleFormat": "Circuit Breaker Alert"
        }
      ]
    },
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    }
  }
}
