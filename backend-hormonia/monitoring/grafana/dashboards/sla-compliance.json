{
  "dashboard": {
    "title": "Clínica Hormonia - SLA Compliance",
    "tags": ["hormonia", "sla", "uptime"],
    "timezone": "browser",
    "refresh": "1m",
    "editable": true,
    "panels": [
      {
        "id": 1,
        "title": "Current SLA Compliance",
        "type": "gauge",
        "targets": [
          {
            "expr": "app_sla_compliance_ratio"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1,
            "min": 0.9,
            "thresholds": {
              "steps": [
                {"value": 0.9, "color": "red"},
                {"value": 0.95, "color": "yellow"},
                {"value": 0.99, "color": "green"}
              ]
            }
          }
        },
        "gridPos": {"h": 10, "w": 8, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "24h Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "avg_over_time(up{job=\"hormonia-app\"}[24h])"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit"
          }
        },
        "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0}
      },
      {
        "id": 3,
        "title": "7d Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "avg_over_time(up{job=\"hormonia-app\"}[7d])"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit"
          }
        },
        "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0}
      },
      {
        "id": 4,
        "title": "30d Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "avg_over_time(up{job=\"hormonia-app\"}[30d])"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit"
          }
        },
        "gridPos": {"h": 5, "w": 8, "x": 8, "y": 5}
      },
      {
        "id": 5,
        "title": "Response Time SLA (95th percentile)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(app_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "yaxes": [
          {"format": "s", "max": 2}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10}
      },
      {
        "id": 6,
        "title": "Error Budget Remaining",
        "type": "graph",
        "targets": [
          {
            "expr": "1 - (sum(rate(app_requests_total{status=~\"5..\"}[24h])) / sum(rate(app_requests_total[24h])))"
          }
        ],
        "yaxes": [
          {"format": "percentunit", "min": 0.95, "max": 1}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10}
      },
      {
        "id": 7,
        "title": "Service Availability Timeline",
        "type": "graph",
        "targets": [
          {
            "expr": "up{job=\"hormonia-app\"}",
            "legendFormat": "{{instance}}"
          }
        ],
        "yaxes": [
          {"max": 1, "min": 0}
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18}
      },
      {
        "id": 8,
        "title": "Database Availability",
        "type": "stat",
        "targets": [
          {
            "expr": "avg_over_time(up{job=\"postgres\"}[24h])"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit"
          }
        },
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 26}
      },
      {
        "id": 9,
        "title": "Redis Availability",
        "type": "stat",
        "targets": [
          {
            "expr": "avg_over_time(up{job=\"redis\"}[24h])"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit"
          }
        },
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 26}
      },
      {
        "id": 10,
        "title": "Celery Workers Availability",
        "type": "stat",
        "targets": [
          {
            "expr": "avg_over_time(up{job=\"celery\"}[24h])"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit"
          }
        },
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 26}
      },
      {
        "id": 11,
        "title": "Overall System Health Score",
        "type": "gauge",
        "targets": [
          {
            "expr": "(avg(up{job=\"hormonia-app\"}) + avg(up{job=\"postgres\"}) + avg(up{job=\"redis\"}) + avg(up{job=\"celery\"})) / 4"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1,
            "min": 0
          }
        },
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 26}
      }
    ]
  }
}
