{
  "dashboard": {
    "id": null,
    "uid": "celery-monitoring",
    "title": "Celery Tasks Monitoring",
    "tags": ["celery", "tasks", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "type": "graph",
        "title": "Task Execution Rate (tasks/min)",
        "targets": [
          {
            "expr": "sum(rate(celery_task_total[5m])) by (task_name)",
            "legendFormat": "{{task_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Tasks/min"},
          {"format": "short"}
        ],
        "xaxis": {"show": true, "mode": "time"},
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "legend": {
          "show": true,
          "values": true,
          "current": true,
          "avg": true
        }
      },
      {
        "id": 2,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "type": "graph",
        "title": "Task Failure Rate (failures/min)",
        "targets": [
          {
            "expr": "sum(rate(celery_task_failures_total[5m])) by (task_name)",
            "legendFormat": "{{task_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Failures/min"},
          {"format": "short"}
        ],
        "xaxis": {"show": true, "mode": "time"},
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [0.1], "type": "gt"},
              "query": {"params": ["A", "5m", "now"]},
              "type": "query"
            }
          ],
          "name": "High Task Failure Rate",
          "message": "Task failure rate exceeds 0.1/min"
        }
      },
      {
        "id": 3,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "type": "graph",
        "title": "Task Duration P95 (seconds)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(celery_task_duration_seconds_bucket[5m])) by (task_name, le))",
            "legendFormat": "{{task_name}} (p95)",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(celery_task_duration_seconds_bucket[5m])) by (task_name, le))",
            "legendFormat": "{{task_name}} (p99)",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ],
        "xaxis": {"show": true, "mode": "time"},
        "lines": true,
        "fill": 0,
        "linewidth": 2
      },
      {
        "id": 4,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "type": "graph",
        "title": "Active Tasks (current)",
        "targets": [
          {
            "expr": "sum(celery_task_active) by (task_name)",
            "legendFormat": "{{task_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Active Tasks"},
          {"format": "short"}
        ],
        "xaxis": {"show": true, "mode": "time"},
        "lines": true,
        "fill": 2,
        "linewidth": 1,
        "stack": true
      },
      {
        "id": 5,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "type": "graph",
        "title": "Queue Length (pending tasks)",
        "targets": [
          {
            "expr": "celery_queue_length",
            "legendFormat": "{{queue_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Queue Length"},
          {"format": "short"}
        ],
        "xaxis": {"show": true, "mode": "time"},
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [1000], "type": "gt"},
              "query": {"params": ["A", "5m", "now"]},
              "type": "query"
            }
          ],
          "name": "Large Queue Backlog",
          "message": "Queue has more than 1000 pending tasks"
        }
      },
      {
        "id": 6,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "type": "graph",
        "title": "Task Retry Rate (retries/min)",
        "targets": [
          {
            "expr": "sum(rate(celery_task_retries_total[5m])) by (task_name)",
            "legendFormat": "{{task_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Retries/min"},
          {"format": "short"}
        ],
        "xaxis": {"show": true, "mode": "time"},
        "lines": true,
        "fill": 1,
        "linewidth": 2
      },
      {
        "id": 7,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "type": "table",
        "title": "Top Failing Tasks (last hour)",
        "targets": [
          {
            "expr": "topk(5, sum by (task_name, exception_type) (rate(celery_task_failures_total[1h])))",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "styles": [
          {
            "pattern": "task_name",
            "type": "string",
            "alias": "Task"
          },
          {
            "pattern": "exception_type",
            "type": "string",
            "alias": "Exception"
          },
          {
            "pattern": "Value",
            "type": "number",
            "alias": "Failures/min",
            "decimals": 3
          }
        ],
        "transform": "table"
      },
      {
        "id": 8,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "type": "table",
        "title": "Slowest Tasks P99 (last hour)",
        "targets": [
          {
            "expr": "topk(5, histogram_quantile(0.99, sum by (task_name, le) (rate(celery_task_duration_seconds_bucket[1h]))))",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "styles": [
          {
            "pattern": "task_name",
            "type": "string",
            "alias": "Task"
          },
          {
            "pattern": "Value",
            "type": "number",
            "alias": "P99 Duration (s)",
            "decimals": 2,
            "unit": "s"
          }
        ],
        "transform": "table"
      },
      {
        "id": 9,
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 32},
        "type": "singlestat",
        "title": "Total Tasks (24h)",
        "targets": [
          {
            "expr": "sum(increase(celery_task_total[24h]))",
            "refId": "A"
          }
        ],
        "format": "short",
        "sparkline": {"show": true, "full": false}
      },
      {
        "id": 10,
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 32},
        "type": "singlestat",
        "title": "Success Rate (24h)",
        "targets": [
          {
            "expr": "sum(increase(celery_task_total{status=\"success\"}[24h])) / sum(increase(celery_task_total[24h])) * 100",
            "refId": "A"
          }
        ],
        "format": "percent",
        "thresholds": "80,95",
        "colors": ["#d44a3a", "#e0b400", "#299c46"]
      },
      {
        "id": 11,
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 32},
        "type": "singlestat",
        "title": "Active Workers",
        "targets": [
          {
            "expr": "sum(celery_worker_active)",
            "refId": "A"
          }
        ],
        "format": "short",
        "thresholds": "1,3",
        "colors": ["#d44a3a", "#e0b400", "#299c46"]
      },
      {
        "id": 12,
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 32},
        "type": "singlestat",
        "title": "Avg Task Duration (1h)",
        "targets": [
          {
            "expr": "sum(rate(celery_task_duration_seconds_sum[1h])) / sum(rate(celery_task_duration_seconds_count[1h]))",
            "refId": "A"
          }
        ],
        "format": "s",
        "sparkline": {"show": true}
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    }
  }
}
