{
  "dashboard": {
    "title": "Clínica Hormonia - Business KPIs",
    "tags": ["hormonia", "business", "metrics"],
    "timezone": "browser",
    "refresh": "5m",
    "editable": true,
    "panels": [
      {
        "id": 1,
        "title": "Revenue (Last 30 Days)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(app_revenue_total[30d]))",
            "legendFormat": "Total Revenue"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Revenue by Tier",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum(increase(app_revenue_total[30d])) by (tier)",
            "legendFormat": "{{tier}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0}
      },
      {
        "id": 3,
        "title": "Active Users Trend",
        "type": "graph",
        "targets": [
          {
            "expr": "app_active_users_total"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}
      },
      {
        "id": 4,
        "title": "Patient Onboarding Success Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "sum(rate(app_patient_onboarding_total{status=\"success\"}[24h])) / sum(rate(app_patient_onboarding_total[24h]))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1,
            "min": 0
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8}
      },
      {
        "id": 5,
        "title": "Quiz Completion Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "app_quiz_completion_rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1,
            "min": 0,
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 0.6, "color": "yellow"},
                {"value": 0.8, "color": "green"}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8}
      },
      {
        "id": 6,
        "title": "Quota Usage by Tier",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(app_quota_usage_bytes) by (tier)",
            "legendFormat": "{{tier}}"
          }
        ],
        "yaxes": [
          {"format": "bytes"}
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8}
      },
      {
        "id": 7,
        "title": "Notifications Sent",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(app_notifications_sent_total[1h])) by (channel)",
            "legendFormat": "{{channel}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 8,
        "title": "WhatsApp Messages",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(app_whatsapp_messages_total[1h])) by (status)",
            "legendFormat": "{{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 9,
        "title": "User Tier Distribution",
        "type": "piechart",
        "targets": [
          {
            "expr": "count(app_quota_usage_bytes) by (tier)",
            "legendFormat": "{{tier}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24}
      },
      {
        "id": 10,
        "title": "Upload Volume",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(app_upload_bytes_total[1h])) by (user_tier)",
            "legendFormat": "{{user_tier}}"
          }
        ],
        "yaxes": [
          {"format": "Bps"}
        ],
        "gridPos": {"h": 8, "w": 16, "x": 8, "y": 24}
      }
    ]
  }
}
