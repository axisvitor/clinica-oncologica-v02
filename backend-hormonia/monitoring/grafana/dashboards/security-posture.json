{
  "dashboard": {
    "title": "Clínica Hormonia - Security Posture",
    "tags": ["hormonia", "security", "compliance"],
    "timezone": "browser",
    "refresh": "1m",
    "editable": true,
    "panels": [
      {
        "id": 1,
        "title": "Security Scans (Last 24h)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(app_security_scan_total[24h]))",
            "legendFormat": "Total Scans"
          }
        ],
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Viruses Detected (Last 24h)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(app_virus_detected_total[24h]))"
          }
        ],
        "thresholds": [
          {"value": 0, "color": "green"},
          {"value": 1, "color": "red"}
        ],
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "MIME Validation Failures",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(app_mime_validation_failures_total[5m])"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Blocked File Extensions",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(app_blocked_extensions_total[5m])) by (extension)",
            "legendFormat": "{{extension}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 5,
        "title": "Security Scan Results",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum(increase(app_security_scan_total[24h])) by (result)",
            "legendFormat": "{{result}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 6,
        "title": "Rate Limit Violations",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(app_api_rate_limit_hits_total[5m])) by (endpoint)",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 7,
        "title": "Patient Risk Alerts",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(app_patient_risk_alerts_total[5m])) by (risk_level)",
            "legendFormat": "{{risk_level}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 8,
        "title": "Security Timeline",
        "type": "table",
        "targets": [
          {
            "expr": "changes(app_virus_detected_total[24h])"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24}
      }
    ]
  }
}
