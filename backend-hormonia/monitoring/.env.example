# =============================================================================
# MONITORING STACK CONFIGURATION
# =============================================================================
# ENV Variable Naming Convention: {CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
# =============================================================================

# ============================================================================
# REDIS CONFIGURATION - REDIS_*
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# GRAFANA CONFIGURATION - GRAFANA_*
# ============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_in_production

# ============================================================================
# PROMETHEUS CONFIGURATION - PROMETHEUS_*
# ============================================================================
PROMETHEUS_RETENTION_DAYS=30

# ============================================================================
# ALERTMANAGER CONFIGURATION - ALERT_*
# ============================================================================
ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ALERT_PAGERDUTY_SERVICE_KEY=YOUR_PAGERDUTY_SERVICE_KEY

# ============================================================================
# EMAIL CONFIGURATION - SMTP_*
# ============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alertmanager@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_ADDRESS=alertmanager@hormonia.com
ALERT_EMAIL_TO=devops@example.com

# ============================================================================
# EXTERNAL URLS - *_URL
# ============================================================================
GRAFANA_EXTERNAL_URL=https://grafana.hormonia.com
RUNBOOK_EXTERNAL_URL=https://docs.hormonia.com/runbooks
