# Monitoring Stack Configuration

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_in_production

# Prometheus Configuration
PROMETHEUS_RETENTION_DAYS=30

# Alertmanager Configuration (fill these in!)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
PAGERDUTY_SERVICE_KEY=YOUR_PAGERDUTY_SERVICE_KEY

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alertmanager@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=alertmanager@hormonia.com
ALERT_EMAIL_TO=devops@example.com

# External URLs (for annotations)
GRAFANA_URL=https://grafana.hormonia.com
RUNBOOK_URL=https://docs.hormonia.com/runbooks
