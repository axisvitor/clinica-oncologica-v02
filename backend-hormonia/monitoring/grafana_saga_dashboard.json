{
  "dashboard": {
    "title": "Saga Orchestration & RBAC Monitoring",
    "tags": ["saga", "rbac", "production", "hormonia"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Saga Success Rate",
        "type": "gauge",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "saga_success_rate",
            "legendFormat": "Success Rate"
          }
        ],
        "options": {
          "orientation": "auto",
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "red"
                },
                {
                  "value": 0.90,
                  "color": "yellow"
                },
                {
                  "value": 0.95,
                  "color": "green"
                }
              ]
            },
            "unit": "percentunit",
            "decimals": 2
          }
        }
      },
      {
        "id": 2,
        "title": "Saga Execution Time",
        "type": "graph",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(saga_execution_time_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(saga_execution_time_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(saga_execution_time_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "label": "Time",
            "show": true
          }
        ],
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "tooltip": {
          "shared": true
        }
      },
      {
        "id": 3,
        "title": "Compensation Rate",
        "type": "gauge",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "saga_compensation_rate",
            "legendFormat": "Compensation Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 0.20,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 0.05,
                  "color": "yellow"
                },
                {
                  "value": 0.10,
                  "color": "red"
                }
              ]
            },
            "unit": "percentunit",
            "decimals": 3
          }
        }
      },
      {
        "id": 4,
        "title": "Duplicate Patient Attempts (Blocked)",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 8,
          "h": 4
        },
        "targets": [
          {
            "expr": "sum(rate(duplicate_patient_attempts[5m])) * 300",
            "legendFormat": "Blocks per 5min"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 5,
                  "color": "yellow"
                },
                {
                  "value": 10,
                  "color": "red"
                }
              ]
            },
            "unit": "short",
            "decimals": 0
          }
        }
      },
      {
        "id": 5,
        "title": "RBAC Authorization Failures",
        "type": "table",
        "gridPos": {
          "x": 8,
          "y": 8,
          "w": 16,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(rbac_authorization_failures[5m])) by (endpoint, role)",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true
              },
              "indexByName": {
                "endpoint": 0,
                "role": 1,
                "Value": 2
              },
              "renameByName": {
                "endpoint": "Endpoint",
                "role": "Role",
                "Value": "Failures/5min"
              }
            }
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "displayName": "Failures/5min",
              "desc": true
            }
          ]
        }
      },
      {
        "id": 6,
        "title": "Stuck Sagas",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 12,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "stuck_sagas_count",
            "legendFormat": "Stuck Sagas"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 1,
                  "color": "red"
                }
              ]
            },
            "unit": "short",
            "decimals": 0
          }
        }
      },
      {
        "id": 7,
        "title": "Saga Retries",
        "type": "graph",
        "gridPos": {
          "x": 6,
          "y": 12,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(saga_retry_count[5m])) by (saga_type)",
            "legendFormat": "{{saga_type}}"
          }
        ],
        "yaxes": [
          {
            "format": "short",
            "label": "Retries/sec",
            "show": true
          }
        ],
        "lines": true,
        "fill": 1,
        "stack": true
      },
      {
        "id": 8,
        "title": "Database Connection Pool Usage",
        "type": "gauge",
        "gridPos": {
          "x": 18,
          "y": 12,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "database_connection_pool_usage",
            "legendFormat": "Pool Usage"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 70,
                  "color": "yellow"
                },
                {
                  "value": 90,
                  "color": "red"
                }
              ]
            },
            "unit": "percent",
            "decimals": 1
          }
        }
      },
      {
        "id": 9,
        "title": "Patient Creation Requests",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 20,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(patient_creation_requests{status=\"success\"}[5m]))",
            "legendFormat": "Successful"
          },
          {
            "expr": "sum(rate(patient_creation_requests{status=\"failed\"}[5m]))",
            "legendFormat": "Failed"
          }
        ],
        "yaxes": [
          {
            "format": "short",
            "label": "Requests/sec",
            "show": true
          }
        ],
        "lines": true,
        "fill": 1
      },
      {
        "id": 10,
        "title": "RBAC Authorization Latency",
        "type": "graph",
        "gridPos": {
          "x": 12,
          "y": 20,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(rbac_authorization_latency_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(rbac_authorization_latency_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(rbac_authorization_latency_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "label": "Latency",
            "show": true
          }
        ],
        "lines": true,
        "fill": 1
      },
      {
        "id": 11,
        "title": "Constraint Violations by Type",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 28,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(constraint_violation_errors[5m])) by (constraint_name)",
            "legendFormat": "{{constraint_name}}"
          }
        ],
        "yaxes": [
          {
            "format": "short",
            "label": "Violations/sec",
            "show": true
          }
        ],
        "lines": true,
        "fill": 1,
        "stack": true
      },
      {
        "id": 12,
        "title": "System Health Overview",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 28,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "saga_orchestrator_health",
            "legendFormat": "Saga Orchestrator"
          },
          {
            "expr": "unique_constraint_effectiveness",
            "legendFormat": "Constraint Effectiveness"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "red"
                },
                {
                  "value": 0.9,
                  "color": "yellow"
                },
                {
                  "value": 1,
                  "color": "green"
                }
              ]
            },
            "unit": "percentunit",
            "decimals": 2
          }
        },
        "options": {
          "orientation": "horizontal",
          "textMode": "value_and_name"
        }
      }
    ],
    "annotations": {
      "list": [
        {
          "datasource": "Prometheus",
          "enable": true,
          "name": "Deployments",
          "iconColor": "blue",
          "tags": ["deployment"]
        },
        {
          "datasource": "Prometheus",
          "enable": true,
          "name": "Alerts",
          "iconColor": "red",
          "tags": ["alert"]
        }
      ]
    },
    "templating": {
      "list": [
        {
          "name": "saga_type",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(saga_execution_time, saga_type)",
          "multi": true,
          "includeAll": true
        }
      ]
    }
  }
}
