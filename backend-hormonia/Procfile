# Railway Procfile for Neoplasias Litoral Backend Production Deployment
# Optimized for Railway's infrastructure and scaling capabilities

# Primary web process - FastAPI with Gunicorn + Uvicorn workers
web: gunicorn app.main:app -w $WEB_CONCURRENCY -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT --access-logfile - --error-logfile - --log-level info --timeout 120 --keep-alive 2 --max-requests 1000 --max-requests-jitter 50 --preload --worker-tmp-dir /dev/shm

# Database migration process (run manually via Railway CLI)
release: python -m alembic upgrade head

# Background worker for async tasks - Celery worker for quiz reminders and flows
worker: celery -A app.celery_app worker --loglevel=info --concurrency=4 --max-tasks-per-child=1000 --queues=celery,flows,quiz,maintenance,monitoring

# Scheduler for periodic tasks - Celery beat for scheduled quiz checks and maintenance
beat: celery -A app.celery_app beat --loglevel=info

# Health monitoring process (optional - for advanced monitoring)
# monitor: python -m app.monitoring.health_monitor