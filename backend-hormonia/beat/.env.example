# ===================================
# BACKEND BEAT - ENV TEMPLATE
# ===================================
# Copy to .env and fill with your values. Do NOT commit secrets.

# Core (same as backend-web)
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
PASSLIB_BUILTIN_BCRYPT=enabled
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Database / Cache
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
REDIS_URL=rediss://default:REDIS_PASSWORD@HOST:PORT/0

# Auth/Providers
SECRET_KEY=CHANGE_THIS
JWT_SECRET_KEY=CHANGE_THIS
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon
SUPABASE_SERVICE_ROLE_KEY=your_service_role
FIREBASE_ADMIN_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=service@project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# Celery beat (matches Dockerfile.beat)
CELERY_BEAT_SCHEDULER=celery.beat.PersistentScheduler
CELERY_BEAT_MAX_INTERVAL=300
