[pytest]
# Pytest configuration for Backend tests

# Test discovery patterns
python_files = test_*.py *_test.py
python_classes = Test*
python_functions = test_*

# Test paths
testpaths = tests

# Minimum Python version
minversion = 7.0

# Add current directory to Python path
pythonpath = .

# Output options
addopts =
    -v
    --strict-markers
    --tb=short
    --disable-warnings
    --color=yes
    --code-highlight=yes

# Markers for test organization
markers =
    asyncio: mark test as async (deselect with '-m "not asyncio"')
    redis: mark test as requiring Redis connection
    integration: mark test as integration test (requires external services)
    unit: mark test as unit test (no external dependencies)
    slow: mark test as slow running
    security: mark test as security-related
    performance: mark test as performance-related

# Async test configuration
asyncio_mode = auto

# Coverage options (when using --cov)
# Run with: pytest --cov=app --cov-report=html
[coverage:run]
source = app
omit =
    */tests/*
    */venv/*
    */__pycache__/*
    */migrations/*

[coverage:report]
precision = 2
show_missing = True
skip_covered = False

[coverage:html]
directory = htmlcov