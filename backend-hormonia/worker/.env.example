# =============================================================================
# BACKEND WORKER - CELERY WORKER ENVIRONMENT TEMPLATE
# =============================================================================
# ENV Variable Naming Convention: {CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
# Copy to .env and fill with your values. Do NOT commit secrets.
# =============================================================================

# ============================================================================
# APPLICATION CONFIGURATION - APP_*
# ============================================================================
APP_ENVIRONMENT=production
APP_ENABLE_DEBUG=false
APP_NAME=NeoplasiaLitoral-Backend
APP_VERSION=2.0.0
SERVICE_TYPE=worker

# ============================================================================
# LOGGING CONFIGURATION - LOGGING_*
# ============================================================================
LOGGING_LEVEL=INFO

# ============================================================================
# PYTHON RUNTIME
# ============================================================================
PASSLIB_BUILTIN_BCRYPT=enabled
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# ============================================================================
# DATABASE CONFIGURATION - DATABASE_*
# ============================================================================
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# ============================================================================
# REDIS CONFIGURATION - REDIS_*
# ============================================================================
# IMPORTANT: Memorystore uses redis:// over private VPC (no TLS/auth)
REDIS_URL=redis://10.109.61.19:6379/0
REDIS_PASSWORD=
REDIS_HOST=10.109.61.19
REDIS_PORT=6379
REDIS_ENABLE_SSL=false
# SECURITY: Use "required" only if TLS is enabled for Redis
REDIS_SSL_CERT_REQS=none

# ============================================================================
# SECURITY CONFIGURATION - SECURITY_*
# ============================================================================
SECURITY_SECRET_KEY=CHANGE_THIS
SECURITY_CSRF_SECRET_KEY=CHANGE_THIS
ENCRYPTION_KEY_CURRENT=CHANGE_THIS
HASH_SALT=CHANGE_THIS
PHI_ENCRYPTION_KEY=CHANGE_THIS

# ============================================================================
# FIREBASE CONFIGURATION - FIREBASE_ADMIN_*
# ============================================================================
FIREBASE_ADMIN_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=service@project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ============================================================================
# WHATSAPP / EVOLUTION API - WHATSAPP_*
# ============================================================================
WHATSAPP_ENABLE_SERVICE=true
WHATSAPP_EVOLUTION_USE_MOCK=false
WHATSAPP_EVOLUTION_API_URL=http://localhost:8080
WHATSAPP_EVOLUTION_INSTANCE_NAME=clinica_oncologica
WHATSAPP_EVOLUTION_API_KEY=CHANGE_THIS
WHATSAPP_EVOLUTION_WEBHOOK_SECRET=CHANGE_THIS
WHATSAPP_CLINIC_NAME=Neoplasias Litoral
WHATSAPP_CLINIC_SUPPORT_PHONE=+55REPLACE_WITH_SUPPORT

# ============================================================================
# AI CONFIGURATION - AI_GEMINI_*
# ============================================================================
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-3-flash-preview
AI_GEMINI_TEMPERATURE=0.7
AI_GEMINI_MAX_OUTPUT_TOKENS=500
AI_GEMINI_TOP_P=0.8
AI_GEMINI_TOP_K=40
AI_GEMINI_TIMEOUT_SECONDS=30
AI_GEMINI_MAX_RETRIES=3

# ============================================================================
# MONTHLY QUIZ - QUIZ_*
# ============================================================================
QUIZ_ENABLE_VIA_LINK=true
QUIZ_BASE_URL=http://localhost:3001
QUIZ_SHORT_BASE_URL=http://localhost:8000/q
QUIZ_TOKEN_SECRET=CHANGE_THIS
QUIZ_TOKEN_EXPIRY_HOURS=72

# ============================================================================
# NOTIFICATIONS - EMAIL (SMTP)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@clinica-oncologica.com
SMTP_ENABLE_TLS=true

# ============================================================================
# CELERY CONFIGURATION - CELERY_*
# ============================================================================
CELERY_BROKER_URL=redis://10.109.61.19:6379/0
CELERY_RESULT_BACKEND=redis://10.109.61.19:6379/1

# ============================================================================
# CELERY WORKER CONFIGURATION - CELERY_WORKER_*
# ============================================================================
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_TIME_LIMIT_SECONDS=300
CELERY_WORKER_SOFT_TIME_LIMIT_SECONDS=240
CELERY_QUEUES=celery,flows,quiz,maintenance,monitoring
