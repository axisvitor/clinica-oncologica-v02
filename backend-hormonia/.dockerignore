# =============================================================================
# DOCKERIGNORE - Railway/Docker Build Optimization
# =============================================================================

# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Build artifacts
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments (CRITICAL - exclude to reduce image size)
venv/
venv_linux/
env/
ENV/
.venv/

# Testing (exclude from production build)
.pytest_cache/
.coverage
htmlcov/
coverage_html/
test-results/
.tox/
tests/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# Logs (exclude all logs from build)
*.log
logs/
server_*.log

# Environment files (SECURITY - never include in image)
.env
.env.local
.env.development
.env.production
.env.railway
# Keep templates for reference
!.env.example
!.env.production.template
!.env.railway.template
!.env.quiz.example
!.env.sentry.example
!.env.pool.example

# Local database files
*.db
*.sqlite
*.sqlite3

# Alembic cache
alembic/versions/__pycache__/

# Documentation (keep README for image)
docs/
*.md
!README.md

# Git (exclude git history from build)
.git/
.gitignore
.gitattributes

# OS files
.DS_Store
Thumbs.db
*.bak

# Docker compose (not needed in image, Railway uses railway.toml)
docker-compose*.yml
docker-compose*.yaml

# NOTE: DO NOT exclude Dockerfile* - Railway needs them!
# The .dockerignore is processed BEFORE the Dockerfile is read

# Celery PID/schedule files (runtime generated)
celerybeat-schedule
celerybeat.pid
*.pid

# Backup files
*.backup
*.bak

# Archives (large files)
*.tar
*.tar.gz
*.zip
*.rar

# Certificates (keep redis_ca.pem for SSL)
certs/*.key
certs/*.crt
!certs/redis_ca.pem
!certs/.gitkeep

# Claude Flow / Swarm metadata (development only)
.claude-flow/
.hive-mind/
.swarm/

# MyPy cache
.mypy_cache/

# Uploads directory (runtime data, not build-time)
uploads/

# Temporary files
*.tmp
*.temp
cookies.txt
error_output.txt
backend_error.txt
debug_auth.log

# Node modules in scripts (if any)
scripts/node_modules/

# Local development folders
worker/
beat/

# Locust load testing
locust/

# Flower (Celery monitoring) configs
flower/

# Operations scripts (not needed in image)
ops/

# Seeds (development data)
seeds/

# SQL scripts (migrations are in alembic)
sql/

# Monitoring configs (external)
monitoring/
