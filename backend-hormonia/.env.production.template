# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env for production deployment
# See docs/DEPLOYMENT_CONFIGURATION.md for complete guide
# ============================================================================

# ============================================================================
# ENVIRONMENT SETTINGS
# ============================================================================
ENVIRONMENT=production
DEBUG=false

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# CRITICAL: Generate secure secrets for production
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE_32_CHARS_MIN
JWT_SECRET_KEY=CHANGE_THIS_TO_A_DIFFERENT_SECURE_VALUE
ENCRYPTION_KEY=CHANGE_THIS_TO_ANOTHER_SECURE_VALUE
CSRF_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_CSRF_SECRET

# Security settings for production
SESSION_COOKIE_SECURE=true
SECURE_SSL_REDIRECT=true
BCRYPT_ROUNDS=14

# ============================================================================
# DATABASE CONFIGURATION (Production PostgreSQL)
# ============================================================================
# CRITICAL: Use SSL connection for production
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DB_POOL_SIZE=30
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================================
# REDIS CONFIGURATION (Production)
# ============================================================================
# CRITICAL: Use SSL/TLS for production Redis
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
REDIS_SSL=true
REDIS_SSL_CERT_REQS=required
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=10.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# Database isolation for production
REDIS_ENABLE_DB_ISOLATION=true
REDIS_CACHE_DB=1
REDIS_BROKER_DB=0
REDIS_SESSION_DB=2
REDIS_RATE_LIMIT_DB=3

# ============================================================================
# CORS CONFIGURATION (Production)
# ============================================================================
# CRITICAL: Set actual production URLs
FRONTEND_URL=https://your-frontend-domain.com
QUIZ_URL=https://your-quiz-domain.com
# Optional: Override with specific origins
# ALLOWED_ORIGINS=https://frontend.com,https://quiz.com

# ============================================================================
# LOGGING CONFIGURATION (Production Optimized)
# ============================================================================
# Optimized for production performance and log volume
LOG_LEVEL=INFO
MAX_LOGS_PER_SECOND=100
ENABLE_REQUEST_LOGGING=false
LOG_STACK_TRACES=false
LOG_DEDUPLICATION_WINDOW=300

# ============================================================================
# ERROR TRACKING CONFIGURATION (Production Monitoring)
# ============================================================================
# Enhanced error tracking for production monitoring
ENABLE_ERROR_TRACKING=true
MAX_ERROR_LOGS=1000
ERROR_DEDUPLICATION_WINDOW=3600
ERROR_TRACKING_RATE_LIMIT=10
CRITICAL_ERROR_NOTIFICATION=true

# ============================================================================
# CELERY CONFIGURATION (Production)
# ============================================================================
CELERY_BROKER_URL=rediss://default:PASSWORD@HOST:PORT/0
CELERY_RESULT_BACKEND=rediss://default:PASSWORD@HOST:PORT/0
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_TIME_LIMIT=300
CELERY_WORKER_SOFT_TIME_LIMIT=240

# ============================================================================
# EVOLUTION API CONFIGURATION (WhatsApp)
# ============================================================================
ENABLE_EVOLUTION=true
EVOLUTION_API_URL=https://your-evolution-api-url.com
EVOLUTION_INSTANCE_NAME=production_instance
EVOLUTION_API_KEY=your-production-evolution-api-key
EVOLUTION_WEBHOOK_SECRET=your-webhook-secret
EVOLUTION_WEBHOOK_URL=https://your-backend-url.com/api/v1/webhooks/evolution

# ============================================================================
# AI SERVICES CONFIGURATION
# ============================================================================
# Google Gemini AI
GEMINI_API_KEY=your-production-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=500
GEMINI_TIMEOUT=30
GEMINI_MAX_RETRIES=3

# LangChain (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langchain-api-key

# ============================================================================
# FIREBASE CONFIGURATION (if using Firebase Auth)
# ============================================================================
FIREBASE_ADMIN_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_PRIVATE_KEY=your-firebase-private-key
FIREBASE_ADMIN_CLIENT_EMAIL=your-firebase-client-email

# Firebase security settings
FIREBASE_ALLOWED_DOMAINS=["yourdomain.com"]
FIREBASE_REQUIRE_CUSTOM_CLAIMS=true
FIREBASE_ALLOWED_ROLES=["admin","doctor","medico"]
FIREBASE_ENABLE_AUDIT_LOGGING=true
FIREBASE_BLOCK_PUBLIC_DOMAINS=true

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================
MONITORING_ENABLED=true
MONITORING_DEBUG=false
MONITORING_REDIS_HOST=your-redis-host
MONITORING_REDIS_PORT=6379
MONITORING_REDIS_DB=1
MONITORING_REDIS_PASSWORD=your-redis-password

# APM Configuration
APM_APDEX_THRESHOLD=0.5
APM_SLOW_REQUEST_THRESHOLD=1.0
DB_SLOW_QUERY_THRESHOLD=1.0

# Resource monitoring
RESOURCE_SAMPLE_INTERVAL=10.0
RESOURCE_CPU_THRESHOLD=80.0
RESOURCE_MEMORY_THRESHOLD=85.0

# ============================================================================
# MONTHLY QUIZ CONFIGURATION
# ============================================================================
MONTHLY_QUIZ_VIA_LINK=true
MONTHLY_QUIZ_BASE_URL=https://your-quiz-domain.com
MONTHLY_QUIZ_TOKEN_SECRET=your-quiz-token-secret-different-from-main-secret
MONTHLY_QUIZ_TOKEN_EXPIRY_HOURS=72

# ============================================================================
# AI HUMANIZATION CONFIGURATION
# ============================================================================
AI_HUMANIZATION_ENABLED=true
AI_HUMANIZATION_SAFETY_MODE=true
AI_HUMANIZATION_MAX_RETRIES=2
AI_HUMANIZATION_TIMEOUT=10.0
AI_HUMANIZATION_FALLBACK_ENABLED=true

# ============================================================================
# WHATSAPP INTEGRATION CONFIGURATION
# ============================================================================
ENABLE_WHATSAPP_ON_REGISTRATION=true
WHATSAPP_WELCOME_MESSAGE_ENABLED=true
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_SECONDS=60
CLINIC_NAME=Your Clinic Name
CLINIC_SUPPORT_PHONE=+1234567890

# ============================================================================
# FILE STORAGE CONFIGURATION
# ============================================================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# ============================================================================
# LOCALIZATION CONFIGURATION
# ============================================================================
DEFAULT_LOCALE=pt-BR
SUPPORTED_LOCALES=["en","pt-BR","es"]

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=rediss://default:PASSWORD@HOST:PORT/3

# ============================================================================
# DEPLOYMENT VALIDATION
# ============================================================================
# Run these commands after deployment:
# python scripts/deployment_validation.py --base-url https://your-api-url.com
# python scripts/validate_deployment_health.py --base-url https://your-api-url.com
# python scripts/validate_critical_fixes.py --base-url https://your-api-url.com