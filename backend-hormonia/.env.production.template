# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# ENV Variable Naming Convention: {CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
# Copy this file to .env for production deployment
# See docs/DEPLOYMENT_CONFIGURATION.md for complete guide
# ============================================================================

# ============================================================================
# APPLICATION CONFIGURATION - APP_*
# ============================================================================
APP_ENVIRONMENT=production
APP_ENABLE_DEBUG=false

# ============================================================================
# SECURITY CONFIGURATION - SECURITY_*, AUTH_*
# ============================================================================
# CRITICAL: Generate secure secrets for production
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECURITY_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE_32_CHARS_MIN
AUTH_JWT_SECRET_KEY=CHANGE_THIS_TO_A_DIFFERENT_SECURE_VALUE
SECURITY_ENCRYPTION_KEY=CHANGE_THIS_TO_ANOTHER_SECURE_VALUE
SECURITY_CSRF_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_CSRF_SECRET

# Security settings for production
AUTH_SESSION_COOKIE_SECURE=true
SECURITY_ENABLE_SSL_REDIRECT=true
SECURITY_BCRYPT_ROUNDS=14

# ============================================================================
# DATABASE CONFIGURATION - DATABASE_*
# ============================================================================
# CRITICAL: Use SSL connection for production
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=3600

# ============================================================================
# REDIS CONFIGURATION - REDIS_*
# ============================================================================
# CRITICAL: Use SSL/TLS for production Redis
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
REDIS_ENABLE_SSL=true
REDIS_SSL_CERT_REQS=required
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT_SECONDS=10.0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5.0
REDIS_ENABLE_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

# Database isolation for production
REDIS_ENABLE_DB_ISOLATION=true
REDIS_CACHE_DB=1
REDIS_BROKER_DB=0
REDIS_SESSION_DB=2
REDIS_RATE_LIMIT_DB=3

# ============================================================================
# CORS CONFIGURATION - CORS_*
# ============================================================================
# CRITICAL: Set actual production URLs
CORS_FRONTEND_URL=https://your-frontend-domain.com
CORS_QUIZ_URL=https://your-quiz-domain.com
# Optional: Override with specific origins
# CORS_ALLOWED_ORIGINS=https://frontend.com,https://quiz.com

# ============================================================================
# LOGGING CONFIGURATION - LOGGING_*
# ============================================================================
# Optimized for production performance and log volume
LOGGING_LEVEL=INFO
LOGGING_MAX_LOGS_PER_SECOND=100
LOGGING_ENABLE_REQUEST_LOGGING=false
LOGGING_ENABLE_STACK_TRACES=false
LOGGING_DEDUPLICATION_WINDOW_SECONDS=300

# ============================================================================
# ERROR TRACKING CONFIGURATION - ERROR_*
# ============================================================================
# Enhanced error tracking for production monitoring
ERROR_ENABLE_TRACKING=true
ERROR_MAX_LOGS=1000
ERROR_DEDUPLICATION_WINDOW_SECONDS=3600
ERROR_TRACKING_RATE_LIMIT=10
ERROR_ENABLE_CRITICAL_NOTIFICATION=true

# ============================================================================
# CELERY CONFIGURATION - CELERY_*
# ============================================================================
CELERY_BROKER_URL=rediss://default:PASSWORD@HOST:PORT/0
CELERY_RESULT_BACKEND=rediss://default:PASSWORD@HOST:PORT/0
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_TIME_LIMIT_SECONDS=300
CELERY_WORKER_SOFT_TIME_LIMIT_SECONDS=240

# ============================================================================
# EVOLUTION API CONFIGURATION - EVOLUTION_*
# ============================================================================
EVOLUTION_ENABLE=true
EVOLUTION_API_URL=https://your-evolution-api-url.com
EVOLUTION_INSTANCE_NAME=production_instance
EVOLUTION_API_KEY=your-production-evolution-api-key
EVOLUTION_WEBHOOK_SECRET=your-webhook-secret
EVOLUTION_WEBHOOK_URL=https://your-backend-url.com/api/v2/webhooks/evolution

# ============================================================================
# AI SERVICES CONFIGURATION - AI_GEMINI_*, AI_LANGCHAIN_*
# ============================================================================
# Google Gemini AI
AI_GEMINI_API_KEY=your-production-gemini-api-key
AI_GEMINI_MODEL=gemini-2.0-flash-exp
AI_GEMINI_TEMPERATURE=0.7
AI_GEMINI_MAX_OUTPUT_TOKENS=500
AI_GEMINI_TIMEOUT_SECONDS=30
AI_GEMINI_MAX_RETRIES=3

# LangChain (optional)
AI_LANGCHAIN_ENABLE_TRACING=false
AI_LANGCHAIN_API_KEY=your-langchain-api-key

# ============================================================================
# FIREBASE CONFIGURATION - FIREBASE_ADMIN_*
# ============================================================================
FIREBASE_ADMIN_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_PRIVATE_KEY=your-firebase-private-key
FIREBASE_ADMIN_CLIENT_EMAIL=your-firebase-client-email

# Firebase security settings
FIREBASE_ALLOWED_DOMAINS=["yourdomain.com"]
FIREBASE_ENABLE_REQUIRE_CUSTOM_CLAIMS=true
FIREBASE_ALLOWED_ROLES=["admin","doctor","medico"]
FIREBASE_ENABLE_AUDIT_LOGGING=true
FIREBASE_ENABLE_BLOCK_PUBLIC_DOMAINS=true

# ============================================================================
# MONITORING CONFIGURATION - MONITORING_*
# ============================================================================
MONITORING_ENABLE=true
MONITORING_ENABLE_DEBUG=false
MONITORING_REDIS_HOST=your-redis-host
MONITORING_REDIS_PORT=6379
MONITORING_REDIS_DB=1
MONITORING_REDIS_PASSWORD=your-redis-password

# APM Configuration
MONITORING_APM_APDEX_THRESHOLD=0.5
MONITORING_APM_SLOW_REQUEST_THRESHOLD_SECONDS=1.0
MONITORING_DB_SLOW_QUERY_THRESHOLD_SECONDS=1.0

# Resource monitoring
MONITORING_RESOURCE_SAMPLE_INTERVAL_SECONDS=10.0
MONITORING_RESOURCE_CPU_THRESHOLD_PERCENT=80.0
MONITORING_RESOURCE_MEMORY_THRESHOLD_PERCENT=85.0

# ============================================================================
# MONTHLY QUIZ CONFIGURATION - QUIZ_*
# ============================================================================
QUIZ_ENABLE_VIA_LINK=true
QUIZ_BASE_URL=https://your-quiz-domain.com
QUIZ_TOKEN_SECRET=your-quiz-token-secret-different-from-main-secret
QUIZ_TOKEN_EXPIRY_HOURS=72

# ============================================================================
# AI HUMANIZATION CONFIGURATION - AI_HUMANIZATION_*
# ============================================================================
AI_HUMANIZATION_ENABLE=true
AI_HUMANIZATION_ENABLE_SAFETY_MODE=true
AI_HUMANIZATION_MAX_RETRIES=2
AI_HUMANIZATION_TIMEOUT_SECONDS=10.0
AI_HUMANIZATION_ENABLE_FALLBACK=true

# ============================================================================
# WHATSAPP INTEGRATION CONFIGURATION - WHATSAPP_*, CLINIC_*
# ============================================================================
WHATSAPP_ENABLE_ON_REGISTRATION=true
WHATSAPP_ENABLE_WELCOME_MESSAGE=true
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_SECONDS=60
CLINIC_NAME=Your Clinic Name
CLINIC_SUPPORT_PHONE=+1234567890

# ============================================================================
# FILE STORAGE CONFIGURATION - UPLOAD_*
# ============================================================================
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_BYTES=10485760

# ============================================================================
# LOCALIZATION CONFIGURATION - LOCALE_*
# ============================================================================
LOCALE_DEFAULT=pt-BR
LOCALE_SUPPORTED=["en","pt-BR","es"]

# ============================================================================
# RATE LIMITING CONFIGURATION - RATE_LIMIT_*
# ============================================================================
RATE_LIMIT_ENABLE=true
RATE_LIMIT_REDIS_URL=rediss://default:PASSWORD@HOST:PORT/3

# ============================================================================
# DEPLOYMENT VALIDATION
# ============================================================================
# Run these commands after deployment:
# python scripts/deployment_validation.py --base-url https://your-api-url.com
# python scripts/validate_deployment_health.py --base-url https://your-api-url.com
# python scripts/validate_critical_fixes.py --base-url https://your-api-url.com
