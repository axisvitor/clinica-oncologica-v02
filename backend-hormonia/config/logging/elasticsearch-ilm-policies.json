{
  "policies": {
    "hormonia-ilm-policy": {
      "policy": {
        "phases": {
          "hot": {
            "min_age": "0ms",
            "actions": {
              "rollover": {
                "max_primary_shard_size": "50GB",
                "max_age": "1d"
              },
              "set_priority": {
                "priority": 100
              }
            }
          },
          "warm": {
            "min_age": "7d",
            "actions": {
              "shrink": {
                "number_of_shards": 1
              },
              "forcemerge": {
                "max_num_segments": 1
              },
              "set_priority": {
                "priority": 50
              }
            }
          },
          "cold": {
            "min_age": "30d",
            "actions": {
              "searchable_snapshot": {
                "snapshot_repository": "hormonia-snapshots"
              },
              "set_priority": {
                "priority": 0
              }
            }
          },
          "delete": {
            "min_age": "90d",
            "actions": {
              "delete": {}
            }
          }
        }
      }
    },
    "hormonia-security-ilm-policy": {
      "policy": {
        "phases": {
          "hot": {
            "min_age": "0ms",
            "actions": {
              "rollover": {
                "max_primary_shard_size": "30GB",
                "max_age": "1d"
              },
              "set_priority": {
                "priority": 150
              }
            }
          },
          "warm": {
            "min_age": "30d",
            "actions": {
              "shrink": {
                "number_of_shards": 1
              },
              "forcemerge": {
                "max_num_segments": 1
              },
              "set_priority": {
                "priority": 75
              }
            }
          },
          "cold": {
            "min_age": "180d",
            "actions": {
              "searchable_snapshot": {
                "snapshot_repository": "hormonia-snapshots"
              },
              "set_priority": {
                "priority": 25
              }
            }
          },
          "delete": {
            "min_age": "365d",
            "actions": {
              "delete": {}
            }
          }
        }
      }
    },
    "hormonia-audit-ilm-policy": {
      "policy": {
        "phases": {
          "hot": {
            "min_age": "0ms",
            "actions": {
              "rollover": {
                "max_primary_shard_size": "50GB",
                "max_age": "30d"
              },
              "set_priority": {
                "priority": 200
              }
            }
          },
          "warm": {
            "min_age": "90d",
            "actions": {
              "shrink": {
                "number_of_shards": 1
              },
              "forcemerge": {
                "max_num_segments": 1
              },
              "set_priority": {
                "priority": 100
              }
            }
          },
          "cold": {
            "min_age": "365d",
            "actions": {
              "searchable_snapshot": {
                "snapshot_repository": "hormonia-snapshots"
              },
              "set_priority": {
                "priority": 50
              }
            }
          },
          "frozen": {
            "min_age": "1825d",
            "actions": {
              "searchable_snapshot": {
                "snapshot_repository": "hormonia-long-term-archive",
                "force_merge_index": true
              },
              "set_priority": {
                "priority": 0
              }
            }
          },
          "delete": {
            "min_age": "2555d",
            "actions": {
              "delete": {}
            }
          }
        }
      }
    }
  },
  "index_templates": {
    "hormonia-logs-template": {
      "index_patterns": ["hormonia-logs-*"],
      "template": {
        "settings": {
          "number_of_shards": 3,
          "number_of_replicas": 1,
          "index.lifecycle.name": "hormonia-ilm-policy",
          "index.lifecycle.rollover_alias": "hormonia-logs",
          "index.codec": "best_compression",
          "index.refresh_interval": "30s",
          "index.translog.durability": "async",
          "index.translog.sync_interval": "30s"
        },
        "mappings": {
          "properties": {
            "@timestamp": {
              "type": "date"
            },
            "level": {
              "type": "keyword"
            },
            "service": {
              "type": "keyword"
            },
            "environment": {
              "type": "keyword"
            },
            "message": {
              "type": "text",
              "fields": {
                "keyword": {
                  "type": "keyword",
                  "ignore_above": 256
                }
              }
            },
            "request_id": {
              "type": "keyword"
            },
            "user_id": {
              "type": "keyword"
            },
            "patient_id": {
              "type": "keyword"
            },
            "exception_type": {
              "type": "keyword"
            },
            "exception_message": {
              "type": "text"
            },
            "stack_trace": {
              "type": "text",
              "index": false
            },
            "api_endpoint": {
              "type": "keyword"
            },
            "http_method": {
              "type": "keyword"
            },
            "http_status": {
              "type": "integer"
            },
            "db_operation": {
              "type": "keyword"
            },
            "db_table": {
              "type": "keyword"
            },
            "db_duration_ms": {
              "type": "float"
            },
            "contains_phi": {
              "type": "boolean"
            },
            "phi_detected": {
              "type": "boolean"
            },
            "error_signature": {
              "type": "keyword"
            },
            "geoip": {
              "properties": {
                "city_name": {
                  "type": "keyword"
                },
                "country_name": {
                  "type": "keyword"
                },
                "location": {
                  "type": "geo_point"
                }
              }
            },
            "tags": {
              "type": "keyword"
            }
          }
        }
      }
    },
    "hormonia-security-template": {
      "index_patterns": ["hormonia-security-*"],
      "template": {
        "settings": {
          "number_of_shards": 2,
          "number_of_replicas": 2,
          "index.lifecycle.name": "hormonia-security-ilm-policy",
          "index.lifecycle.rollover_alias": "hormonia-security",
          "index.codec": "best_compression"
        },
        "mappings": {
          "properties": {
            "@timestamp": {
              "type": "date"
            },
            "security_event_type": {
              "type": "keyword"
            },
            "severity": {
              "type": "keyword"
            },
            "user_id": {
              "type": "keyword"
            },
            "ip_address": {
              "type": "ip"
            },
            "user_agent": {
              "type": "text",
              "fields": {
                "keyword": {
                  "type": "keyword",
                  "ignore_above": 256
                }
              }
            },
            "action": {
              "type": "keyword"
            },
            "resource": {
              "type": "keyword"
            },
            "result": {
              "type": "keyword"
            }
          }
        }
      }
    },
    "hormonia-audit-template": {
      "index_patterns": ["hormonia-audit-*"],
      "template": {
        "settings": {
          "number_of_shards": 2,
          "number_of_replicas": 2,
          "index.lifecycle.name": "hormonia-audit-ilm-policy",
          "index.lifecycle.rollover_alias": "hormonia-audit",
          "index.codec": "best_compression",
          "index.store.type": "niofs"
        },
        "mappings": {
          "properties": {
            "@timestamp": {
              "type": "date"
            },
            "user_id": {
              "type": "keyword"
            },
            "patient_id": {
              "type": "keyword"
            },
            "action": {
              "type": "keyword"
            },
            "resource_type": {
              "type": "keyword"
            },
            "resource_id": {
              "type": "keyword"
            },
            "changes": {
              "type": "object",
              "enabled": false
            },
            "ip_address": {
              "type": "ip"
            },
            "user_agent": {
              "type": "text",
              "index": false
            },
            "compliance_tags": {
              "type": "keyword"
            }
          }
        }
      }
    }
  },
  "ingest_pipelines": {
    "hormonia-enrich-pipeline": {
      "description": "Enrich log entries with additional context",
      "processors": [
        {
          "set": {
            "field": "ingested_at",
            "value": "{{_ingest.timestamp}}"
          }
        },
        {
          "script": {
            "lang": "painless",
            "source": "if (ctx.containsKey('db_duration_ms') && ctx.db_duration_ms != null && ctx.db_duration_ms > 1000) { ctx.slow_query = true; }"
          }
        },
        {
          "script": {
            "lang": "painless",
            "source": "if (ctx.containsKey('http_status') && ctx.http_status != null && ctx.http_status >= 500) { ctx.server_error = true; }"
          }
        },
        {
          "grok": {
            "field": "message",
            "patterns": [
              "%{GREEDYDATA:parsed_message}"
            ],
            "ignore_failure": true
          }
        }
      ]
    }
  },
  "snapshot_policy": {
    "hormonia-snapshot-policy": {
      "schedule": "0 30 2 * * ?",
      "name": "<hormonia-snapshot-{now/d}>",
      "repository": "hormonia-snapshots",
      "config": {
        "indices": ["hormonia-*"],
        "ignore_unavailable": true,
        "include_global_state": false,
        "partial": false
      },
      "retention": {
        "expire_after": "30d",
        "min_count": 5,
        "max_count": 50
      }
    }
  }
}