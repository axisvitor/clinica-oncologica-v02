"""
Comprehensive WhatsApp Routing Tests

Tests P2 Implementation: WhatsApp instance routing and load balancing
Tests message routing logic, instance failover, load balancing, and error handling.
Priority: P2 - High (Reliability Feature)
"""
import pytest
from datetime import datetime, timedelta
from uuid import uuid4
from unittest.mock import Mock, patch, AsyncMock, MagicMock

from app.services.whatsapp_routing import (
    WhatsAppRouter,
    RoutingStrategy,
    InstanceHealth,
    RouteResult
)


@pytest.fixture
def mock_instances():
    """Create mock WhatsApp instances"""
    return [
        {
            "id": "instance-1",
            "name": "Primary Instance",
            "status": "connected",
            "message_count": 100,
            "error_rate": 0.01,
            "last_health_check": datetime.utcnow()
        },
        {
            "id": "instance-2",
            "name": "Secondary Instance",
            "status": "connected",
            "message_count": 50,
            "error_rate": 0.02,
            "last_health_check": datetime.utcnow()
        },
        {
            "id": "instance-3",
            "name": "Tertiary Instance",
            "status": "disconnected",
            "message_count": 200,
            "error_rate": 0.05,
            "last_health_check": datetime.utcnow() - timedelta(minutes=10)
        }
    ]


class TestWhatsAppRouter:
    """Test WhatsApp routing core functionality"""

    def test_router_initialization(self, mock_instances):
        """Test router initializes with instances"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        assert router.instance_count == 2
        assert len(router.active_instances) == 2

    def test_router_filters_disconnected_instances(self, mock_instances):
        """Test router excludes disconnected instances"""
        router = WhatsAppRouter(instances=mock_instances)

        # Should only include connected instances
        active = router.get_active_instances()

        assert len(active) == 2
        assert all(i["status"] == "connected" for i in active)
        assert "instance-3" not in [i["id"] for i in active]

    def test_router_no_active_instances(self):
        """Test router handles no active instances gracefully"""
        disconnected_instances = [{
            "id": "instance-1",
            "status": "disconnected"
        }]

        router = WhatsAppRouter(instances=disconnected_instances)

        assert router.get_active_instances() == []


class TestRoutingStrategies:
    """Test different routing strategies"""

    def test_round_robin_routing(self, mock_instances):
        """Test round-robin distribution across instances"""
        router = WhatsAppRouter(
            instances=mock_instances[:2],
            strategy=RoutingStrategy.ROUND_ROBIN
        )

        # Route multiple messages
        routes = []
        for i in range(6):
            route = router.route_message(f"Message {i}")
            routes.append(route.instance_id)

        # Should alternate between instances
        assert routes == [
            "instance-1", "instance-2",
            "instance-1", "instance-2",
            "instance-1", "instance-2"
        ]

    def test_least_loaded_routing(self, mock_instances):
        """Test routing to least loaded instance"""
        router = WhatsAppRouter(
            instances=mock_instances[:2],
            strategy=RoutingStrategy.LEAST_LOADED
        )

        # instance-2 has 50 messages vs instance-1 with 100
        route = router.route_message("Test message")

        assert route.instance_id == "instance-2"
        assert route.strategy == RoutingStrategy.LEAST_LOADED

    def test_weighted_routing_by_error_rate(self, mock_instances):
        """Test weighted routing based on instance health"""
        router = WhatsAppRouter(
            instances=mock_instances[:2],
            strategy=RoutingStrategy.WEIGHTED
        )

        # Route 100 messages
        routes = []
        for i in range(100):
            route = router.route_message(f"Message {i}")
            routes.append(route.instance_id)

        # instance-1 (error_rate=0.01) should get more messages
        # than instance-2 (error_rate=0.02)
        instance1_count = routes.count("instance-1")
        instance2_count = routes.count("instance-2")

        assert instance1_count > instance2_count

    def test_priority_routing(self, mock_instances):
        """Test priority routing for important messages"""
        # Set priority for instances
        mock_instances[0]["priority"] = 1  # Highest
        mock_instances[1]["priority"] = 2  # Lower

        router = WhatsAppRouter(
            instances=mock_instances[:2],
            strategy=RoutingStrategy.PRIORITY
        )

        # High priority message should go to instance-1
        route = router.route_message("Urgent message", priority="high")

        assert route.instance_id == "instance-1"

    def test_hash_based_routing_consistency(self, mock_instances):
        """Test hash-based routing for same patient goes to same instance"""
        router = WhatsAppRouter(
            instances=mock_instances[:2],
            strategy=RoutingStrategy.CONSISTENT_HASH
        )

        patient_id = "patient-123"

        # Route multiple messages for same patient
        routes = []
        for i in range(5):
            route = router.route_message(
                f"Message {i}",
                patient_id=patient_id
            )
            routes.append(route.instance_id)

        # All should go to same instance
        assert len(set(routes)) == 1


class TestInstanceFailover:
    """Test instance failover functionality"""

    def test_failover_to_backup_instance(self, mock_instances):
        """Test automatic failover when primary instance fails"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        # Mark instance-1 as failed
        router.mark_instance_failed("instance-1")

        # Next message should route to instance-2
        route = router.route_message("Test message")

        assert route.instance_id == "instance-2"
        assert route.is_failover is True

    def test_failover_cascading(self, mock_instances):
        """Test cascading failover through multiple instances"""
        router = WhatsAppRouter(instances=mock_instances)

        # Mark first two as failed
        router.mark_instance_failed("instance-1")
        router.mark_instance_failed("instance-2")

        # Should have no active instances (instance-3 already disconnected)
        with pytest.raises(Exception, match="No active instances"):
            router.route_message("Test message")

    def test_instance_recovery(self, mock_instances):
        """Test instance recovery after failure"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        # Fail and recover instance
        router.mark_instance_failed("instance-1")
        assert "instance-1" not in [i["id"] for i in router.get_active_instances()]

        router.mark_instance_recovered("instance-1")
        assert "instance-1" in [i["id"] for i in router.get_active_instances()]

    def test_automatic_health_check_failover(self, mock_instances, mocker):
        """Test failover triggered by health check failure"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        # Mock health check failure
        mocker.patch.object(
            router,
            '_check_instance_health',
            return_value=InstanceHealth(
                instance_id="instance-1",
                is_healthy=False,
                error="Connection timeout"
            )
        )

        # Trigger health check
        router.run_health_checks()

        # instance-1 should be marked as failed
        assert "instance-1" not in [i["id"] for i in router.get_active_instances()]

    def test_circuit_breaker_pattern(self, mock_instances):
        """Test circuit breaker prevents routing to failing instance"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        # Simulate repeated failures
        for i in range(5):
            router.record_failure("instance-1")

        # Circuit should open (instance marked as failed)
        route = router.route_message("Test message")

        assert route.instance_id != "instance-1"


class TestLoadBalancing:
    """Test load balancing functionality"""

    def test_even_distribution_round_robin(self, mock_instances):
        """Test even distribution with round-robin"""
        router = WhatsAppRouter(
            instances=mock_instances[:2],
            strategy=RoutingStrategy.ROUND_ROBIN
        )

        routes = []
        for i in range(100):
            route = router.route_message(f"Message {i}")
            routes.append(route.instance_id)

        # Should be roughly 50-50
        instance1_count = routes.count("instance-1")
        instance2_count = routes.count("instance-2")

        assert abs(instance1_count - instance2_count) <= 2

    def test_load_rebalancing_after_instance_added(self, mock_instances):
        """Test load rebalances when new instance is added"""
        router = WhatsAppRouter(instances=mock_instances[:1])

        # Route some messages
        for i in range(50):
            router.route_message(f"Message {i}")

        # Add second instance
        router.add_instance(mock_instances[1])

        # New messages should distribute to both
        routes = []
        for i in range(20):
            route = router.route_message(f"New message {i}")
            routes.append(route.instance_id)

        # Should use both instances
        assert "instance-2" in routes

    def test_adaptive_load_balancing(self, mock_instances):
        """Test adaptive balancing based on instance performance"""
        router = WhatsAppRouter(
            instances=mock_instances[:2],
            strategy=RoutingStrategy.ADAPTIVE
        )

        # Simulate instance-1 responding faster
        for i in range(10):
            router.record_latency("instance-1", latency_ms=100)
            router.record_latency("instance-2", latency_ms=500)

        # Route messages - should favor faster instance
        routes = []
        for i in range(50):
            route = router.route_message(f"Message {i}")
            routes.append(route.instance_id)

        # instance-1 should get more messages
        assert routes.count("instance-1") > routes.count("instance-2")


class TestRoutingMetrics:
    """Test routing metrics collection"""

    def test_message_count_tracking(self, mock_instances):
        """Test accurate message count per instance"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        # Route messages
        for i in range(10):
            router.route_message(f"Message {i}")

        metrics = router.get_metrics()

        assert metrics["total_messages"] == 10
        assert metrics["instance-1"]["message_count"] >= 5
        assert metrics["instance-2"]["message_count"] >= 5

    def test_error_rate_tracking(self, mock_instances):
        """Test error rate calculation per instance"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        # Send messages and record some failures
        for i in range(100):
            route = router.route_message(f"Message {i}")
            if i % 10 == 0:  # 10% failure rate
                router.record_failure(route.instance_id)
            else:
                router.record_success(route.instance_id)

        metrics = router.get_metrics()

        # Error rate should be around 10%
        for instance_id in ["instance-1", "instance-2"]:
            error_rate = metrics[instance_id]["error_rate"]
            assert 0.08 <= error_rate <= 0.12

    def test_latency_tracking(self, mock_instances):
        """Test latency metrics per instance"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        # Record latencies
        router.record_latency("instance-1", latency_ms=150)
        router.record_latency("instance-1", latency_ms=200)
        router.record_latency("instance-2", latency_ms=100)

        metrics = router.get_metrics()

        assert metrics["instance-1"]["avg_latency_ms"] == 175
        assert metrics["instance-2"]["avg_latency_ms"] == 100


class TestRoutingEdgeCases:
    """Test edge cases in routing"""

    def test_routing_with_single_instance(self, mock_instances):
        """Test routing works with only one instance"""
        router = WhatsAppRouter(instances=mock_instances[:1])

        for i in range(10):
            route = router.route_message(f"Message {i}")
            assert route.instance_id == "instance-1"

    def test_routing_empty_message(self, mock_instances):
        """Test routing handles empty message gracefully"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        route = router.route_message("")

        assert route.instance_id in ["instance-1", "instance-2"]

    def test_routing_with_metadata(self, mock_instances):
        """Test routing with additional metadata"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        route = router.route_message(
            "Test message",
            patient_id="patient-123",
            priority="high",
            message_type="alert"
        )

        assert route.metadata["patient_id"] == "patient-123"
        assert route.metadata["priority"] == "high"

    def test_concurrent_routing_thread_safety(self, mock_instances, mocker):
        """Test routing is thread-safe with concurrent requests"""
        import threading

        router = WhatsAppRouter(instances=mock_instances[:2])

        results = []
        errors = []

        def route_messages():
            try:
                for i in range(50):
                    route = router.route_message(f"Message {i}")
                    results.append(route.instance_id)
            except Exception as e:
                errors.append(str(e))

        # Create 10 threads
        threads = []
        for _ in range(10):
            t = threading.Thread(target=route_messages)
            threads.append(t)
            t.start()

        # Wait for all threads
        for t in threads:
            t.join()

        # Should have routed all messages without errors
        assert len(results) == 500
        assert len(errors) == 0


class TestInstanceHealthChecks:
    """Test instance health checking"""

    @pytest.mark.asyncio
    async def test_health_check_all_instances(self, mock_instances, mocker):
        """Test health check runs for all instances"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        # Mock Evolution API health check
        mock_client = AsyncMock()
        mock_client.get_instance_status = AsyncMock(return_value={
            "status": "open",
            "connected": True
        })

        mocker.patch(
            'app.services.whatsapp_routing.EvolutionClient',
            return_value=mock_client
        )

        health_results = await router.check_all_instances()

        assert len(health_results) == 2
        assert all(h.is_healthy for h in health_results)

    @pytest.mark.asyncio
    async def test_health_check_detects_failure(self, mock_instances, mocker):
        """Test health check detects failed instance"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        # Mock failure for instance-1
        async def mock_health_check(instance_id):
            if instance_id == "instance-1":
                return InstanceHealth(
                    instance_id=instance_id,
                    is_healthy=False,
                    error="Connection refused"
                )
            return InstanceHealth(
                instance_id=instance_id,
                is_healthy=True
            )

        mocker.patch.object(
            router,
            '_check_instance_health',
            side_effect=mock_health_check
        )

        health_results = await router.check_all_instances()

        instance1_health = next(h for h in health_results if h.instance_id == "instance-1")
        assert instance1_health.is_healthy is False

    def test_health_check_interval(self, mock_instances, mocker):
        """Test health checks run at configured interval"""
        router = WhatsAppRouter(
            instances=mock_instances[:2],
            health_check_interval=60  # 60 seconds
        )

        assert router.health_check_interval == 60


class TestRoutingConfiguration:
    """Test routing configuration"""

    def test_default_configuration(self, mock_instances):
        """Test default router configuration"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        assert router.strategy == RoutingStrategy.ROUND_ROBIN
        assert router.health_check_interval > 0
        assert router.max_retries >= 1

    def test_custom_configuration(self, mock_instances):
        """Test custom router configuration"""
        router = WhatsAppRouter(
            instances=mock_instances[:2],
            strategy=RoutingStrategy.LEAST_LOADED,
            health_check_interval=30,
            max_retries=5,
            circuit_breaker_threshold=10
        )

        assert router.strategy == RoutingStrategy.LEAST_LOADED
        assert router.health_check_interval == 30
        assert router.max_retries == 5
        assert router.circuit_breaker_threshold == 10

    def test_configuration_validation(self):
        """Test invalid configuration is rejected"""
        with pytest.raises(ValueError, match="instances"):
            WhatsAppRouter(instances=[])  # Empty instances

        with pytest.raises(ValueError, match="health_check_interval"):
            WhatsAppRouter(
                instances=[{"id": "test", "status": "connected"}],
                health_check_interval=-1  # Negative interval
            )


class TestRoutingIntegration:
    """Integration tests for routing"""

    @pytest.mark.asyncio
    async def test_end_to_end_message_routing(self, mock_instances, mocker):
        """Test complete message routing flow"""
        router = WhatsAppRouter(instances=mock_instances[:2])

        # Mock Evolution API
        mock_send = AsyncMock(return_value={
            "success": True,
            "message_id": "msg-123"
        })

        mocker.patch(
            'app.services.whatsapp_unified.send_whatsapp_message',
            side_effect=mock_send
        )

        # Route and send message
        route = router.route_message("Test message", patient_id="patient-123")

        # Send via routed instance
        result = await mock_send(
            instance_id=route.instance_id,
            phone="5511999999999",
            message="Test message"
        )

        assert result["success"] is True
        assert route.instance_id in ["instance-1", "instance-2"]

