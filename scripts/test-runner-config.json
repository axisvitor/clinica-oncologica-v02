{
  "test_runner_config": {
    "version": "1.0.0",
    "project_name": "Clinica Oncológica v02",
    "description": "Comprehensive test execution configuration",

    "coverage": {
      "threshold": {
        "global": 90,
        "backend": 90,
        "frontend": 85
      },
      "exclude_patterns": [
        "*/migrations/*",
        "*/venv/*",
        "*/node_modules/*",
        "*/dist/*",
        "*/build/*",
        "*/__pycache__/*",
        "*/coverage/*",
        "*.test.js",
        "*.test.ts",
        "*.test.tsx",
        "*.spec.js",
        "*.spec.ts",
        "*.spec.tsx",
        "*/test/*",
        "*/tests/*"
      ],
      "include_patterns": [
        "backend-hormonia/app/**/*.py",
        "frontend-hormonia/src/**/*.ts",
        "frontend-hormonia/src/**/*.tsx",
        "frontend-hormonia/src/**/*.js",
        "frontend-hormonia/src/**/*.jsx"
      ]
    },

    "test_discovery": {
      "backend": {
        "test_paths": [
          "backend-hormonia/tests",
          "backend-hormonia/app/tests"
        ],
        "test_patterns": [
          "test_*.py",
          "*_test.py"
        ],
        "exclude_patterns": [
          "**/migrations/**",
          "**/venv/**",
          "**/__pycache__/**"
        ]
      },
      "frontend": {
        "test_paths": [
          "frontend-hormonia/src",
          "frontend-hormonia/tests",
          "frontend-hormonia/test"
        ],
        "test_patterns": [
          "*.test.ts",
          "*.test.tsx",
          "*.test.js",
          "*.test.jsx",
          "*.spec.ts",
          "*.spec.tsx",
          "*.spec.js",
          "*.spec.jsx"
        ],
        "exclude_patterns": [
          "**/node_modules/**",
          "**/dist/**",
          "**/build/**",
          "**/coverage/**"
        ]
      }
    },

    "environments": {
      "development": {
        "database_url": "postgresql://postgres:postgres@localhost:5432/clinica_dev",
        "redis_url": "redis://localhost:6379/0",
        "api_base_url": "http://localhost:8000",
        "frontend_url": "http://localhost:3000"
      },
      "testing": {
        "database_url": "postgresql://postgres:postgres@localhost:5432/test_clinica",
        "redis_url": "redis://localhost:6379/1",
        "api_base_url": "http://localhost:8001",
        "frontend_url": "http://localhost:3001"
      },
      "ci": {
        "database_url": "postgresql://postgres:postgres@localhost:5432/test_db",
        "redis_url": "redis://localhost:6379",
        "api_base_url": "http://localhost:8000",
        "frontend_url": "http://localhost:3000"
      }
    },

    "timeouts": {
      "command_timeout": 300,
      "test_timeout": 120,
      "benchmark_timeout": 600,
      "security_scan_timeout": 180
    },

    "parallel_execution": {
      "backend": {
        "max_workers": 4,
        "chunk_size": 10
      },
      "frontend": {
        "max_workers": 2,
        "chunk_size": 5
      }
    },

    "reporting": {
      "formats": ["json", "html", "junit", "coverage"],
      "output_directory": "test-reports",
      "archive_reports": true,
      "retention_days": 30,
      "generate_badges": true
    },

    "security": {
      "tools": {
        "backend": ["bandit", "safety", "semgrep"],
        "frontend": ["npm-audit", "audit-ci"],
        "general": ["trufflehog", "gitleaks"]
      },
      "severity_threshold": "medium",
      "fail_on_high": true,
      "whitelist_files": [
        "test-*",
        "*.test.*",
        "*.spec.*",
        "mock*",
        "fixture*"
      ]
    },

    "performance": {
      "benchmarks": {
        "enabled": true,
        "tools": ["pytest-benchmark", "lighthouse", "web-vitals"],
        "thresholds": {
          "response_time_ms": 500,
          "memory_usage_mb": 100,
          "cpu_usage_percent": 80
        }
      },
      "load_testing": {
        "enabled": false,
        "tools": ["locust", "artillery"],
        "concurrent_users": 10,
        "duration_seconds": 60
      }
    },

    "notifications": {
      "enabled": true,
      "channels": ["github", "slack", "email"],
      "conditions": {
        "always": ["failure"],
        "on_change": ["success", "coverage_change"],
        "scheduled": ["daily_summary"]
      }
    },

    "integrations": {
      "github_actions": {
        "enabled": true,
        "workflow_file": ".github/workflows/comprehensive-testing.yml",
        "artifact_retention_days": 30
      },
      "codecov": {
        "enabled": true,
        "token_env": "CODECOV_TOKEN",
        "fail_ci_if_error": false
      },
      "sonarqube": {
        "enabled": false,
        "server_url": "",
        "project_key": "clinica-oncologica-v02"
      }
    },

    "database": {
      "migrations": {
        "run_before_tests": true,
        "rollback_after_tests": false,
        "seed_test_data": true
      },
      "cleanup": {
        "truncate_tables": true,
        "reset_sequences": true,
        "preserve_structure": true
      }
    },

    "test_categories": {
      "unit": {
        "description": "Fast, isolated tests",
        "timeout": 30,
        "parallel": true,
        "required_coverage": 95
      },
      "integration": {
        "description": "Tests with external dependencies",
        "timeout": 60,
        "parallel": false,
        "required_coverage": 80
      },
      "e2e": {
        "description": "End-to-end user scenarios",
        "timeout": 120,
        "parallel": false,
        "required_coverage": 70
      },
      "performance": {
        "description": "Performance and load tests",
        "timeout": 300,
        "parallel": false,
        "required_coverage": 0
      },
      "security": {
        "description": "Security and vulnerability tests",
        "timeout": 180,
        "parallel": true,
        "required_coverage": 0
      }
    },

    "test_data": {
      "fixtures": {
        "location": "test-data/fixtures",
        "format": "json",
        "auto_load": true
      },
      "mocks": {
        "location": "test-data/mocks",
        "auto_discover": true
      },
      "factories": {
        "location": "test-data/factories",
        "auto_register": true
      }
    },

    "docker": {
      "enabled": true,
      "services": {
        "postgres": {
          "image": "postgres:15",
          "ports": ["5432:5432"],
          "environment": {
            "POSTGRES_PASSWORD": "postgres",
            "POSTGRES_DB": "test_db"
          }
        },
        "redis": {
          "image": "redis:7",
          "ports": ["6379:6379"]
        }
      },
      "networks": ["test-network"],
      "cleanup_after": true
    },

    "feature_flags": {
      "enable_experimental_tests": false,
      "enable_mutation_testing": false,
      "enable_visual_regression": false,
      "enable_accessibility_tests": true,
      "enable_cross_browser_tests": false
    },

    "quality_gates": {
      "required_checks": [
        "test_success_rate >= 100%",
        "code_coverage >= 90%",
        "security_high_issues == 0",
        "build_success == true"
      ],
      "optional_checks": [
        "performance_regression < 10%",
        "code_duplication < 5%",
        "technical_debt < 1h"
      ],
      "blocking": true,
      "allow_override": false
    }
  }
}