# EditorConfig - Sistema Clínica Oncológica V02
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,pyi}]
indent_size = 4
max_line_length = 88

[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 100

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{sh,bash}]
indent_size = 2
end_of_line = lf

[Makefile]
indent_style = tab

[*.sql]
indent_size = 2

[{package.json,package-lock.json,*.lock}]
indent_size = 2

[*.{html,css,scss}]
indent_size = 2

[Dockerfile*]
indent_size = 2

[docker-compose*.yml]
indent_size = 2

[*.ini]
indent_size = 4

[*.toml]
indent_size = 2

[.env*]
indent_size = 2
insert_final_newline = false
