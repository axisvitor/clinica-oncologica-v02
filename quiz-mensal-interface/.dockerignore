# =============================================================================
# DOCKERIGNORE - Quiz Mensal Interface (Railway/Docker Build Optimization)
# =============================================================================
# IMPORTANT: DO NOT exclude Dockerfile* - Railway needs them for build!
# =============================================================================

# Dependencies (rebuilt in container)
node_modules
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.npm
.pnpm-store

# Build output (rebuilt in container - Next.js standalone)
.next
out
build
dist

# Testing
coverage
test-results
.nyc_output
playwright-report

# IDE
.vscode
.idea
*.swp
*.swo
*~

# Environment files (SECURITY - never include in image)
.env
.env.local
.env.development
.env.test
.env.production
# Keep example for reference
!.env.example

# Logs
*.log
logs

# OS
.DS_Store
Thumbs.db

# Git (exclude history from build)
.git
.gitignore
.gitattributes

# Documentation (not needed in production image)
docs/
*.md
!README.md

# Cache
.cache
.temp
tmp
.turbo

# TypeScript
*.tsbuildinfo

# ESLint
.eslintcache

# Next.js cache (rebuilt during build)
.next/cache

# Backup files
*.bak
*.backup

# Archives
*.tar
*.tar.gz
*.zip

# Claude Flow metadata (development only)
.claude-flow/
.hive-mind/
.swarm/

# Storybook (if present)
storybook-static
