    "@vitest/ui": "^3.2.4",
    "cross-env": "^10.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.23",
    "eslint-plugin-testing-library": "^7.1.1",
    "globals": "^16.4.0",
    "jsdom": "^26.1.0",
    "lightningcss": "^1.30.1",
    "playwright": "^1.49.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^6.0.7",
    "vitest": "^3.2.4",
    "vitest-sonar-reporter": "^2.0.0"
  },
  "optionalDependencies": {
    "rollup": "^4.46.3"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:prod": "vite build --mode production",
    "build:railway": "npm ci --prefer-offline && npm run build:runtime",
    "build:runtime": "tsc && vite build --mode production && npm run post-build:runtime",
    "post-build:runtime": "node scripts/post-build-config.js",
    "start": "npm run preview",
    "preview": "vite preview --host 0.0.0.0 --port $PORT",
    "preview:local": "vite preview --host 0.0.0.0 --port 4173",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:run": "vitest run",
    "test:ci": "vitest run --coverage --reporter=verbose --reporter=json --reporter=html",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:config": "playwright test tests/e2e/runtime-config.spec.ts",
    "test:e2e:validate": "node scripts/validate_e2e_setup.js",
    "validate:config": "npx tsx scripts/validate-ai-config.ts",
    "validate:ai": "npm run validate:config",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm run test:run && npm run test:e2e",
    "test:security": "npm audit --audit-level=moderate",
    "test:performance": "npm run build && npm run test:e2e -- --grep='@performance'",
    "typecheck": "tsc --noEmit",
    "typecheck:ci": "tsc --noEmit --skipLibCheck",
    "quality": "npm run lint && npm run typecheck && npm run test:ci",
    "setup:playwright": "npx playwright install",
    "clean": "rm -rf dist node_modules/.vite",
    "clean:full": "rm -rf dist node_modules package-lock.json && npm install",
    "analyze": "npm run build:prod && npx vite-bundle-analyzer dist",
    "health": "curl -f http://localhost:$PORT/ || exit 1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
