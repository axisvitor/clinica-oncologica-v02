# =============================================================================
# HORMONIA FRONTEND - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
#
# ENV Variable Naming Convention: VITE_{CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
#
# OVERVIEW: Frontend-specific configuration variables for React/Vite
# This file extends the root .env.example with frontend-only variables
#
# SETUP INSTRUCTIONS:
# 1. First, set up root .env with shared variables
# 2. Copy this file to frontend-hormonia/.env for development
# 3. Copy to frontend-hormonia/.env.production for production deployment
# 4. Fill in your actual values (replace all 'your-*' placeholders)
#
# IMPORTANT: All Vite variables MUST start with VITE_ to be accessible in browser
# SECURITY: VITE_ variables are PUBLIC - never put secrets here
# NOTE: Database credentials and API keys are handled by backend
# =============================================================================

# =============================================================================
# APPLICATION CONFIGURATION - VITE_APP_*
# =============================================================================
# Environment: development, staging, production
VITE_APP_ENVIRONMENT=production
# Enable debug mode for development (shows debug tools, verbose logging)
VITE_APP_ENABLE_DEBUG=false
# Application display name
VITE_APP_NAME=Hormonia - Sistema de Gestão Oncológica
# Application version
VITE_APP_VERSION=2.0.0
# Show version in UI footer
VITE_APP_ENABLE_VERSION_DISPLAY=false

# =============================================================================
# BACKEND API CONFIGURATION - VITE_API_*
# =============================================================================
# Backend base URL (without /api/v2 path)
# Development: http://localhost:8000
# Production: https://your-backend.railway.app
VITE_API_BASE_URL=http://localhost:8000
# Full API endpoint URL
# Development: http://localhost:8000/api/v2
# Production: https://your-backend.railway.app/api/v2
VITE_API_ENDPOINT_URL=http://localhost:8000/api/v2
# API base path (used for routing)
VITE_API_BASE_PATH=/api/v2
# API request timeout in milliseconds
VITE_API_REQUEST_TIMEOUT_MS=30000

# =============================================================================
# WEBSOCKET CONFIGURATION - VITE_WS_*
# =============================================================================
# WebSocket base URL for real-time features
# Development: ws://localhost:8000/ws
# Production: wss://your-backend.railway.app/ws (use wss:// for secure)
VITE_WS_BASE_URL=ws://localhost:8000/ws
# WebSocket endpoint URL (alternative)
VITE_WS_ENDPOINT_URL=ws://localhost:8000/ws

# =============================================================================
# FIREBASE AUTHENTICATION - VITE_FIREBASE_* (Client SDK)
# =============================================================================
# Public Firebase configuration (safe for browser)
# Get from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# =============================================================================
# WHATSAPP INTEGRATION - VITE_WHATSAPP_*
# =============================================================================
# WhatsApp Evolution API instance name
VITE_WHATSAPP_INSTANCE_NAME=hormonia-instance
# Enable WhatsApp service integration
VITE_WHATSAPP_ENABLE_SERVICE=true
# Maximum file size for WhatsApp uploads (16MB default)
VITE_WHATSAPP_MAX_FILE_SIZE_BYTES=16777216

# =============================================================================
# AI FEATURES - VITE_AI_*
# =============================================================================
# Enable AI chat interface
VITE_AI_ENABLE_CHAT=true
# Enable AI analytics dashboard
VITE_AI_ENABLE_ANALYTICS=true
# Enable AI-driven insights
VITE_AI_ENABLE_INSIGHTS=true
# Enable AI recommendations engine
VITE_AI_ENABLE_RECOMMENDATIONS=true

# =============================================================================
# FEATURE FLAGS - VITE_FEATURE_ENABLE_*
# =============================================================================
# Core UI Features - Control what's visible in frontend
VITE_FEATURE_ENABLE_WHATSAPP=true
VITE_FEATURE_ENABLE_AI_CHAT=true
VITE_FEATURE_ENABLE_APPOINTMENT=true
VITE_FEATURE_ENABLE_PATIENT_PORTAL=true
VITE_FEATURE_ENABLE_TELEMEDICINE=true
VITE_FEATURE_ENABLE_DARK_MODE=true

# =============================================================================
# DEVELOPMENT FLAGS - VITE_DEV_ENABLE_*
# =============================================================================
# Development UI Features (should be false in production)
VITE_DEV_ENABLE_DEBUG_TOOLS=false
VITE_DEV_ENABLE_MOCK_DATA=false
VITE_DEV_ENABLE_MOCK_API=false
VITE_DEV_ENABLE_MOCK_AUTH=false

# =============================================================================
# SESSION MANAGEMENT - VITE_SESSION_*
# =============================================================================
# Session timeout in milliseconds
# 8 hours (28800000 ms) to match backend SESSION_COOKIE_MAX_AGE
VITE_SESSION_TIMEOUT_MS=28800000
# Token refresh threshold in milliseconds (5 minutes before expiry)
VITE_SESSION_TOKEN_REFRESH_THRESHOLD_MS=300000
# JWT token storage key in localStorage
VITE_SESSION_JWT_STORAGE_KEY=hormonia_access_token
# JWT refresh token storage key
VITE_SESSION_JWT_REFRESH_KEY=hormonia_refresh_token

# =============================================================================
# SECURITY FEATURES - VITE_SECURITY_ENABLE_*
# =============================================================================
# Enable Content Security Policy
VITE_SECURITY_ENABLE_CSP=true
# Force HTTPS redirect
VITE_SECURITY_ENABLE_HTTPS=true
# Enable security headers
VITE_SECURITY_ENABLE_HEADERS=true

# =============================================================================
# FILE UPLOAD - VITE_UPLOAD_*
# =============================================================================
# Maximum file size in bytes (10MB default)
VITE_UPLOAD_MAX_SIZE_BYTES=10485760
# Supported MIME types for uploads
VITE_UPLOAD_SUPPORTED_MIMETYPES=image/jpeg,image/png,image/gif,application/pdf
# Allowed file extensions
VITE_UPLOAD_ALLOWED_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png,gif,txt
# Chunk size for large file uploads (1MB default)
VITE_UPLOAD_CHUNK_SIZE_BYTES=1048576

# =============================================================================
# MONITORING & ANALYTICS - VITE_MONITORING_*
# =============================================================================
# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/
VITE_MONITORING_SENTRY_DSN=
# General analytics tracking ID
VITE_MONITORING_ANALYTICS_ID=
# Enable error reporting
VITE_MONITORING_ENABLE_ERRORS=true
# Enable performance monitoring
VITE_MONITORING_ENABLE_PERFORMANCE=true
# Google Analytics tracking ID
VITE_MONITORING_GOOGLE_ANALYTICS_ID=
# Hotjar site ID
VITE_MONITORING_HOTJAR_ID=
# Mixpanel token
VITE_MONITORING_MIXPANEL_TOKEN=

# =============================================================================
# PERFORMANCE - VITE_REQUEST_*
# =============================================================================
# HTTP request timeout in milliseconds
VITE_REQUEST_TIMEOUT_MS=30000
# Maximum retry attempts for failed requests
VITE_REQUEST_MAX_RETRY_ATTEMPTS=3
# Delay between retry attempts in milliseconds
VITE_REQUEST_RETRY_DELAY_MS=1000

# =============================================================================
# CACHE CONFIGURATION - VITE_CACHE_*
# =============================================================================
# Default cache duration in milliseconds (5 minutes)
VITE_CACHE_DURATION_MS=300000
# Image cache duration in milliseconds (1 hour)
VITE_CACHE_IMAGE_DURATION_MS=3600000

# =============================================================================
# THEME CONFIGURATION - VITE_THEME_*
# =============================================================================
# Theme colors - CSS custom properties
VITE_THEME_PRIMARY_COLOR=#2563eb
VITE_THEME_SECONDARY_COLOR=#7c3aed
VITE_THEME_SUCCESS_COLOR=#10b981
VITE_THEME_ERROR_COLOR=#ef4444
VITE_THEME_WARNING_COLOR=#f59e0b

# =============================================================================
# LAYOUT CONFIGURATION - VITE_LAYOUT_*
# =============================================================================
# UI component dimensions in pixels
VITE_LAYOUT_SIDEBAR_WIDTH_PX=280
VITE_LAYOUT_HEADER_HEIGHT_PX=64
VITE_LAYOUT_FOOTER_HEIGHT_PX=60

# =============================================================================
# PAGINATION - VITE_PAGINATION_*
# =============================================================================
# Default page size for lists
VITE_PAGINATION_DEFAULT_SIZE=20
# Maximum allowed page size
VITE_PAGINATION_MAX_SIZE=100

# =============================================================================
# LOCALIZATION - VITE_I18N_*
# =============================================================================
# Default language locale
VITE_I18N_DEFAULT_LANGUAGE=pt-BR
# Supported language locales (comma-separated)
VITE_I18N_SUPPORTED_LANGUAGES=pt-BR,en-US
# Default timezone
VITE_I18N_TIMEZONE=America/Sao_Paulo
# Date format pattern
VITE_I18N_DATE_FORMAT=DD/MM/YYYY
# Time format pattern
VITE_I18N_TIME_FORMAT=HH:mm
# DateTime format pattern
VITE_I18N_DATETIME_FORMAT=DD/MM/YYYY HH:mm

# =============================================================================
# PWA CONFIGURATION - VITE_PWA_*
# =============================================================================
# Enable Progressive Web App features
VITE_PWA_ENABLE_SERVICE=true
# PWA short name for home screen
VITE_PWA_SHORT_NAME=Hormonia
# PWA description
VITE_PWA_DESCRIPTION=Sistema de Gestão para Clínica Oncológica
# PWA theme color
VITE_PWA_THEME_COLOR=#2563eb
# PWA background color
VITE_PWA_BACKGROUND_COLOR=#ffffff

# =============================================================================
# HEALTH CHECK - VITE_HEALTH_*
# =============================================================================
# Health check polling interval in milliseconds
VITE_HEALTH_CHECK_INTERVAL_MS=60000
# Enable API status checks
VITE_HEALTH_ENABLE_API_STATUS=true

# =============================================================================
# CLINIC BRANDING - VITE_CLINIC_*
# =============================================================================
# Clinic information - Displayed in frontend UI
VITE_CLINIC_NAME=Clínica Hormonia
VITE_CLINIC_ADDRESS=Rua das Flores, 123, São Paulo, SP
VITE_CLINIC_PHONE=+55 11 99999-9999
VITE_CLINIC_EMAIL=contato@clinicahormonia.com.br

# =============================================================================
# MAP SERVICES - VITE_MAP_*
# =============================================================================
# Google Maps API key (if used in frontend)
VITE_MAP_GOOGLE_API_KEY=
# Mapbox token (if used in frontend)
VITE_MAP_MAPBOX_TOKEN=

# =============================================================================
# BUILD CONFIGURATION - VITE_BUILD_*
# =============================================================================
# Enable source maps (disable in production for security)
VITE_BUILD_ENABLE_SOURCEMAP=true
# Enable code minification
VITE_BUILD_ENABLE_MINIFY=true
# Build target ES version
VITE_BUILD_TARGET=es2015
# Base URL for deployment
VITE_BUILD_BASE_URL=/
# Asset inline limit in bytes
VITE_BUILD_ASSET_INLINE_LIMIT_BYTES=4096
# Enable CSS code splitting
VITE_BUILD_ENABLE_CSS_SPLIT=true

# =============================================================================
# DEVELOPMENT/PRODUCTION EXAMPLES:
#
# Development:
# VITE_APP_ENVIRONMENT=development
# VITE_APP_ENABLE_DEBUG=true
# VITE_API_BASE_URL=http://localhost:8000
# VITE_WS_BASE_URL=ws://localhost:8000/ws
# VITE_DEV_ENABLE_DEBUG_TOOLS=true
# VITE_SECURITY_ENABLE_HTTPS=false
# VITE_BUILD_ENABLE_SOURCEMAP=true
#
# Production:
# VITE_APP_ENVIRONMENT=production
# VITE_APP_ENABLE_DEBUG=false
# VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_WS_BASE_URL=wss://api.yourdomain.com/ws
# VITE_DEV_ENABLE_DEBUG_TOOLS=false
# VITE_SECURITY_ENABLE_HTTPS=true
# VITE_BUILD_ENABLE_SOURCEMAP=false
# =============================================================================
