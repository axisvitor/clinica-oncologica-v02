# =============================================================================
# HORMONIA FRONTEND - FRONTEND-SPECIFIC ENVIRONMENT VARIABLES
# =============================================================================
#
# OVERVIEW: Frontend-specific configuration variables for React/Vite
# This file extends the root .env.example with frontend-only variables
#
# SETUP INSTRUCTIONS:
# 1. First, set up root .env with shared variables
# 2. Copy this file to Frontend-v2/.env for development
# 3. Copy to Frontend-v2/.env.production for production deployment
# 4. Fill in your actual values (replace all 'your-*' placeholders)
#
# IMPORTANT: All Vite variables MUST start with VITE_ to be accessible in browser
# SECURITY: VITE_ variables are PUBLIC - never put secrets here
# NOTE: Database credentials and API keys are handled by backend
# =============================================================================

# =============================================================================
# BACKEND API CONFIGURATION - FRONTEND CONNECTIONS
# =============================================================================
# Backend API Configuration
# Development: http://localhost:8000/api/v2
# Production: https://your-backend-web.railway.app/api/v2
VITE_API_URL=http://localhost:8000/api/v2
VITE_API_BASE_URL=http://localhost:8000

# API Configuration
VITE_API_BASE_PATH=/api/v2
VITE_API_TIMEOUT=30000

# WebSocket Configuration for real-time features
# Development: ws://localhost:8000/ws
# Production: wss://your-backend-web.railway.app/ws
VITE_WS_URL=ws://localhost:8000/ws
VITE_WS_BASE_URL=ws://localhost:8000/ws


# =============================================================================
# FIREBASE AUTHENTICATION - FRONTEND CLIENT SDK
# =============================================================================
# Public Firebase configuration (safe for browser)
# Get from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# =============================================================================
# APPLICATION CONFIGURATION - FRONTEND METADATA
# =============================================================================

# Environment and Debug Settings
VITE_ENVIRONMENT=production
VITE_DEBUG_MODE=false

# Application Metadata - Displayed in UI
VITE_APP_NAME=Hormonia - Sistema de Gestão Oncológica
VITE_APP_VERSION=2.0.0

{{ ... }}
# =============================================================================
# FEATURE FLAGS - FRONTEND UI TOGGLES
# =============================================================================

# Core UI Features - Control what's visible in frontend
VITE_ENABLE_WHATSAPP_INTEGRATION=true
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_APPOINTMENT_BOOKING=true
VITE_ENABLE_PATIENT_PORTAL=true
VITE_ENABLE_TELEMEDICINE=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_EVOLUTION=true

# Development UI Features (production defaults)
VITE_ENABLE_DEBUG_TOOLS=false
VITE_ENABLE_MOCK_DATA=false
VITE_USE_MOCK_API=false
VITE_USE_MOCK_AUTH=false

# AI UI Features - Frontend AI components
VITE_AI_CHAT_ENABLED=true
VITE_AI_ANALYTICS_ENABLED=true
VITE_AI_INSIGHTS_ENABLED=true
VITE_AI_RECOMMENDATIONS_ENABLED=true

# =============================================================================
# AUTHENTICATION - FRONTEND SESSION MANAGEMENT
# =============================================================================

# Session Management (in milliseconds)
# Session timeout: 8 hours (28800000 ms) to match backend SESSION_COOKIE_MAX_AGE
VITE_SESSION_TIMEOUT=28800000
VITE_TOKEN_REFRESH_THRESHOLD=300000

# JWT Token Storage Keys - Frontend local storage
VITE_JWT_STORAGE_KEY=hormonia_access_token
VITE_JWT_REFRESH_KEY=hormonia_refresh_token

# Security Features - Frontend security enforcement (production defaults)
VITE_ENABLE_CSP=true
VITE_FORCE_HTTPS=true
VITE_SECURITY_HEADERS_ENABLED=true

# =============================================================================
# UI/UX CONFIGURATION - FRONTEND STYLING
# =============================================================================

# Theme Colors - CSS custom properties
VITE_PRIMARY_COLOR=#2563eb
VITE_SECONDARY_COLOR=#7c3aed
VITE_SUCCESS_COLOR=#10b981
VITE_ERROR_COLOR=#ef4444
VITE_WARNING_COLOR=#f59e0b

# Layout Settings - UI component dimensions
VITE_SIDEBAR_WIDTH=280
VITE_HEADER_HEIGHT=64
VITE_FOOTER_HEIGHT=60

# Data Display Settings - Tables and pagination
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# =============================================================================
# PERFORMANCE CONFIGURATION - FRONTEND OPTIMIZATION
# =============================================================================

# HTTP Request Settings - Frontend API calls
VITE_REQUEST_TIMEOUT=30000
VITE_REQUEST_RETRY_ATTEMPTS=3
VITE_REQUEST_RETRY_DELAY=1000

# Cache Settings - Frontend caching (milliseconds)
VITE_CACHE_DURATION=300000
VITE_IMAGE_CACHE_DURATION=3600000

# =============================================================================
# FILE UPLOAD CONFIGURATION - FRONTEND LIMITS
# =============================================================================

# File Upload Limits - Frontend validation (bytes)
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,gif,txt
VITE_UPLOAD_CHUNK_SIZE=1048576
VITE_SUPPORTED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# =============================================================================
# LOCALIZATION - FRONTEND UI LANGUAGE
# =============================================================================

# Language Settings - Frontend UI localization
VITE_DEFAULT_LANGUAGE=pt-BR
VITE_SUPPORTED_LANGUAGES=pt-BR,en-US
VITE_TIMEZONE=America/Sao_Paulo

# Date/Time Formatting - Frontend display formats
VITE_DATE_FORMAT=DD/MM/YYYY
VITE_TIME_FORMAT=HH:mm
VITE_DATETIME_FORMAT=DD/MM/YYYY HH:mm

# =============================================================================
# WHATSAPP INTEGRATION - FRONTEND COMPONENTS
# =============================================================================

# WhatsApp UI Configuration
VITE_WHATSAPP_INSTANCE_NAME=hormonia-instance
VITE_WHATSAPP_MAX_FILE_SIZE=16777216

# =============================================================================
# MONITORING & ANALYTICS - FRONTEND TRACKING
# =============================================================================

# Error Reporting - Frontend error boundary
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# External Analytics (Optional)
# Get your Sentry DSN from: https://sentry.io/
VITE_SENTRY_DSN=

# Get your Analytics tracking ID
VITE_ANALYTICS_TRACKING_ID=

# =============================================================================
# PWA CONFIGURATION - PROGRESSIVE WEB APP
# =============================================================================

# Progressive Web App Settings
VITE_PWA_ENABLED=true
VITE_PWA_SHORT_NAME=Hormonia
VITE_PWA_DESCRIPTION=Sistema de Gestão para Clínica Oncológica
VITE_PWA_THEME_COLOR=#2563eb
VITE_PWA_BACKGROUND_COLOR=#ffffff

# =============================================================================
# HEALTH CHECK - FRONTEND MONITORING
# =============================================================================

# Health Monitoring - Frontend service checks
VITE_HEALTH_CHECK_INTERVAL=60000
VITE_API_STATUS_CHECK=true

# Version Display - Frontend version info
VITE_SHOW_VERSION=false

# =============================================================================
# CLINIC BRANDING - FRONTEND DISPLAY
# =============================================================================

# Clinic Information - Displayed in frontend UI
VITE_CLINIC_NAME=Clínica Hormonia
VITE_CLINIC_ADDRESS=Rua das Flores, 123, São Paulo, SP
VITE_CLINIC_PHONE=+55 11 99999-9999
VITE_CLINIC_EMAIL=contato@clinicahormonia.com.br

# =============================================================================
# EXTERNAL INTEGRATIONS - FRONTEND ONLY KEYS
# =============================================================================

# NOTE: These are ONLY for frontend-only services
# Backend API keys should NEVER be in frontend environment

# Client-side Analytics Keys (if different from backend)
# These are safe to expose as they're meant for browser use
VITE_GOOGLE_ANALYTICS_ID=
VITE_HOTJAR_ID=
VITE_MIXPANEL_TOKEN=

# Map Services (if used in frontend)
VITE_GOOGLE_MAPS_API_KEY=
VITE_MAPBOX_TOKEN=

# =============================================================================
# BUILD CONFIGURATION - FRONTEND BUILD PROCESS
# =============================================================================

# Build Settings - Vite build configuration
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true
VITE_BUILD_TARGET=es2015

# Base URL - For deployment on subdirectories
VITE_BASE_URL=/

# Asset Optimization
VITE_ASSET_INLINE_LIMIT=4096
VITE_CSS_CODE_SPLIT=true

# =============================================================================
# DEVELOPMENT/PRODUCTION EXAMPLES:
#
# Development:
# VITE_ENVIRONMENT=development
# VITE_DEBUG_MODE=true
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000/ws
# VITE_ENABLE_DEBUG_TOOLS=true
# VITE_FORCE_HTTPS=false
# VITE_BUILD_SOURCEMAP=true
#
# Production:
# VITE_ENVIRONMENT=production
# VITE_DEBUG_MODE=false
# VITE_API_URL=https://api.yourdomain.com
# VITE_WS_URL=wss://api.yourdomain.com/ws
# VITE_ENABLE_DEBUG_TOOLS=false
# VITE_FORCE_HTTPS=true
# VITE_BUILD_SOURCEMAP=false
# =============================================================================
