# ============================================================================
# FRONTEND HORMONIA - RAILWAY DEPLOYMENT ENVIRONMENT VARIABLES
# ============================================================================
# Este arquivo contém APENAS as variáveis necessárias para Railway deployment.
# Para desenvolvimento local, use .env.example completo.
#
# IMPORTANTE:
# - Todas as variáveis VITE_* são injetadas em BUILD TIME
# - BACKEND_URL é injetado em RUNTIME via nginx entrypoint.sh
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────
# RUNTIME CONFIGURATION (Required for Railway)
# ──────────────────────────────────────────────────────────────────────────
# Esta variável é OBRIGATÓRIA no Railway e é injetada pelo entrypoint.sh
# Ela configura o proxy nginx para rotear /api/* e /ws para o backend
BACKEND_URL=https://backend-production-xxxxx.up.railway.app

# Railway define PORT automaticamente (default: 3000)
# Não é necessário definir PORT no Railway dashboard
# PORT=3000

# ──────────────────────────────────────────────────────────────────────────
# BUILD-TIME VARIABLES (Optional - Fallback Configuration)
# ──────────────────────────────────────────────────────────────────────────
# Estas variáveis são opcionais porque o frontend carrega config via /api/config
# Se /api/config falhar, o frontend usa estas variáveis como fallback
# ──────────────────────────────────────────────────────────────────────────

# Firebase Web SDK (Público - Safe to expose)
VITE_FIREBASE_API_KEY=AIzaSyC_example_public_key_12345
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase Client (Público - Anon Key Only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example_anon_key

# API Configuration (Fallback - Prefer /api/config runtime)
VITE_API_URL=https://backend-production-xxxxx.up.railway.app/api/v1
VITE_API_BASE_URL=https://backend-production-xxxxx.up.railway.app
VITE_WS_BASE_URL=wss://backend-production-xxxxx.up.railway.app/ws

# ──────────────────────────────────────────────────────────────────────────
# DEPLOYMENT CHECKLIST
# ──────────────────────────────────────────────────────────────────────────
#
# 1. BACKEND_URL é OBRIGATÓRIO - Configure no Railway após deploy do backend
# 2. VITE_* são OPCIONAIS - Funcionam como fallback se /api/config falhar
# 3. Ordem de precedência: /api/config > VITE_* > hardcoded defaults
# 4. Validação pós-deploy: curl https://frontend.railway.app/health
#
# Documentação completa: docs/architecture/RAILWAY_DEPLOYMENT_ARCHITECTURE.md
