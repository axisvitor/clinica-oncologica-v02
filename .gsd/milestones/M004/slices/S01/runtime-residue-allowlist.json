      "matchers": [
        {
          "type": "literal",
          "pattern": "query_session_id"
        },
        {
          "type": "literal",
          "pattern": "searchParams.set('session_id'"
        },
        {
          "type": "literal",
          "pattern": "searchParams.set(\"session_id\""
        },
        {
          "type": "literal",
          "pattern": "normalizeSessionQueryFallback("
        },
        {
          "type": "literal",
          "pattern": "normalizeSessionFallback("
        }
      ],
      "scopes": {
        "backend": {
          "roots": [
            "backend-hormonia/app/api/websockets.py"
          ],
          "approved": [
            {
              "path": "backend-hormonia/app/api/websockets.py",
              "anchors": [
