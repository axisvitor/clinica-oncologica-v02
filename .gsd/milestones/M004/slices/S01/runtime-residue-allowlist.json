{
  "schema_version": 1,
  "out_of_scope_exclusions": [
    {
      "id": "schema_model_residue",
      "reason": "Schema/model residue belongs to M005 and is outside the official runtime-auth/session failure surface for S01.",
      "paths": [
        "backend-hormonia/app/models/**",
        "backend-hormonia/app/schemas/**"
      ]
    },
    {
      "id": "historical_docs_tests",
      "reason": "Historical docs, generated docs, and tests can mention the legacy contract without representing live runtime drift.",
      "paths": [
        "backend-hormonia/tests/**",
        "backend-hormonia/docs/**",
        "backend-hormonia/app/api/v2/routers/docs/**",
        "frontend-hormonia/tests/**",
        "frontend-hormonia/src/**/__tests__/**",
        "frontend-hormonia/src/**/*.test.ts",
        "frontend-hormonia/src/**/*.test.tsx",
        "frontend-hormonia/src/**/*.spec.ts",
        "frontend-hormonia/src/**/*.spec.tsx",
        "docs/**"
      ]
    },
    {
      "id": "vendor_or_unrelated_session_strings",
      "reason": "WuzAPI, quiz/public session strings, mocks, and third-party clients are not the staff auth/session runtime boundary this slice freezes.",
      "paths": [
        "backend-hormonia/app/api/v2/monitoring/wuzapi.py",
        "backend-hormonia/app/api/v2/routers/monthly_quiz_operations/public.py",
        "backend-hormonia/app/api/v2/routers/monthly_quiz_operations/crud.py",
        "frontend-hormonia/src/features/whatsapp/**",
        "frontend-hormonia/src/services/whatsapp/**",
        "frontend-hormonia/src/mocks/**",
        "frontend-hormonia/src/monitoring/**"
      ]
    }
  ],
  "scope_defaults": {
    "backend": {
      "extensions": [
        ".py"
      ],
      "exclude": [
        "backend-hormonia/tests/**",
        "backend-hormonia/docs/**",
        "backend-hormonia/app/models/**",
        "backend-hormonia/app/schemas/**",
        "backend-hormonia/app/api/v2/routers/docs/**",
        "backend-hormonia/app/api/v2/monitoring/wuzapi.py"
      ]
    },
    "frontend": {
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "exclude": [
        "frontend-hormonia/tests/**",
        "frontend-hormonia/src/**/__tests__/**",
        "frontend-hormonia/src/**/*.test.ts",
        "frontend-hormonia/src/**/*.test.tsx",
        "frontend-hormonia/src/**/*.spec.ts",
        "frontend-hormonia/src/**/*.spec.tsx",
        "frontend-hormonia/src/mocks/**",
        "frontend-hormonia/src/services/whatsapp/**",
        "frontend-hormonia/src/monitoring/**"
      ]
    }
  },
  "categories": [
    {
      "id": "firebase_uid",
      "display_name": "firebase_uid",
      "description": "Compatibility-oriented firebase_uid residue retained in backend fallback/cache/auth helpers after S04 retired root /session/* and legacy session transport from the official runtime.",
      "matchers": [
        {
          "type": "literal",
          "pattern": "firebase_uid"
        }
      ],
      "scopes": {
        "backend": {
          "roots": [
            "backend-hormonia/app/dependencies",
            "backend-hormonia/app/routers/auth_session.py",
            "backend-hormonia/app/core/redis_manager/session_cache.py",
            "backend-hormonia/app/api/v2"
          ],
          "exclude": [
            "backend-hormonia/app/api/v2/routers/admin_extensions/**",
            "backend-hormonia/app/api/v2/routers/physicians/**",
            "backend-hormonia/app/api/v2/routers/patients/base.py",
            "backend-hormonia/app/api/v2/templates_shared.py",
            "backend-hormonia/app/api/v2/routers/docs/**"
          ],
          "approved": [
            {
              "path": "backend-hormonia/app/dependencies/auth_dependencies.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "def _validate_firebase_uid(firebase_uid: str) -> None:",
                  "label": "auth_dependencies_firebase_uid_validator"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/dependencies/auth_legacy_firebase.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "firebase_uid = cached_token[\"firebase_uid\"]",
                  "label": "auth_legacy_firebase_cached_uid_lookup"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/dependencies/auth_role_dependencies.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "firebase_uid = current_user.get(\"firebase_uid\")",
                  "label": "auth_role_dependencies_current_user_fallback"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/dependencies/auth_session_cache.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "firebase_uid = session_data.get(\"firebase_uid\")",
                  "label": "auth_session_cache_compat_uid_fallback"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/dependencies/auth_session_contract.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "load_user_from_db_by_firebase_uid: Callable[[str], Any],",
                  "label": "auth_session_contract_compat_uid_loader"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/dependencies/auth_user_adapter.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "\"firebase_uid\": user.firebase_uid,",
                  "label": "auth_user_adapter_serializes_firebase_uid"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/core/redis_manager/session_cache.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "session_data[\"firebase_uid\"] = firebase_uid",
                  "label": "session_cache_persists_firebase_uid"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/api/v2/auth_session_shared.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "\"firebase_uid\": \"firebase_uid\"",
                  "label": "auth_session_shared_compat_uid_passthrough"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/api/v2/routers/admin/utils.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "\"firebase_uid\": getattr(user, \"firebase_uid\", None),",
                  "label": "admin_utils_serializes_firebase_uid"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/api/v2/routers/auth.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "user_payload[\"firebase_uid\"] = user.firebase_uid",
                  "label": "auth_router_login_payload_compat_key"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/api/v2/user_cache_shared.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "firebase_uid: Optional[str] = None,",
                  "label": "user_cache_shared_compat_uid_fallback"
                }
              ]
            }
          ]
        },
        "frontend": {
          "roots": [
            "frontend-hormonia/src/lib/api-client",
            "frontend-hormonia/src/types/admin.ts",
            "frontend-hormonia/shared-types/src/admin.ts"
          ],
          "approved": []
        }
      }
    },
    {
      "id": "x_session_id",
      "display_name": "X-Session-ID",
      "description": "Legacy X-Session-ID text that survives only in backend rejection/detection plumbing after S04 removed it as accepted staff session transport; the frontend scope remains a reintroduction guard.",
      "matchers": [
        {
          "type": "literal",
          "pattern": "X-Session-ID"
        }
      ],
      "scopes": {
        "backend": {
          "roots": [
            "backend-hormonia/app/api/v2",
            "backend-hormonia/app/api/websockets.py",
            "backend-hormonia/app/routers/auth_session.py",
            "backend-hormonia/app/dependencies/auth_dependencies.py"
          ],
          "approved": [
            {
              "path": "backend-hormonia/app/api/websockets.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "x_session_id = _mapping_get(headers, \"x-session-id\", \"X-Session-ID\")",
                  "label": "websocket_header_detection"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/dependencies/auth_dependencies.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "x_session_id: str = Header(None, alias=\"X-Session-ID\"),",
                  "label": "auth_dependencies_header_alias"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/api/v2/routers/admin/dependencies.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "request.headers.get(\"X-Session-ID\")",
                  "label": "admin_dependencies_legacy_header_detection"
                }
              ]
            }
          ]
        },
        "frontend": {
          "roots": [
            "frontend-hormonia/src/lib/api-client"
          ],
          "approved": []
        }
      }
    },
    {
      "id": "session_bearer_fallback",
      "display_name": "session-as-Bearer fallback",
      "description": "Authorization: Bearer <session_id> text that survives only in backend rejection/detection plumbing after S04 removed it as accepted staff session transport; the frontend scope remains a reintroduction guard.",
      "matchers": [
        {
          "type": "literal",
          "pattern": "Bearer "
        },
        {
          "type": "literal",
          "pattern": "Bearer <session_id>"
        },
        {
          "type": "literal",
          "pattern": "Bearer session_id"
        }
      ],
      "scopes": {
        "backend": {
          "roots": [
            "backend-hormonia/app/api/v2",
            "backend-hormonia/app/dependencies/auth_session_contract.py"
          ],
          "exclude": [
            "backend-hormonia/app/api/v2/routers/platform_sync.py"
          ],
          "approved": [
            {
              "path": "backend-hormonia/app/dependencies/auth_session_contract.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "if authorization and authorization.startswith(\"Bearer \"):",
                  "label": "auth_session_contract_bearer_priority"
                }
              ]
            },
            {
              "path": "backend-hormonia/app/api/v2/routers/admin/dependencies.py",
              "anchors": [
                {
                  "type": "literal",
                  "pattern": "or (auth_header and auth_header.startswith(\"Bearer \"))",
                  "label": "admin_dependencies_legacy_bearer_detection"
                }
              ]
            }
          ]
        },
        "frontend": {
          "roots": [
            "frontend-hormonia/src/lib/api-client"
          ],
          "approved": []
        }
      }
    },
    {
      "id": "websocket_session_id_query",
