1482: class TestUser(dict):
1483:     """Dictionary-backed test user with attribute access for User fields."""
1484: 
1485:     def __init__(self, user: User, password: str):
1486:         super().__init__(
1487:             id=str(user.id),
1488:             email=user.email,
1489:             password=password,
1490:             full_name=user.full_name,
1491:             role=user.role,
1492:             user=user,
1493:             firebase_uid=getattr(user, "firebase_uid", None),
1494:             is_active=user.is_active,
1495:             created_at=user.created_at.isoformat() if user.created_at else None,
1496:             updated_at=user.updated_at.isoformat() if user.updated_at else None,
1497:             last_login=user.last_login.isoformat() if user.last_login else None,
1498:             display_name=user.get_display_name() if hasattr(user, "get_display_name") else getattr(user, "display_name", user.full_name),
1499:             photo_url=user.get_photo_url() if hasattr(user, "get_photo_url") else getattr(user, "photo_url", None),
1500:             preferences=user.get_preferences_data() if hasattr(user, "get_preferences_data") else dict(getattr(user, "preferences", {}) or {}),
1501:         )
1502:         self.user = user
1503:         self.password = password
1504:         self.access_token = f"test_session_{user.id}"
1505: 
1506:     def __getattr__(self, name):
1507:         if hasattr(self.user, name):
1508:             return getattr(self.user, name)
1509:         if name in self:
1510:             return self[name]
1511:         raise AttributeError(name)
1512: 
1513:     def __setattr__(self, name, value):
1514:         if name in {"user", "password", "access_token"} or name.startswith("_"):
1515:             object.__setattr__(self, name, value)
1516:             return
1517:         if hasattr(self, "user") and hasattr(self.user, name):
1518:             setattr(self.user, name, value)
1519:             return
1520:         if name in self:
1521:             self[name] = value
1522:             return
1523:         object.__setattr__(self, name, value)
1524: 
1525:     def session_dict(self) -> dict:
1526:         role = self.user.role.value if hasattr(self.user.role, "value") else str(self.user.role)
1527:         return {
1528:             "id": str(self.user.id),
1529:             "email": self.user.email,
1530:             "full_name": self.user.full_name,
1531:             "role": role,
1532:             "is_active": self.user.is_active,
1533:             "firebase_uid": getattr(self.user, "firebase_uid", None),
1534:             "created_at": self.user.created_at.isoformat() if self.user.created_at else None,
1535:             "updated_at": self.user.updated_at.isoformat() if self.user.updated_at else None,
1536:             "last_login": self.user.last_login.isoformat()
1537:             if self.user.last_login
1538:             else None,
1539:             "display_name": self.user.get_display_name() if hasattr(self.user, "get_display_name") else getattr(self.user, "display_name", self.user.full_name),
1540:             "photo_url": self.user.get_photo_url() if hasattr(self.user, "get_photo_url") else getattr(self.user, "photo_url", None),
1541:             "preferences": self.user.get_preferences_data() if hasattr(self.user, "get_preferences_data") else dict(getattr(self.user, "preferences", {}) or {}),
