# Configuração de Ambiente - Docker / Railway
# Copie este arquivo para .env e preencha com seus valores

# ================================
# DATABASE CONFIGURATION (AWS RDS)
# ================================
DATABASE_URL=postgresql://your-aws-rds-endpoint:5432/clinica_oncologica
DATABASE_USER=postgres
DATABASE_PASSWORD=super-secure-password

# ================================
# BACKEND API CONFIGURATION
# ================================
VITE_API_URL=http://localhost:8000/api/v2

# ================================
# BACKEND CONFIGURATION
# ================================
NODE_ENV=production
PORT=8000

# ================================
# RAILWAY SPECIFIC (if deploying to Railway)
# ================================
# Não é necessário configurar PORT no Railway - ele injeta automaticamente
# RAILWAY_ENVIRONMENT=production
