# =============================================================================
# HORMONIA PROJECT - ROOT ENVIRONMENT TEMPLATE
# =============================================================================
# ENV Variable Naming Convention: {CATEGORY}_{SUBCATEGORY}_{ATTRIBUTE}_{UNIT}
# Copy this file to .env and fill with your actual values
# =============================================================================

# ============================================================================
# DATABASE CONFIGURATION - DATABASE_*
# ============================================================================
DATABASE_URL=postgresql://your-aws-rds-endpoint:5432/clinica_oncologica
DATABASE_USER=postgres
DATABASE_PASSWORD=super-secure-password

# ============================================================================
# BACKEND API CONFIGURATION - VITE_API_*
# ============================================================================
VITE_API_ENDPOINT_URL=http://localhost:8000/api/v2
VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# APPLICATION CONFIGURATION - APP_*
# ============================================================================
APP_ENVIRONMENT=production
APP_DEBUG=false
APP_PORT=8000

# ============================================================================
# RAILWAY SPECIFIC (if deploying to Railway)
# ============================================================================
# Railway automatically injects PORT - no need to configure
# RAILWAY_ENVIRONMENT=production
