# Configuração de Ambiente - Docker / Railway
# Copie este arquivo para .env e preencha com seus valores

# ================================
# SUPABASE CONFIGURATION
# ================================
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anonima-aqui
SUPABASE_SERVICE_KEY=sua-chave-de-servico-aqui

# ================================
# FRONTEND CONFIGURATION
# ================================
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
VITE_API_URL=http://localhost:8000

# ================================
# BACKEND CONFIGURATION
# ================================
NODE_ENV=production
PORT=8000

# ================================
# RAILWAY SPECIFIC (if deploying to Railway)
# ================================
# Não é necessário configurar PORT no Railway - ele injeta automaticamente
# RAILWAY_ENVIRONMENT=production
